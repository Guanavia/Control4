    <dependency>AddMusic.c4z</dependency>
    <dependency>Stations.c4z</dependency>
    <dependency>Channels.c4z</dependency>
  </dependencies>
  <audioPlayLoadFactor>150</audioPlayLoadFactor>
  <audio_dev_type>corelite</audio_dev_type>
  <driver>100063</driver>
