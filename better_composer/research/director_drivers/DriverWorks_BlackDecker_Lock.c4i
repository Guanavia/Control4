        <commands>
            <command>
                <name>Lock</name>
                <description>Lock the NAME</description>
            </command>
            <command>
                <name>Unlock</name>
                <description>Unlock the NAME</description>
            </command>
            <command>
                <name>Toggle</name>
                <description>Toggle the NAME</description>
            </command>
            <command>
                <name>Set Name, Code</name>
                <description>Set User PARAM1 lock code to PARAM2 on the NAME</description>
                <params>
                    <param>
                        <name>User ID</name>
                        <type>STRING</type>
                        <default> </default>
                    </param>
                    <param>
                        <name>Name, Code</name>
                        <type>STRING</type>
                        <default> </default>
                    </param>
                </params>
            </command>
            <command>
                <name>Delete Code</name>
                <description>Delete User PARAM1 lock code from the NAME</description>
                <params>
                    <param>
                        <name>User ID</name>
                        <type>STRING</type>
                        <default> </default>
                    </param>
                </params>
            </command>
            <command>
                <name>Delete All Codes</name>
                <description>Delete all lock codes from the NAME</description>
            </command>
            <command>
                <name>Show Codes</name>
                <description>Retrieve lock codes from the NAME</description>
            </command>
            <command>
                <name>Hide Codes</name>
                <description>Hide codes on the NAME</description>
            </command>
            <command>
                <name>Debug Command</name>
                <description>Execute Debug Command 'PARAM1' on the NAME</description>
                <params>
                    <param>
                        <name>Command</name>
                        <type>STRING</type>
                        <default> </default>
                    </param>
                </params>
            </command>
        </commands>
