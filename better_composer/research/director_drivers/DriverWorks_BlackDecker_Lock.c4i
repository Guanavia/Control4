    <capabilities/>
    <events>
        <event>
            <id>1</id>
            <name>Unlocked Manually</name>
            <description>Lock was unlocked using knob</description>
        </event>
        <event>
            <id>2</id>
            <name>Locked Manually</name>
            <description>Lock was locked using knob</description>
        </event>
        <event>
            <id>3</id>
            <name>Unlocked</name>
            <description>Lock was unlocked</description>
        </event>
        <event>
            <id>4</id>
            <name>Locked</name>
            <description>Lock was locked</description>
        </event>
        <event>
            <id>5</id>
            <name>Not Locked</name>
            <description>Lock was not fully locked (possibly jammed)</description>
        </event>
        <event>
            <id>6</id>
            <name>Incorrect Code Lockout</name>
            <description>Incorrect code(s) entered 3 times, lock has locked out</description>
        </event>
        <event>
            <id>7</id>
            <name>Invalid Schedule</name>
            <description>User attempted to unlock outside of approved schedule</description>
        </event>
        <event>
            <id>8</id>
            <name>Low Battery</name>
            <description>The battery in the lock is low</description>
        </event>
        <event>
            <id>9</id>
            <name>Very Low Battery</name>
            <description>The battery in the lock is very low</description>
        </event>
        <event>
            <id>10</id>
            <name>Battery Cannot Operate Motor</name>
            <description>The battery in the lock is too low to operate the motor</description>
        </event>
    </events>
