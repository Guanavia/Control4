  <name>Saflok Hub</name>
  <model>MT ZigBee</model>
  <version>149</version>
  <control>lua_gen</control>
  <combo>true</combo>
  <OnlineCategory>others</OnlineCategory>
  <proxy>SaflokHub</proxy>
  <driver>DriverWorks</driver>
  <search_type>saflok:mt2:001</search_type>
  <connections>
    <connection>
      <id>6002</id>
      <facing>6</facing>
      <connectionname>Zigbee Device Connection</connectionname>
      <type>4</type>
      <consumer>True</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>False</linelevel>
      <classes>
        <class>
          <classname>ZIGBEE</classname>
        </class>
      </classes>
    </connection>
  </connections>
  <config>
    <documentation>Control4 certified on 6/28/2010 for software released versions: 1.8.2, 2.0.0.

Control4 certified on 6/28/2010 for software released versions: 1.8.2, 2.0.0.


	This Lua version of Saflok Hub is designed to support battery operated Saflok MT2 ZigBee lock.
	The locks communicate through this Control4 Lua driver to the Saflok 6000 Messenger server.
    </documentation>
    <properties>
      <property>
        <name>Messenger Server Name</name>
        <type>STRING</type>
        <default />
        <readonly>true</readonly>
      </property>
      <property>
        <name>Status Report Interval</name>
        <type>STRING</type>
        <default />
        <readonly>true</readonly>
      </property>
      <property>
        <name>Saflok hubID</name>
        <type>STRING</type>
        <default>0</default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Kaba deviceID</name>
        <type>STRING</type>
        <default />
        <readonly>true</readonly>
      </property>
      <property>
        <name>C4 DeviceID</name>
        <type>STRING</type>
        <default>0</default>
        <readonly>True</readonly>
      </property>
      <property>
        <name>Lua Driver Version</name>
        <type>STRING</type>
        <default />
        <readonly>True</readonly>
      </property>
      <property>
        <name>Debug Mode</name>
        <type>LIST</type>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
        <default>Off</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>commission</name>
        <type>LIST</type>
        <items>
          <item>factory</item>
          <item>enabled</item>
          <item>locked</item>
        </items>
        <default>factory</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Encryption</name>
        <type>LIST</type>
        <items>
          <item>On</item>
          <item>Off</item>
        </items>
        <default>Off</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Logging Level</name>
        <type>LIST</type>
        <items>
          <item>DEBUG2</item>
          <item>DEBUG1</item>
          <item>DEBUG0</item>
          <item>DEBUG</item>
          <item>INFO</item>
          <item>WARN</item>
          <item>ERROR</item>
          <item>FATAL</item>
        </items>
        <default>INFO</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Messenger Server IP</name>
        <type>STRING</type>
        <default>127.0.0.1</default>
        <readonly>false</readonly>
      </property>
    </properties>
    <actions>
      <action>
        <name>Kill All Timers</name>
        <command>KILL_ALL_TIMERS</command>
      </action>
      <action>
        <name>Print Status</name>
        <command>PRINT_STATUS</command>
      </action>
      <action>
        <name>Print Lock FW Versions</name>
        <command>PRINT_LOCK_FW_VERSIONS</command>
      </action>
      <action>
        <name>Print Lock Config</name>
        <command>PRINT_LOCK_CONFIG</command>
      </action>
      <action>
        <name>Print Persistent Data</name>
        <command>PRINT_PERSIST_DATA</command>
      </action>
      <action>
        <name>Send Hub Delete Msg</name>
        <command>SEND_HUB_DELETE</command>
      </action>
      <action>
        <name>Send Lock Delete Msg</name>
        <command>SEND_LOCK_DELETE</command>
      </action>
      <action>
        <name>Send Device Assign Msg</name>
        <command>SEND_DEVICE_ASSIGN</command>
      </action>
      <action>
        <name>Send Hub Start Msg</name>
        <command>SEND_HUB_START</command>
      </action>
      <action>
        <name>Send Device Status</name>
        <command>SEND_DEVICE_STATUS</command>
      </action>
      <action>
        <name>Request Device Identify</name>
        <command>REQUEST_DEVICE_IDENTIFY</command>
      </action>
      <action>
        <name>Request Device Status</name>
        <command>REQUEST_DEVICE_STATUS</command>
      </action>
      <action>
        <name>Start F/W Update</name>
        <command>OTA_UPDATE</command>
      </action>
    </actions>
    <commands>
      <command>
        <name>Send Hub Start</name>
        <description>Send hub start message to Messenger server</description>
      </command>
      <command>
        <name>Send device assign</name>
        <description>Send lock assignment message to Messenger</description>
      </command>
      <command>
        <name>Reset to factory</name>
        <description>Reset to factory state and send hub start</description>
      </command>
    </commands>
