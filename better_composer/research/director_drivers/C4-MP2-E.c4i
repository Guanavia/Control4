-- return the next usable resolution
function GetNextSwitchableRes(DirArray)
	-- first check to make sure they have at least one set to true
	local haveAtLeastOne = false
 	for index,pName in pairs(DirArray)do
		if (Properties[pName] == "true") then
			haveAtLeastOne = true
			break
	  end
	end
  if (haveAtLeastOne == false) then
	  return nul
	end

	local bUseNext = false;
	if (g_lastSwitchableSelected == "") then
		--if they haven't selected any yet - pick the first one
		bUseNext = true;
	end
 	for index,pName in pairs(DirArray)do
		if (bUseNext) then
			if (Properties[pName] == "true") then
			 	g_lastSwitchableSelected = pName
				return(pName)
			end
		elseif (pName == g_lastSwitchableSelected) then
			-- we found the last guy we used - set use next to true
			bUseNext = true
		end
	end
	-- if we made it this far then they are at the last one - call again and pick the first
	g_lastSwitchableSelected = ""
	return(GetNextSwitchableRes(DirArray))
end



-----------------------------------------  timer functions -----------------------------------------
function CancelOffTimer()
  if (g_powerOffTimer ~= 0) then
	 C4:KillTimer(g_powerOffTimer)
  end
  g_powerOffTimer = 0
end

function CancelQueueTimer()
  if (g_queueTimer ~= 0) then
	 g_queueTimer = C4:KillTimer(g_queueTimer)
  end
  g_queueTimer = 0
end

function CancelPlayTimer()
  if (g_playTimer ~= 0) then
    g_playTimer = C4:KillTimer(g_playTimer)
  end
  g_playTimer = 0
end

function CancelPingTimer()
  if (g_pingTimer ~= 0) then
    g_pingTimer = C4:KillTimer(g_pingTimer)
  end
  g_pingTimer = 0
end

 ----------------------------------------- Command Functions -----------------------------------------
function CMDS.PLAY_THIS_FILE(BindingID, Params)
  CancelOffTimer()
  location = Params["FILE"]
  if ((location ~= nil) and (location ~= g_location)) then
	  g_location = location
    if (Properties["Restart Playback on Reselect"] == "true") then
      CancelPlayTimer()
      g_playTimer = C4:AddTimer(2,"SECONDS")
    end
	  -- Send a play event for programming
	  -- we should get back a "play" from the device C4:SendToProxy(BindingID, "PLAY", {})
	  -- Stop any currently playing files
	  -- they didn't want a stop SendCmd(CMDS.Stop)
	  user = Params["USER"]
	  pass = Params["PASSWORD"]
	  title = Params["TITLE"]
    if ((title) and (title ~= "")) then
  		SendCmd(CMDS.SetTitleText, title)
    else
  		SendCmd(CMDS.SetTitleText, "Video")
    end
	  SendPlayFile(location, user, pass)
  end
end

function CMDS.ON(BindingID, Params)
  CancelOffTimer()
  SendCmd(CMDS.PowerOn)
  --should be called from driver response C4:SendToProxy(BindingID, "ON", {})
end

function CMDS.OFF(BindingID, Params)
  CancelOffTimer()
  -- Stop any currently playing files
  SendCmd(CMDS.Stop)
  g_powerOffTimer = C4:AddTimer(5,"SECONDS")
  g_location = ""
end

function CMDS.PLAY(BindingID, Params)
  SendCmd(CMDS.Play)
  --should be called from driver response C4:SendToProxy(BindingID, "PLAY", {})
end

function CMDS.STOP(BindingID, Params)
  SendCmd(CMDS.Stop)
  --should be called from driver response C4:SendToProxy(BindingID, "STOP", {})
  g_location = ""
end

function CMDS.PAUSE(BindingID, Params)
  SendCmd(CMDS.Pause)
  --should be called from driver response C4:SendToProxy(BindingID, "PAUSE", {})
end

function CMDS.SET_PROPERTIES(tParams)
	-- send down stored properties in driver
  SendCmd(CMDS.AudioDownmix, "passthrough")
	SendCmd(CMDS.BackgroundUrl, Properties[PropertyNames.BgUrl])
	SendCmd(CMDS.ScreenSaverUrl, Properties[PropertyNames.SSUrl])
	SendCmd(CMDS.Resolution, ResolutionNamesToModes[Properties[PropertyNames.Resolution]])
	SendCmd(CMDS.UpdateURL, makeHttpCompliant(Properties["Update URL"], true))
end

function CMDS.GET_PROPERTIES(tParams)
  SendCmd(CMDS.PowerQuery)
  SendCmd(CMDS.StatusQuery)
  SendCmd(CMDS.VersionNumber)
  SendCmd(CMDS.Resolution)
  SendCmd(CMDS.AudioDownmix)
  SendCmd(CMDS.BackgroundUrl)
  SendCmd(CMDS.ScreenSaverUrl)
end

