end
 
function CMDS.PAGE_UP(tParams)
  local newRes = GetNextSwitchableRes(PropertySwitchableResolutionsNext)
	if (newRes) then
		dbg("Next res is " .. newRes)
 		Properties.Resolution = newRes
		C4:UpdateProperty("Resolution", newRes)
		SendCmd(CMDS.Resolution, ResolutionNamesToModes[newRes])
	end
end

function CMDS.PAGE_DOWN(tParams)
  local newRes = GetNextSwitchableRes(PropertySwitchableResolutionsPrev)
	if (newRes) then
		dbg("Prev res is " .. newRes)
 		Properties.Resolution = newRes
		C4:UpdateProperty("Resolution", newRes)
		SendCmd(CMDS.Resolution, ResolutionNamesToModes[newRes])
	end
end

function CMDS.RIGHT(tParams)
  -- send the simple menu cmd
 	SendCmd(CMDS.Right)
  -- also send the Next Title cmd
