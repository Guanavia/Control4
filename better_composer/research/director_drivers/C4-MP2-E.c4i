--------------- global vars  ---------------------
g_expectedVersion = "2.0.22.39"
g_defaultUrlForUpdate = "http://update.control4.com/release-pro/firmware/Control4MediaPlayer-2.0.22.39.fw"

----- Everything below this point should be the same for C4-MP1-E.c4i and C4-MP2-E.c4i
----- So if you make any changes, make it in both!

g_location = ""
