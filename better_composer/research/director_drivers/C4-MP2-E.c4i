end
 
function CMDS.LEFT(tParams)
  -- send the simple menu cmd
 	SendCmd(CMDS.Left)
  -- also send the Next Title cmd
  SendCmd(CMDS.PrevTitle)
end

function ReceivedFromProxy(BindingID, Command, Params)

  if (g_tcpConnected == false) then
	  dbg("Received command from proxy with no connection to device.  Verify device's ip address")
  end
  dbg("ReceivedFromProxy called with command: " .. Command)
  if ((nil ~= tParams) and (tParams ~= "")) then
	 for pName, pValue in pairs(Params) do
		dbg("..Parameter: " .. pName .. " with value: " .. pValue)
	 end
  end

  -- First try our function LUT
  cmd = CMDS[Command]   -- ON, OFF, PLAY, STOP, PAUSE
  if ((cmd ~= nil) and (type(cmd) == "function")) then
	 cmd(BindingID, Params)
	 return
  end

  -- OK. Lets try the simple commands
  if (cmd ~= nil) then
	 SendCmd(cmd)
	return
  end

  dbg("Unhandled Command: " .. Command)
end

function SendCmd(strCmd, params)
  -- Generate Command based on parameters passed...
  local len = 1
  if (nil ~= params) then
	 len = len + string.len(params)
  end

  local cmd = string.pack("b>Hb", 0xC4, len, strCmd)
  if (nil ~= params) then
	 cmd = cmd .. params
  end

  if (g_debugprint) then
	 dbg("SendChangerCmd: ")
	 hexdump(cmd)
  end
  C4:SendToNetwork(TCP_BINDING_ID, TCP_PORT, cmd)
end

function uriEscape(s)
  -- see rfc 2396
     return string.gsub(s, "([^A-Za-z0-9-_.!~*%'%(%)%/%/])", function(c)
        return string.format("%%%02x", string.byte(c))
    end)
end

function makeHttpCompliant(data, hasLoc)
  -- see rfc 2396
  start = ""
	if (hasLoc) then
		-- it has something://somePath
		pos = string.find(data, ":")
		if (pos) then
			start = string.sub(data, 0, pos)
			data = string.sub(data, pos + 1)
		end
	end
	data = uriEscape(data)
	return(start .. data)
end


function SendPlayFile(fileLoc, user, pass)
   -- first strip any leader slashes - look like "//servername/share/folder/filename" - want in form "servername/share/folder/filename"
  local slashPos = string.find(fileLoc, "/")
	while (slashPos == 1) do
       fileLoc = string.sub(fileLoc, 2)
	   slashPos = string.find(fileLoc, "/")
	end
  if (user ~= nil) then
  -- should look like: smb://username:password@servername/share/folder/filename.mpg
	 sessionMsg = [[smb://]]
	 sessionMsg = sessionMsg .. uriEscape(user)
	 sessionMsg = sessionMsg .. ":"
	 sessionMsg = sessionMsg .. uriEscape(pass)
	 sessionMsg = sessionMsg .. "@"
  else
  -- should look like: smb://servername/share/folder/filename.mpg
	 sessionMsg = [[smb://]]
  end
	fileLoc = uriEscape(fileLoc);
  sessionMsg = sessionMsg .. fileLoc
  SendCmd(CMDS.OpenVideoFile, sessionMsg)
end

-- handles unpacking of status message received from the device
function HandleUpdateStatus(updateSts)
  local code = "Unknown update code"
  local msg = nil
  if (UPDATE_STS[string.byte(updateSts, 1)] ~= nil) then
    code = UPDATE_STS[string.byte(updateSts, 1)]
    dbg("Code is " .. code)
    msg = string.sub(updateSts, 2)
    if (code == "Status") then
      subcode = string.byte(updateSts, 2)
      msg = string.sub(updateSts, 3)
    end
  end
  if (msg ~= nil) then
    C4:UpdateProperty(PropertyNames.UpdateStatus, "code: " .. code .. " status: " .. msg)
  else
    C4:UpdateProperty(PropertyNames.UpdateStatus, "code: " .. code)
  end
end

---------------------- call to dispatch all data from device --------------------------

function ReceivedFromNetwork(idBinding, nPort, strData)
  PrintPacket("ReceivedFromNetwork - port " .. nPort, strData)
  if (nPort == TCP_PORT) then
		g_receiveBuffer = g_receiveBuffer .. strData
	-- Find 0xC4 in buf... If not at first, move to top...
	  local pos --position in the buffer of the start current packet
	  local hdr --position in the buffer of the start of the c4 header
	  local len --the length (as reported by the device) of the current packet
	  local cmd --the cmd from the packet

	  local startpos = string.find(g_receiveBuffer, tohex("C4"), 1, true)
	  while (startpos ~= nil) do

		-- If 0xC4 not found in position 1, delete anything up to the 0xC4...
		if (startpos ~= 1) then
		  g_receiveBuffer = string.sub(g_receiveBuffer, startpos)
		end

		-- If there aren't at least 4 characters, we don't have a full msg header to parse out...
		if (string.len(g_receiveBuffer) < 4) then
		  return
		end

		-- Unpack header, see what we've got...
		hexdump(g_receiveBuffer)
		pos, hdr, len, cmd = string.unpack(g_receiveBuffer, "b>Hb")
		dbg("CMD Header Found:   Pos: " .. pos .. " Len: " .. len .. " Cmd: " .. cmd)

		-- If we don't have full message (length of rest of message + 0xC4 + length (2 bytes))
		if (string.len(g_receiveBuffer) < (3 + len)) then
		  dbg("Full Data not received... returning")
		  return
		end

		-- Call function for this notify, if there is one...
		if (cmd == CMDS.STS_Power) then
		  hexdump(g_receiveBuffer)
		  local _, onoff = string.unpack(g_receiveBuffer, "b", pos)
		  dbg("Power Notify, pos is " .. pos .. ", onoff is " .. onoff)
      if (g_powerStatus ~= onoff) then
		    if (onoff == 0x01) then
			    C4:SendToProxy(ID_PROXY, "ON", {})
			    dbg("Sending ON to Proxy")
		    else
			    C4:SendToProxy(ID_PROXY, "OFF", {})
			    dbg("Sending OFF to Proxy")
		    end
      end
      g_powerStatus = onoff
		end
		if (cmd == CMDS.STS_Playing) then
			C4:SendToProxy(ID_PROXY, "PLAY", {})
			dbg("Sending PLAY to Proxy")
		end
		if (cmd == CMDS.STS_Stopped) then
			C4:SendToProxy(ID_PROXY, "STOP", {})
			dbg("Sending STOP to Proxy")
		end
		if (cmd == CMDS.STS_Paused) then
			C4:SendToProxy(ID_PROXY, "PAUSE", {})
			dbg("Sending PAUSE to Proxy")
		end
		if (cmd == CMDS.STS_Error) then
			errorMsg = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			if (len > 1) then
				dbg("Received error from player - error is" .. errorMsg)
				C4:UpdateProperty(PropertyNames.LastError, errorMsg)
			else
				dbg("Received error from player - no data")
				C4:UpdateProperty(PropertyNames.LastError, "No data")
			end
		end
		if (cmd == CMDS.STS_VersionNumber) then
			firmwareVersion = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			firmwareVersion = string.gsub(firmwareVersion, "\n", "")
			firmwareVersion = string.gsub(firmwareVersion, "\r", "")
			C4:UpdateProperty(PropertyNames.FirmwareVersion, firmwareVersion)
			CheckVersionAndUpdate(firmwareVersion)
		end
		if (cmd == CMDS.STS_Update) then
			updateSts = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			HandleUpdateStatus(updateSts)
		end
		if (cmd == CMDS.STS_Resolution) then
			resol = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			C4:UpdateProperty(PropertyNames.CurrentResolution, resol)
		end
		if (cmd == CMDS.STS_AudioMode) then
			local dwnMix = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			if (dwnMix == "stereo") then
			  C4:UpdateProperty(PropertyNames.AudioDownmixSetting, "true")
			else
			  C4:UpdateProperty(PropertyNames.AudioDownmixSetting, "false")
			end
		end
		if (cmd == CMDS.STS_BackgroudUrl) then
			local bgUrl = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			C4:UpdateProperty(PropertyNames.BgUrl,  bgUrl)
		end
		if (cmd == CMDS.STS_ScreenSaverUrl) then
			local ssUrl = string.sub(g_receiveBuffer, pos, pos + (len - 2))
			C4:UpdateProperty(PropertyNames.SSUrl,  ssUrl)
		end


		-- FF past data section...
		pos = pos + (len - 1)

		g_receiveBuffer = string.sub(g_receiveBuffer, pos)
		startpos = string.find(g_receiveBuffer, tohex("C4"), 1, true)
	  end
	end
end


function OnTimerExpired(idTimer)
  if (idTimer == g_enquedPacketTimer) then
	 if (g_SendBuffer ~= nil) then
		if (g_tcpConnected) then
		SendToNetwork(TCP_BINDING_ID, TCP_PORT, g_SendBuffer)
		  g_SendBuffer = nil
		else
		  -- we need to readd the queue timer because the device is still offline
		  CancelQueueTimer()
		  g_queueTimer = C4:AddTimer(1,"SECONDS")
		end
	 end
  elseif (idTimer == g_DebugTimer) then
	 dbg("Turning Debug Mode back to Print [default] (timer expired)")
	 C4:UpdateProperty("Debug Mode", "Print")
  elseif (idTimer == g_powerOffTimer) then
		  g_powerOffTimer = 0
		  dbg("OnTimerExpired - g_powerOffTimer sending off")
		  SendCmd(CMDS.PowerOff)
		  --should be called from driver response C4:SendToProxy(ID_PROXY, "OFF", {})
  elseif (idTimer == g_playTimer) then
  	  g_location = nil
  elseif (idTimer == g_pingTimer) then
    if (g_tcpConnected == true) then
  	  SendCmd(CMDS.Ping)
    end
	else 
		C4:KillTimer(idTimer)
  end

end

function OnConnectionStatusChanged(idBinding, nPort, strStatus)
	dbg("OnConnectionStatusChanged nPort " .. nPort .. " status = " .. strStatus)
	if (nPort == TCP_PORT) then
		if (strStatus == "ONLINE") then
			g_tcpConnected = true
			CMDS.SET_PROPERTIES()
			CMDS.GET_PROPERTIES()
			-- make sure the device has our stored url
			SendCmd(CMDS.UpdateURL, makeHttpCompliant(Properties["Update URL"], true))
		else
			-- tcp off line - not good
			g_tcpConnected = false
		end
	 end
end

function ExecuteCommand(strCommand, tParams)
  dbg("ExecuteCommand function called with : " .. strCommand)
  if (tParams == nil) then
    if (strCommand =="GET_PROPERTIES") then
      CMDS.GET_PROPERTIES()
    else
      print ("From ExecuteCommand Function - Unutilized command: " .. strCommand)
    end
  end
  if (strCommand == "LUA_ACTION") then
    if tParams ~= nil then
      for cmd,cmdv in pairs(tParams) do
        print (cmd,cmdv)
        if cmd == "ACTION" then
          if cmdv == "StartUpdate" then
        		SendCmd(CMDS.StartUpdate)
          else
            dbg("From ExecuteCommand Function - Undefined Action")
            dbg("Key: " .. cmd .. "  Value: " .. cmdv)
          end
        else
          dbg("From ExecuteCommand Function - Undefined Command")
          dbg("Key: " .. cmd .. "  Value: " .. cmdv)
        end
      end
    end
  end
end

function OnDriverDestroyed()
  dbg("OnDriverDestroyed called")
  CancelOffTimer()
  g_receiveBuffer = ""
  g_SendBuffer = ""
  if (g_DebugTimer ~= 0) then
	 g_DebugTimer = C4:KillTimer(g_DebugTimer)
  end
  CancelQueueTimer()
  CancelPlayTimer()
  CancelPingTimer()
end

-- Fire On Property Changed to set Property global sets, they'll change if Property is changed.
for k,v in pairs(Properties) do
  OnPropertyChanged(k)
end

-- get any other stuff from the device
CMDS.GET_PROPERTIES(tParams)


-----------  stuff to get the firmware version on the director box -----------
function connect(address, port, laddress, lport)
    local sock, err = socket.tcp()
    if not sock then return nil, err end
    if laddress then
        local res, err = sock:bind(laddress, lport, -1)
        if not res then return nil, err end
    end
    local res, err = sock:connect(address, port)
    if not res then return nil, err end
    return sock
end

