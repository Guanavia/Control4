g_queueTimer = 0
g_playTimer = 0
g_receiveBuffer = "" 
g_tcpConnected = false
g_powerStatus = -1 --init to invalid
g_triedUpdate = false


function ParseVersions(firmwareVersionString)
    local d1 = string.find(firmwareVersionString, "%p")
    local d2 = string.find(firmwareVersionString, "%p", d1 + 1)
    local d3 = string.find(firmwareVersionString, "%p", d2 + 1)
		if ((d1 == nill) or (d2 == nill) or (d3 == nill)) then
			print("Unable to verify version - no firmware update will be initiated")
			return false
		end
		local major = string.sub(firmwareVersionString, 0, d1-1)
		local minor = string.sub(firmwareVersionString, d1+1, d2-1)
		local build = string.sub(firmwareVersionString, d2+1, d3-1)
		local rev = string.sub(firmwareVersionString, d3+1);
		if ((major == nill) or (minor == nill) or (build == nill) or (rev == nill)) then
			print("Unable to verify version - no firmware update will be initiated")
			return false
		end
		t1 = tonumber(major)
		t2 = tonumber(minor)
		t3 = tonumber(build)
		t4 = tonumber(rev)	
		if ((t1 == nill) or (t2 == nill) or (t3 == nill) or (t4 == nill)) then
			print("Unable to verify version - non numeric version data - no firmware update will be initiated")
			return false
		end
			
		return true, tonumber(major), tonumber(minor), tonumber(build), tonumber(rev)
end

function IsExpectedVersionNewerThanFirmwareVersion(firmwareVersion)
    good, major, minor, build, rev = ParseVersions(g_expectedVersion)
		if (good == false) then
			return(false)
	  end
		dbg("Expected ver:   Maj:" .. major .. " Min:" .. minor .. " Bld: " .. build .. " Rev:" .. rev)
			
    good, fmajor, fminor, fbuild, frev = ParseVersions(firmwareVersion)
		if (good == false) then
			return(false)
	  end
		dbg("Firmware ver:   Maj:" .. fmajor .. " Min:" .. fminor .. " Bld: " .. fbuild .. " Rev:" .. frev)
			
		if (major < fmajor) then 
	        return false	
		elseif (major > fmajor) then
				dbg("Expected major greater - firmware update initiated");
				return true
		end
		if (minor < fminor) then
			return false
		elseif (minor > fminor) then
				dbg("Expected minor greater - firmware update initiated");
				return true
		end
		if (build < fbuild) then
			return false
		elseif (build > fbuild) then
				dbg("Expected build greater - firmware update initiated");
				return true
		end
		if (rev < frev) then
			return false
		elseif (rev > frev) then
				dbg("Expected rev greater - firmware update initiated");
				return true
		end
		dbg("Expected equals target");
		return false
end



--------------  hard coded version and URL for updates ---------------------
function CheckVersionAndUpdate(firmwareVersion)
  if (Properties["Auto Updates Enabled"] == "true") then
		if ((firmwareVersion ~= "") and (firmwareVersion ~= g_expectedVersion)) then
			 if (g_triedUpdate == false) then
					if (IsExpectedVersionNewerThanFirmwareVersion(firmwareVersion)) then
						dbg("Current firmware version (" .. firmwareVersion .. ") needs to be updated to (" .. g_expectedVersion .. ").  Starting update.")
						SendCmd(CMDS.StartUpdate)
						g_triedUpdate = true
					end
			 else 
					dbg("Different firmware detected - already attempted update - no automatic update will be initiated")
			 end
		end
	end
end

g_pingTimer = C4:AddTimer(30,"SECONDS", true)

--------------- property handling ------------------
function OnPropertyChanged(strProperty)
	if (strProperty == "Debug Mode") then
		if (Properties[strProperty] == "Off") then
			g_debugprint = false
			g_debuglog = false
			g_DebugTimer = 0
		 end
		 if (Properties[strProperty] == "Print") then
			g_debugprint = true
			g_debuglog = false
			startDebugTimer()
		 end
		 if (Properties[strProperty] == "Log") then
			g_debugprint = false
			g_debuglog = true
			startDebugTimer()
		 end
		 if (Properties[strProperty] == "Print and Log") then
			g_debugprint = true
			g_debuglog = true
			startDebugTimer()
		 end
  end
  if (strProperty == PropertyNames.Resolution) then
		SendCmd(CMDS.Resolution, ResolutionNamesToModes[Properties[strProperty]])
  end
  if (strProperty == "Update URL") then
		if (Properties[strProperty] == "") then
			Properties[strProperty] = g_defaultUrlForUpdate
			C4:UpdateProperty(strProperty, g_defaultUrlForUpdate)
		end
		SendCmd(CMDS.UpdateURL, makeHttpCompliant(Properties["Update URL"], true))
  end
  if (strProperty == PropertyNames.StartUpdate) then
		SendCmd(CMDS.StartUpdate)
  end
  if (strProperty == PropertyNames.AudioDownmix) then
    if (Properties[strProperty] == "true") then
		  SendCmd(CMDS.AudioDownmix, "stereo")
    else
		  SendCmd(CMDS.AudioDownmix, "passthrough")
    end
    -- following used to verify and update property
    SendCmd(CMDS.AudioDownmix)
  end
  if (strProperty == PropertyNames.BgUrl) then
		SendCmd(CMDS.BackgroundUrl, Properties[strProperty])
  end
  if (strProperty == PropertyNames.SSUrl) then
		SendCmd(CMDS.ScreenSaverUrl, Properties[strProperty])
  end
end

function startDebugTimer()
  if (g_DebugTimer) then
	 g_DebugTimer = C4:KillTimer(g_DebugTimer)
  end
  g_DebugTimer = C4:AddTimer(15, "MINUTES")
end

function dbg(strDebugText)
  if (g_debugprint) then print(strDebugText) end
  if (g_debuglog) then C4:ErrorLog(strDebugText) end
end

function PrintPacket(msg, packet)
  if (g_debugprint) then
	 print("........Hex Packet: " .. msg)
	 hexdump(packet)
  end
end

