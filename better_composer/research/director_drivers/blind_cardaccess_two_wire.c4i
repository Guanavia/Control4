  <back/><top/><bottom/><left/><right/><capabilities>
    <can_stop>True</can_stop>
  </capabilities><name>Two-wire Shade</name><small>devices_sm/blinds.gif</small><large>devices_lg/blinds.gif</large><control>lua_gen</control><composer_categories>
