		<script>
			<![CDATA[

-- Global Variables
gnDebugTimer = 0
g_dbgprint = false
g_dbglog = false

g_CommandHandlers = {}
g_JoinedRooms = {}

--======================================== Persist State ========================================--
function SaveState(strRooms)
	PersistData["ROOMS"] = strRooms
	C4:InvalidateState()
end

function RestoreState()
	if PersistData ~= nil then
		local strRooms = PersistData["ROOMS"]
		if strRooms ~= nil and strRooms ~= "" then
			JoinRooms(strRooms)
		end
	end
end

--========================================== Wrappers ===========================================--

function ExecuteCommand(strCommand, tParams)
	DebugPrintLog("ExecuteCommand(" .. strCommand .. ")")

	if( tParams ~= nil ) then

		for cmd,cmdv in pairs(tParams) do
			DebugPrintLog("tParams[\"" .. cmd .. "\"]: " .. cmdv)
		end

	end

	if #strCommand == 7 or #strCommand == 8 then
		local first, last, EventNum = string.find(strCommand, "Event (%d%d?)")
		if(EventNum ~= nil) then
			local fDispatchLocal = tParams["Dispatch event in:"] == "joined rooms and locally"
			if fDispatchLocal then
				strWhichRooms = "all"
			else
				strWhichRooms = "joined"
			end
			DebugPrintLog("Sending Event " .. EventNum .. " to " .. strWhichRooms .. " rooms.")
			SendCommandToAllRooms("DISPATCH_EVENT", {["EVENT_ID"] = EventNum}, fDispatchLocal)
			return
		end
	end

	CommandHandler = g_CommandHandlers[strCommand];
	if(CommandHandler ~= nil) then
		if(tParams == nil) then
			CommandHandler()
		else
			CommandHandler(tParams)
		end
	else
		DebugPrintLog("Unknown command " .. strCommand)
		C4:ErrorLog("Unknown command " .. strCommand)
	end
end

function OnDriverInit()
    DebugPrintLog("OnDriverInit called")
end

function OnPropertyChanged(strPropertyName)
	local strNewValue = Properties[strPropertyName]

	if(strPropertyName == "Debug Mode") then

		if gnDebugTimer ~= 0 then
			C4:KillTimer(gnDebugTimer)
			gnDebugTimer = 0
		end

		g_dbgprint = (Properties["Debug Mode"]:find("Print") ~= nil)
		g_dbglog = (Properties["Debug Mode"]:find("Log") ~= nil)

		if (Properties["Debug Mode"] == "Off") then
			return
		end

		gnDebugTimer = C4:AddTimer(45, "MINUTES")
		DebugPrintLog("Enabling logging for 45 minutes...")
	end

	DebugPrintLog("OnPropertyChanged - strPropertyName: " .. strPropertyName .. " strNewValue: " .. strNewValue)
end

function OnTimerExpired(pnTimerId)
	if pnTimerId == gnDebugTimer then
		DebugPrintLog("Timer expired for debug logging")
		C4:UpdateProperty("Debug Mode", "Off")
		OnPropertyChanged("Debug Mode")
	end
end

function OnDriverDestroyed()
	if gnDebugTimer ~= 0 then
		gnDebugTimer = C4:KillTimer(gnDebugTimer)
	end
end

function StopTimer(timer, timerName)
	DebugPrintLog("Stopping "..timerName.." timer...")
	C4:KillTimer(timer)
end

--================================== TCP COMMUNICATION ================================================

function OnConnectionStatusChanged(idBinding, nPort, strStatus)

	DebugPrintLog("Received OnConnectionStatusChanged call with [" .. idBinding .. "] [" .. nPort .. "] [" .. strStatus .. "]")

	index = idBinding - 6000
	if(strStatus == "ONLINE") then
		g_JoinedRooms[index].Connected = true
	else
		g_JoinedRooms[index].Connected = false
	end

end

function DeleteAllConnections()
	local JoinedRoom = {}
	for _,JoinedRoom in pairs(g_JoinedRooms) do
		DebugPrintLog("Calling NetDisconnect(" .. JoinedRoom.BindingID .. ")")
		C4:NetDisconnect(JoinedRoom.BindingID, JoinedRoom.Port);
		-- TODO: I've disconnected. Do I also need to delete the connection? How do I do that?
	end
	g_JoinedRooms = {}

	C4:SetVariable("IS_JOINED", "0")
	C4:FireEvent("Room Disjoins")
end

function AddConnection(IPAddress)
	local JoinedRoom = {}
	index = #g_JoinedRooms + 1
	JoinedRoom.BindingID = 6000 + index;
	JoinedRoom.IPAddress = IPAddress;
	JoinedRoom.Connected = false
	JoinedRoom.Port = 5020
	g_JoinedRooms[index] = JoinedRoom
	DebugPrintLog("Calling CreateNetworkConnection(" .. JoinedRoom.BindingID .. ", " .. JoinedRoom.IPAddress .. ")")
	-- Create the connection:
	C4:CreateNetworkConnection(JoinedRoom.BindingID, JoinedRoom.IPAddress)
	-- Connect: (If we created the network connection, it will not auto-connect.)
	C4:NetConnect(JoinedRoom.BindingID, JoinedRoom.Port)
end

function SendCommandToAllRooms(strCommand, tParams, fDispatchLocal)
	local tJoinedRoom = {}
	for _, tJoinedRoom in pairs(g_JoinedRooms) do
		SendCommandToRoom(tJoinedRoom, strCommand, tParams)
	end
	if fDispatchLocal then
		-- Also execute the command myself:
		ExecuteCommand(strCommand, tParams)
	end
end

function SendCommandToRoom(tJoinedRoom, strCommand, tParams)
	local strParams = ""
--	if(tParams ~= nil) do
	for ParamName, ParamValue in pairs(tParams) do
		strParams = strParams .. '<param><name>' .. ParamName .. '</name><value type="STRING"><static>' .. ParamValue .. '</static></value></param>'
	end
	local message = '<c4soap name="SendToDeviceUsingC4iAsync" async="True"><param name="c4i_name" type="STRING">RoomJoin.c4i</param><param type="string" name="data"><devicecommand><command>' .. strCommand .. '</command><params>' .. strParams .. '</params></devicecommand></param></c4soap>'
	DebugPrintLog("Calling SendToNetwork(" .. tJoinedRoom.BindingID .. ", " .. tJoinedRoom.Port .. ", \"" .. message .. "\")")
	C4:SendToNetwork(tJoinedRoom.BindingID, tJoinedRoom.Port, message .. "\0");
end

--=============================== Data received commands =============================================

function ReceivedFromNetwork(idBinding, nPort, strData)
	DebugPrintLog ("ReceivedFromNetwork - idBinding: " .. idBinding .. " \"" .. strData .. "\"");
end

function ReceivedFromProxy(idBinding, strCommand, tParams)
	ExecuteCommand(strCommand, tParams)
end

--============================== Command Handlers ============================================

function g_CommandHandlers.GET_PROPERTIES()
	DebugPrintLog ("Getting Properties")
	for k,v in pairs(Properties) do
	  OnPropertyChanged(k)
	end
end

function g_CommandHandlers.JOIN_ROOMS(tParams)
--[[
The JOIN_ROOMS command should include a parameter called ROOMS, with a string
value that is a comma-separated list of ip addresses (or host names). Each
address should point to the primary controller (the one running Director) in
the other room(s).

Note: Do not include yourself in the list.
]]--


	local strRooms = tParams["ROOMS"]
	if(strRooms == nil) then
		error("The ROOMS parameter is required for the JOIN_ROOMS command.")
	else
		DeleteAllConnections()
		JoinRooms(strRooms)
		SaveState(strRooms)
	end
end

function JoinRooms(strRooms)
	-- Parse the comma-delimited list:
	while #strRooms > 0 do
		-- Take everything up to the first comma:
		_, iEnd, strAddress = string.find(strRooms, "(.-),")
		if strAddress == nil then
			-- If there isn't a comma, take the whole string:
			strAddress = strRooms
			iEnd = #strRooms
		end
		if #strAddress > 0 then
			AddConnection(strAddress)
		end
		strRooms = string.sub(strRooms, iEnd + 1)
	end

	if #g_JoinedRooms >= 1 then
		C4:SetVariable("IS_JOINED", "1")
		C4:FireEvent("Room Joins")
	end
end

function g_CommandHandlers.UNJOIN()
	DeleteAllConnections()
	DebugPrintLog("Unjoined from all rooms.")
	SaveState("")
end

function g_CommandHandlers.DISPATCH_EVENT(tParams)
	local EventID = tParams["EVENT_ID"]
	local EventName = "Event " .. EventID
	DebugPrintLog("Dispatching \"" .. EventName .. "\"...")
	C4:FireEvent(EventName)
end

---------------------------------------------------------------------------------------------------
----------------------------- UTIL ----------------------------------------------------------------
---------------------------------------------------------------------------------------------------

--function GetTableCount(ptTable)
--	local lnCount = 0
--	for _,_ in pairs(ptTable) do
--		lnCount=lnCount+1
--	end
--	return lnCount
--end

function round(num)
	return math.floor(num+.5)
end

function DebugPrintLog(strData)
	if g_dbgprint then
		print(strData)
	end

	if g_dbglog then
		C4:DebugLog(strData .. "\n")
	end
end

--======================================== Startup Code =========================================--

C4:AddVariable("IS_JOINED", "0", "BOOL", true)
RestoreState()


			]]>
		</script>
	</config>

	<connections>
	</connections>

</devicedata>
