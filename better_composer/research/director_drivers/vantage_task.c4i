			<command>
				<name>Execute Task</name>
				<description>Do PARAM1 on Task NAME</description>
				<params>
					<param>
						<name>TASK</name>
						<type>LIST</type>
						<items>
							<item>PRESS</item>
							<item>RELEASE</item>
							<item>HOLD</item>
							<item>TIMER</item>
							<item>DATA</item>
							<item>POSITION</item>
							<item>INRANGE</item>
							<item>OUTOFRANGE</item>
