			<id>1</id>
			<facing>6</facing>
			<connectionname>Vantage Infusion Control</connectionname>
			<type>1</type>
			<consumer>True</consumer>
			<audiosource>False</audiosource>
			<videosource>False</videosource>
			<linelevel>True</linelevel>
			<classes>
				<class>
					<classname>VANTAGE_TASK</classname>
					<autobind>True</autobind>
				</class>
			</classes>
		</connection>
