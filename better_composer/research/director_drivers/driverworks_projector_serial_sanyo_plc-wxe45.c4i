function RESP.PROJECTOR_OPERATING_STATUS(msg)
  if (msg=='00') then msg = 'POWER_ON'
  elseif (msg=='80') then msg = 'STANDBY'
  elseif (msg=='81') then msg = 'STANDBY_AFTER_LAMP_FAILURE'
  elseif (msg=='04') then msg  = 'POWER_SAVE'
  elseif (msg=='10') then msg  = 'POWER_FAILURE'
  elseif (msg=='40') then msg  = 'COUNTDOWN'
  elseif (msg=='20') then msg  = 'COOLING_DOWN'
  elseif (msg=='24') then msg  = 'COOLING_DOWN_POWER_SAVE'
  elseif (msg=='21') then msg  = 'COOLING_DOWN_LAMP_FAILURE'
  elseif (msg=='28') then msg  = 'COOLING_DOWN_TEMPERATURE_ANOMALY'
  elseif (msg=='88') then msg  = 'RECOVERY_FROM_TEMPERATURE_ANOMALY' 
  else 
    dbg('Projector_Operating_Status-Invalid Message: ' .. msg)
     return
  end

  dbg('Projector_Operating_Status: ' .. msg)
  C4:SetVariable('Projector_Operating_Status',msg)
  if (g_Projector_Operating_Status~=msg) then
    dbg('Projector_Operating_Status_Changed: ' .. msg)
    C4:FireEvent('Projector_Operating_Status_Changed')
    g_Projector_Operating_Status=msg
    if (msg=='POWER_ON') or (msg=='POWER_SAVE') then
      C4:SendToProxy(5001, 'ON', {})
      g_PowerState[0] = 'ON'
    else
      C4:SendToProxy(5001, 'OFF', {})
      g_PowerState[0] = 'OFF'
    end
  end
end

function RESP.POWER_STATUS(msg)
  C4:SendToProxy(5001, msg, {})
  g_PowerState[0] =  msg
  dbg('Sent powerState to proxy: ' .. msg)
end

function RESP.MUTE_STATUS(msg)   
  C4:SendToProxy(5001,'MUTE_CHANGED', {MUTE = msg, OUTPUT = 4000})
  dbg('Sent mute State to proxy: ' .. msg)
end



function OnPropertyChanged(strProperty)
  if (strProperty == 'Debug Mode') then
    if (Properties[strProperty] == 'Off') then
      g_debugprint = false
      g_debuglog = false
      g_DebugTimer = C4:KillTimer(g_DebugTimer)
      g_DebugTimer = 0
    end
    if (Properties[strProperty] == 'Print') then
      g_debugprint = true
      g_debuglog = false
      startDebugTimer()
    end
    if (Properties[strProperty] == 'Log') then
      g_debugprint = false
      g_debuglog = true
      startDebugTimer()
    end
    if (Properties[strProperty] == 'Print and Log') then
      g_debugprint = true
      g_debuglog = true
      startDebugTimer()
    end
  elseif (strProperty == 'Volume Ramp Delay-Milliseconds') then
    intraVolRampDelayValue = tonumber(Properties['Volume Ramp Delay-Milliseconds'])
  elseif (strProperty == 'Command Delay-Milliseconds') then
    intraCommandDelayValue = tonumber(Properties['Command Delay-Milliseconds'])
  elseif (strProperty == 'Power On Delay-Seconds') then
    powerOnDelayValue = tonumber(Properties['Power On Delay-Seconds'])
  elseif (strProperty == 'Status Query Timer-Minutes') then
    g_StatusQueryTimerInterval = tonumber(Properties['Status Query Timer-Minutes'])
  elseif (strProperty == 'ResponseTimeoutTimer-Seconds') then
    g_ResponseTimeoutTimerInterval = tonumber(Properties['ResponseTimeoutTimer-Seconds'])
  elseif (strProperty == 'Operating Status Query Timer-Minutes') then
    g_OperatingStatusQueryTimerInterval = tonumber(Properties['Operating Status Query Timer-Minutes'])
  end
end

