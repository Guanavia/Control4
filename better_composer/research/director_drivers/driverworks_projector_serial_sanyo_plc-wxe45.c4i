 ['F'] = 15,
}
ChannelCommands = ''
tVolumeCommands = {}
ChannelRampTimerID = 0
tVolRampTimerID = {}
tCurrentVolume = {}
tMaxVolume = {}
tVolumeCommandNames = {}
gSerialBuf = ''
CMDS = {
['MENU']='1C',
['UP']='3C',
['DOWN']='3D',
['LEFT']='3B',
['RIGHT']='3A',
['ENTER']='3F',
['CANCEL']='1E',
['MUTE_ON']='0B',
['MUTE_OFF']='0C',
['PULSE_VOL_UP']='09',
['PULSE_VOL_DOWN']='0A',
['RESET_TOTAL_LAMP_RUNNING_TIME']='F LAMPH RST',
['GET_LAMP_REPLACEMENT_TIME']='R LAMPREPL',
['GET_LAMP_TOTAL_RUNNING_TIME_ACTUAL']='R LAMPH',
['GET_LAMP_TOTAL_RUNNING_TIME_CORRESPONDING']='R LAMPCORRESPH',
['GET_LAMP_MODE_STATUS']='R LAMPMODE',
['GET_LAMP_LIGHTING_STATUS']='R LAMPSTS',
['GET_LAMP_NUMBER']='R HMLAMP',
['GET_PROJECTOR_TOTAL_RUNNING_TIME_ACTUAL']='R PROJH',
['GET_PROJECTOR_OPERATING_STATUS']='R0',
}
RESP = {}
intraCommandDelayValue = Properties['Command Delay-Milliseconds']
powerOnDelayValue = Properties['Power On Delay-Seconds']
intraVolRampDelayValue = Properties['Volume Ramp Delay-Milliseconds']
g_StatusQueryTimerInterval = Properties['Status Query Timer-Minutes']
g_ResponseTimeoutTimerInterval = Properties['ResponseTimeoutTimer-Seconds']
g_OperatingStatusQueryTimerInterval = Properties['Operating Status Query Timer-Minutes']
C4:AddVariable('Lamp_Time_Actual',0,'STRING',false,false)
g_Lamp_Time_Actual = 0
C4:AddVariable('Lamp_Time_Corresponding',0,'STRING',false,false)
g_Lamp_Time_Corresponding = 0
C4:AddVariable('Lamp_Replacement_Time',0,'STRING',false,false)
g_Lamp_Replacement_Time = N
C4:AddVariable('Lamp_Mode_Status',0,'STRING',false,false)
g_Lamp_Mode_Status = ''
C4:AddVariable('Lamp_Lighting_Status',0,'STRING',false,false)
g_Lamp_Lighting_Status = ''
C4:AddVariable('Lamp_Number',0,'STRING',false,false)
g_Lamp_Number = 0
C4:AddVariable('Projector_Running_Time',0,'STRING',false,false)
g_Projector_Running_Time = 0
C4:AddVariable('Projector_Operating_Status',0,'STRING',false,false)
g_Projector_Operating_Status = ''


function ReceivedFromProxy(idBinding, strCommand, tParams)
  dbg('ReceivedFromProxy: ' .. strCommand)
  if tParams==nil then
    tParams={}
  end
  tParams['BindingID'] = idBinding
  if (CMDS[strCommand] ~= nil) and (type(CMDS[strCommand])=='function') then
    CMDS[strCommand] (tParams, strCommand)
  elseif (CMDS[strCommand] ~= nil) then
    emit(CMDS[strCommand], strCommand, tParams.OUTPUT)
  else
    dbg('ReceivedFromProxy - Command not defined: '.. strCommand)
  end
end

function ExecuteCommand(Command, Parameters)
  dbg('ExecuteCommand: ' .. Command)
  if (CMDS[Command] ~= nil) and (type(CMDS[Command])=='function') then
    CMDS[Command] (Parameters, Command)
  elseif (CMDS[Command] ~= nil) then
    emit(CMDS[Command], Command)
  else
    dbg('ExecuteCommand - Command not defined: '.. Command)
  end
end


function emit(strCommand, strCommandName, lngOutputID)
  local bUsePowerOnDelay = false
  if (strCommandName == 'ON') then
    bUsePowerOnDelay = true
  end
  strCommand = 'C' .. strCommand .. '\r'
  dbg('Emit: ' .. strCommand)
  table.insert(tEmitCommands, {strCommand, bUsePowerOnDelay, strCommandName})
  if (idEmitCommandsTimer==nil) then
     idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
  end
end

function OnTimerExpired(idTimer)
  if (idTimer == idEmitCommandsTimer) then
    C4:KillTimer(idEmitCommandsTimer)
    idEmitCommandsTimer = nil

    if (g_Projector_Operating_Status=='POWER_FAILURE') or
       (g_Projector_Operating_Status=='COUNTDOWN') or
       (g_Projector_Operating_Status=='COOLING_DOWN') or
       (g_Projector_Operating_Status=='COOLING_DOWN_POWER_SAVE') or
       (g_Projector_Operating_Status=='COOLING_DOWN_LAMP_FAILURE') or
       (g_Projector_Operating_Status=='COOLING_DOWN_TEMPERATURE_ANOMALY') or
       (g_Projector_Operating_Status=='RECOVERY_FROM_TEMPERATURE_ANOMALY') then
      if tEmitCommands[1] ~= nil then
        idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
      end
      return
    end

    if (idBusyTimer~=0) then
      if tEmitCommands[1] ~= nil then
        idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
      end
      return
    end 
    if (tEmitCommands[1]~=nil) then
      dbg('SendToSerial:' .. tEmitCommands[1][1])
      g_CurrentCommand=tEmitCommands[1][3]
      C4:SendToSerial(1, tEmitCommands[1][1]) 
      if (tEmitCommands[1][2] == true) then
        idBusyTimer = C4:AddTimer(powerOnDelayValue, 'SECONDS', false)
      end
      table.remove(tEmitCommands, 1)
    end 
    if (tEmitCommands[1]~=nil) then
      if (idResponseTimeoutTimer~=nil) then
        C4:KillTimer(idResponseTimeoutTimer)
      end
      idResponseTimeoutTimer = C4:AddTimer(g_ResponseTimeoutTimerInterval, 'SECONDS', false)
    end
    return
  end
  if (idTimer == idResponseTimeoutTimer) then
    idResponseTimeoutTimer = C4:KillTimer(idResponseTimeoutTimer)
    idResponseTimeoutTimer=nil
    if tEmitCommands[1] ~= nil then
      if (idEmitCommandsTimer~=nil) then
        C4:KillTimer(idEmitCommandsTimer)
      end
      idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
    end
  end
  if (idTimer == idBusyTimer) then
    if (g_Projector_Operating_Status=='POWER_FAILURE') or
       (g_Projector_Operating_Status=='COUNTDOWN') or
       (g_Projector_Operating_Status=='COOLING_DOWN') or
       (g_Projector_Operating_Status=='COOLING_DOWN_POWER_SAVE') or
       (g_Projector_Operating_Status=='COOLING_DOWN_LAMP_FAILURE') or
       (g_Projector_Operating_Status=='COOLING_DOWN_TEMPERATURE_ANOMALY') or
       (g_Projector_Operating_Status=='RECOVERY_FROM_TEMPERATURE_ANOMALY') then
      dbg('SendToSerial:' .. 'CR0\r')
      g_CurrentCommand='GET_PROJECTOR_OPERATING_STATUS'
      C4:SendToSerial(1, 'CR0\r') 
      idBusyTimer = C4:KillTimer(idBusyTimer)
      idBusyTimer = C4:AddTimer(powerOnDelayValue, 'SECONDS', false) 
      return
    end
    idBusyTimer = C4:KillTimer(idBusyTimer)
    if tEmitCommands[1] ~= nil then
      if (idEmitCommandsTimer~=nil) then
        C4:KillTimer(idEmitCommandsTimer)
      end
      idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
    end
  end
  if (idTimer==idOperatingStatusQueryTimer) then
    dbg('SendToSerial:' .. 'CR0\r')
    g_CurrentCommand='GET_PROJECTOR_OPERATING_STATUS'
    C4:SendToSerial(1, 'CR0\r') 
    return  
  end
  if (idTimer==idStatusQueryTimer) then
    CMDS.GET_STATUS()
    return  
  end
  if idTimer == tVolRampTimerID[0] then
    if (tCurrentVolume[0] ~= nil) and (tCurrentVolume[0] == 0) then
      C4:KillTimer(VolRampTimerID)
      tVolRampTimerID[0] = nil
      for j,k in pairs(tEmitCommands) do 
        if string.match(k[1],tVolumeCommands[0]) ~= nil then
          table.remove(tEmitCommands, j)
        end
      end
    end
    emit(tVolumeCommands[0])
    return
  end
  if idTimer == ChannelRampTimerID then
    emit(ChannelCommands)
    return
  end
  if (idTimer == g_DebugTimer) then
    dbg('Turning Debug Mode back to Off [default] (timer expired)')
    C4:UpdateProperty('Debug Mode', 'Off')
    g_debugprint = false
    g_debuglog = false
    g_DebugTimer = C4:KillTimer(g_DebugTimer)
    return
  end
end

function ReceivedFromSerial(idBinding, strData)
  dbg('Received something from serial on binding ' .. idBinding)
  if (g_debugprint) then
    hexdump(strData)
  end
  -- concat until we have a full serial data packet, Verify checksum, send to ProcessSerial
  gSerialBuf = gSerialBuf .. strData

  local buflen, pos, start, len, data, lastpos

  buflen = string.len(gSerialBuf)
  pos = 1
  lastpos = 0 -- Tracks last 'used' byte in gSerialBuf, so we will not cut partial messages...

  while (pos < buflen) do
    -- If completed message received, process it.
      len = string.find(gSerialBuf,'\r',pos)
      if (len==nil) then return end

    -- Verify we have at least *len* to pull from gSerialBuf from pos to end...
    if (len <= buflen) then
      data = string.sub(gSerialBuf, pos, len-1)
      pos = len+1
      lastpos = pos
      processSerial(data)
    else
      -- Leaving with partial buffer...
      gSerialBuf = string.sub(gSerialBuf, lastpos)
      return
    end
  end
  gSerialBuf = string.sub(gSerialBuf, lastpos) 
end

function processSerial(retMessage)
  local response, param, pos
  pos=string.find(retMessage, ' ')
  if (pos==nil) then
    response =retMessage
  else
    response = string.sub(retMessage,1,pos-1)
    param = string.sub(retMessage,pos+1,string.len(retMessage))
  end
  if (response=='?') or
     (response==101) or
     (response==102) or
     (response==103) or
     (response==201) or
     (response==301) or
     (response==302) or
     (response==402) then 
    dbg('processSerial - Error Code: ' .. response) 
    return 
  end

  dbg('processSerial')
  if (g_CurrentCommand~=nil) then
    dbg('g_CurrentCommand: ' .. g_CurrentCommand)
  end 
  if (response~=nil) then
    if (response==tohex('06')) then response = 'ACK' end
    dbg('Response=' .. response)
  end
  if (param~=nil) then
  dbg('Param=' .. param)
  end

  if (tEmitCommands[1]~=nil) then
    if (idEmitCommandsTimer~=nil) then
      C4:KillTimer(idEmitCommandsTimer)
    end
    idEmitCommandsTimer = C4:AddTimer(intraCommandDelayValue, 'MILLISECONDS', false)
  end

  if (g_CurrentCommand=='ON') then
    RESP.POWER_STATUS('ON')
  elseif (g_CurrentCommand=='OFF') then
    RESP.POWER_STATUS('OFF')
  elseif (g_CurrentCommand=='MUTE_ON') then
    RESP.MUTE_STATUS('True')
  elseif (g_CurrentCommand=='MUTE_OFF') then
    RESP.MUTE_STATUS('False')
  elseif (g_CurrentCommand=='GET_LAMP_REPLACEMENT_TIME') then
    param=string.sub(param,2,2)
    if (param=='Y') then param='YES'
    elseif  (param=='N') then param='NO'
    else return end
    RESP.LAMP_REPLACEMENT_TIME(param)
  elseif (g_CurrentCommand=='GET_LAMP_TOTAL_RUNNING_TIME_ACTUAL') then
    param=tonumber(param)
    RESP.LAMP_TIME_ACTUAL(param)
  elseif (g_CurrentCommand=='GET_LAMP_TOTAL_RUNNING_TIME_CORRESPONDING') then
    param=tonumber(param)
    RESP.LAMP_TIME_CORRESPONDING(param)
  elseif (g_CurrentCommand=='GET_LAMP_MODE_STATUS') then
    RESP.LAMP_MODE_STATUS(param)
  elseif (g_CurrentCommand=='GET_LAMP_LIGHTING_STATUS') then
    param=string.sub(param,2,2)
    if (param=='I') then param='ON'
    elseif  (param=='O') then param='OFF'
    elseif  (param=='X') then param='FAILURE' 
    else return end
    RESP.LAMP_LIGHTING_STATUS(param)
  elseif (g_CurrentCommand=='GET_LAMP_NUMBER') then
    param=tonumber(param)
    RESP.LAMP_NUMBER(param)
  elseif (g_CurrentCommand=='GET_PROJECTOR_TOTAL_RUNNING_TIME_ACTUAL') then
    param=tonumber(param)
    RESP.PROJECTOR_RUNNING_TIME(param)
  elseif (g_CurrentCommand=='GET_PROJECTOR_OPERATING_STATUS') then
    RESP.PROJECTOR_OPERATING_STATUS(response)
  end
  g_CurrentCommand=nil
end

function OnDriverDestroyed()
  if (g_DebugTimer) then
    g_DebugTimer = C4:KillTimer(g_DebugTimer)
  end
  for lngOutputID,VolRampTimerID in pairs(tVolRampTimerID) do
    if (VolRampTimerID) then
      VolRampTimerID = C4:KillTimer(VolRampTimerID)
    end
  end
  if (idEmitCommandsTimer) then
    idEmitCommandsTimer = C4:KillTimer(idEmitCommandsTimer)
    idEmitCommandsTimer = nil
  end
  if (ChannelRampTimerID) then
    ChannelRampTimerID = C4:KillTimer(ChannelRampTimerID)
  end
  if (idConnectToNetworkTimer) then
    idConnectToNetworkTimer = C4:KillTimer(idConnectToNetworkTimer)
  end
  if (idBusyTimer) then
    idBusyTimer = C4:KillTimer(idBusyTimer)
  end
  if (idOperatingStatusQueryTimer) then
    idOperatingStatusQueryTimer = C4:KillTimer(idOperatingStatusQueryTimer)
  end
  if (idStatusQueryTimer) then
    idStatusQueryTimer = C4:KillTimer(idStatusQueryTimer)
  end
  if (idResponseTimeoutTimer) then
    idResponseTimeoutTimer = C4:KillTimer(idResponseTimeoutTimer)
  end
end

function hextoascii(strIn)
  local out = ""
  string.gsub (strIn, "(.)", function (c) out = out .. string.format("%02x", string.byte(c)) end)
  return out
end


