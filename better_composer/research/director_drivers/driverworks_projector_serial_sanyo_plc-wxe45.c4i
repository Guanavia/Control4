function dbg(strDebugText)
  if (g_debugprint) then print(strDebugText) end
  if (g_debuglog) then C4:ErrorLog(strDebugText) end
end

function startDebugTimer()
  if (g_DebugTimer) then
    g_DebugTimer = C4:KillTimer(g_DebugTimer)
  end
  g_DebugTimer = C4:AddTimer(15, 'MINUTES')
end

function fromHex(hexString) -- converts a string representing a hex number to decimal
   local stringLen = string.len(hexString)
   local decValue = 0
   for k=0,stringLen-1 do
      lastdigit = string.sub(hexString, stringLen-k)
      decValue = decValue + (hexmap[lastdigit] * 16^k)
      hexString=string.sub(hexString,1,stringLen-1)
   end
   return decValue
end

function concat_string(s1, s2)
  if s1 == nil then
    return s2
  else
    return s1 .. s2
  end
end

function CMDS.ON(tParams,strCommand)
  dbg(strCommand)
  if (g_PowerState[0] ~= nil) and (g_PowerState[0] == 'ON') then return end
  tEmitCommands={}
  emit('00',strCommand)
  emit(CMDS.GET_PROJECTOR_OPERATING_STATUS,'GET_PROJECTOR_OPERATING_STATUS')

  C4:SendToProxy(5001, 'ON', {})
  g_PowerState[0] = 'ON'

  if (idOperatingStatusQueryTimer==nil) then
     idOperatingStatusQueryTimer = C4:AddTimer(g_OperatingStatusQueryTimerInterval, 'MINUTES', true)
  end
  if (idStatusQueryTimer==nil) then
     idStatusQueryTimer = C4:AddTimer(g_StatusQueryTimerInterval, 'MINUTES', true)
  end
  CMDS.GET_STATUS()
end

function CMDS.OFF(tParams,strCommand)
  dbg(strCommand)
  --first OFF command will display Are You Sure message
  --second OFF command will acknowledge message and turn unit off
  emit('F INPUTSEARCH OFF',  'INPUTSEARCH')
  emit('02', strCommand)
  emit('02', strCommand)
  emit(CMDS.GET_PROJECTOR_OPERATING_STATUS,'GET_PROJECTOR_OPERATING_STATUS')

  C4:SendToProxy(5001, 'OFF', {})
  g_PowerState[0] = 'OFF'

  tSetInputTrack=nil
  gSerialBuf = ''

  if (idBusyTimer~=0) then
    C4:KillTimer(idBusyTimer)
  end
  idBusyTimer = C4:AddTimer(powerOnDelayValue, 'SECONDS', false)

  if (idStatusQueryTimer) then
    idStatusQueryTimer = C4:KillTimer(idStatusQueryTimer)
    idStatusQueryTimer =nil
  end
end

function CMDS.GET_CAPABILITIES(tParams,strCommand) 
  if (idOperatingStatusQueryTimer==nil) then
     idOperatingStatusQueryTimer = C4:AddTimer(g_OperatingStatusQueryTimerInterval, 'MINUTES', true)
  end
end

function CMDS.GET_STATUS()
  emit(CMDS.GET_LAMP_REPLACEMENT_TIME, 'GET_LAMP_REPLACEMENT_TIME')
  emit(CMDS.GET_LAMP_TOTAL_RUNNING_TIME_ACTUAL, 'GET_LAMP_TOTAL_RUNNING_TIME_ACTUAL')
  emit(CMDS.GET_LAMP_TOTAL_RUNNING_TIME_CORRESPONDING, 'GET_LAMP_TOTAL_RUNNING_TIME_CORRESPONDING')
  emit(CMDS.GET_LAMP_MODE_STATUS, 'GET_LAMP_MODE_STATUS')
  emit(CMDS.GET_LAMP_LIGHTING_STATUS, 'GET_LAMP_LIGHTING_STATUS')
  emit(CMDS.GET_LAMP_NUMBER, 'GET_LAMP_NUMBER')
  emit(CMDS.GET_PROJECTOR_TOTAL_RUNNING_TIME_ACTUAL, 'GET_PROJECTOR_TOTAL_RUNNING_TIME_ACTUAL')
end

function CMDS.SET_VOLUME_LEVEL(tParams,strCommand)
  dbg(strCommand)
  local volumeLevel = tonumber(tParams['LEVEL'])
  if (volumeLevel==100) then volumeLevel=99 end
  volumeLevel=string.pack('b',volumeLevel)
  volumeLevel=hextoascii(volumeLevel)
  volumeLevel=string.rep("0", 3 - string.len(volumeLevel)) .. volumeLevel
  local strCmd = 'F VOLUME ' .. volumeLevel
  emit(strCmd, strCommand)
  C4:SendToProxy(5001,'VOLUME_LEVEL_CHANGED', {LEVEL = tParams['LEVEL'], OUTPUT = 4000})
end



function CMDS.START_VOL_DOWN(tParams,strCommand)
  dbg(strCommand)
  local strCmd = '0A'
  changeVolume(tParams['OUTPUT'],strCommand,strCmd)
  g_Mute='False'
  C4:SendToProxy(5001,'MUTE_CHANGED', {MUTE = g_Mute, OUTPUT = 4000})
end

function CMDS.START_VOL_UP(tParams,strCommand)
  dbg(strCommand)
  local strCmd =  '09'
  changeVolume(tParams['OUTPUT'],strCommand,strCmd)
  g_Mute='False'
  C4:SendToProxy(5001,'MUTE_CHANGED', {MUTE = g_Mute, OUTPUT = 4000})
end

function CMDS.STOP_VOL_UP(tParams,strCommand)
  local strCmd = '09'
  changeVolume(tParams['OUTPUT'],strCommand,strCmd)
end

function CMDS.STOP_VOL_DOWN(tParams,strCommand)
  local strCmd = '0A'
  changeVolume(tParams['OUTPUT'],strCommand,strCmd)
end

function changeVolume(lngOutputID, strCommand, strCommandData)
  lngOutputID=0
  if (strCommand == 'STOP_VOL_UP') or (strCommand == 'STOP_VOL_DOWN') then
    intraCommandDelayValue=g_holdIntraCommandDelayValue 
    if tVolRampTimerID[lngOutputID] ~= nil then
      C4:KillTimer(tVolRampTimerID[lngOutputID])
      tVolRampTimerID[lngOutputID] = nil
      for j,k in pairs(tEmitCommands) do 
        if string.match(k[1],strCommandData) ~= nil then
          table.remove(tEmitCommands, j)
        end
      end
    end
  else
    if (strCommand == 'START_VOL_UP') or (strCommand == 'START_VOL_DOWN') then
      g_holdIntraCommandDelayValue=intraCommandDelayValue 
      intraCommandDelayValue=intraVolRampDelayValue
      if  idEmitCommandsTimer ~=nil then
        C4:KillTimer(idEmitCommandsTimer)
        idEmitCommandsTimer = nil
      end 
      if (tVolRampTimerID[lngOutputID] == nil) then
        if (tVolRampTimerID[lngOutputID]) then
          tVolRampTimerID[lngOutputID] = C4:KillTimer(tVolRampTimerID[lngOutputID])
        end
        tVolRampTimerID[lngOutputID] = C4:AddTimer(intraVolRampDelayValue, 'MILLISECONDS', true)
        tVolumeCommands[lngOutputID] = strCommandData
        tVolumeCommandNames[lngOutputID] = strCommand
        emit(strCommandData)
      end
    else
       emit(strCommandData)
    end
  end
end

function CMDS.MUTE_TOGGLE(tParams,strCommand)
  dbg(strCommand)
  local strCmd
  if (g_Mute==nil) or (g_Mute=='False') then
    strCmd='0B'
    g_Mute='True'
  else
    strCmd='0C'
    g_Mute='False'
  end
  emit(strCmd, strCommand)
end

function CMDS.SET_INPUT(tParams,strCommand)
  local strCmd, input
  dbg('SET_INPUT')
  dbg('SET_INPUT-tParams: ')
  if tParams ~= nil then
    for j,k in pairs(tParams) do
      dbg('SET_INPUT_ParamID: ' .. j .. ' - SET_INPUT_ParamValue: ' .. k)
      if (j == 'INPUT') then input = tonumber(k) % 1000  end
    end
  end
  if (input==1) then --COMPUTER 1 ANALOG RGB
    strCmd = '05'
    emit(strCmd, strCommand)
    strCmd = '50'
    emit(strCmd, strCommand)
  elseif (input==2) then --COMPUTER 1 COMPONENT
    strCmd = '05'
    emit(strCmd, strCommand)
    strCmd = '54'
    emit(strCmd, strCommand)
  elseif (input==3) then --COMPUTER 2
    strCmd = '06'
    emit(strCmd, strCommand)
  elseif (input==4) then --S-VIDEO
    strCmd = '07'
    emit(strCmd, strCommand)
    strCmd = '34'
    emit(strCmd, strCommand)
  elseif (input==5) then --VIDEO
    strCmd = '07'
    emit(strCmd, strCommand)
    strCmd = '33'
    emit(strCmd, strCommand)
  end
  C4:SendToProxy(5001,'INPUT_CHANGED', {INPUT=tParams.INPUT})
end


function RESP.LAMP_TIME_ACTUAL(msg)
  dbg('Lamp_Time_Actual: ' .. msg)
  C4:SetVariable('Lamp_Time_Actual',msg)
