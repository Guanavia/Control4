function NotifyRoomOfCurrentMedia()
		SendUISimpleToProxy("artistname", g_artist)
		SendUISimpleToProxy("albumname", g_album)
		SendUISimpleToProxy("titlename", g_title)

		SendToProxy("UPDATE_MEDIA_INFO", {ARTIST = g_artist, ALBUM = g_album, TITLE = g_title, IMAGE_AVAILABLE = g_haveImage})
end

function Docked()
	g_online = true
	ClearQueuedCommands()
	SetGettingCoverArt(false)
	SendUISimpleToProxy("online", "true")
	SendUISimpleToProxy("docked", "true")

	g_imagequeue = {}

	ResetDock()
	startDockedTimer()
end

function Undocked()
	Properties["Firmware Version"] = ""

	g_online = false
	g_ipodname = "Offline"
	ClearQueuedCommands()
	SetGettingCoverArt(false)

	SendUISimpleToProxy("busy", "false")
	SendUISimpleToProxy("online", "false")
	SendUISimpleToProxy("docked", "false")
	SendUISimpleToProxy("iportname", g_ipodname)

	g_imagequeue = {}

	-- Update Play Status
	g_playerstatus = "Stopped"
	SendUISimpleToProxy("playstatusclear", g_playerstatus)

	-- Update Artist / Title / Etc.
	g_title = ""
	g_artist = ""
	g_album = ""
	g_haveImage = false
	NotifyRoomOfCurrentMedia()

	-- Clear Elapsed Time / Remaining Time
	g_elapsed = 0
	g_remaining = 0
	SendElapsedTimeUI()

	-- Update # of Songs Progress
	g_totalsongs = 0
	SendProgressUI()

	-- Update LIST to display nothing...
	SendOfflineUI()
--  Stopped()
	SendUISimpleToProxy("playstatus", "Stopped")
end

function Stopped()
	g_imagequeue = {}
	ClearQueuedCommands()
	SetGettingCoverArt(false)

	-- Update Play Status
	g_playerstatus = "Stopped"
	SendUISimpleToProxy("playstatusclear", g_playerstatus)

	-- Update Artist / Title / Etc.
	g_title = ""
	g_artist = ""
	g_album = ""
	g_haveImage = false
	NotifyRoomOfCurrentMedia()

	-- Clear Elapsed Time / Remaining Time
	g_elapsed = 0
	g_remaining = 0
	SendElapsedTimeUI()

	-- Update # of Songs Progress
	g_totalsongs = 0
	SendProgressUI()
end

function SendProgressUI()
	local strProgress = ""
	if ((g_totalsongs > 0) and (g_current > -1)) then
		strProgress = XmlTag("progress", {current = g_current, total = g_totalsongs})
	else
		strProgress = XmlTag("progress", {current = "0", total = "0"})
	end
	SendToProxy("PROGRESS", strProgress)
end

function SendElapsedTimeUI()
	local strTime = ""
	if ((g_elapsed > 0) and (g_remaining > 0)) then
		local elapsedTime = ConvertTime(g_elapsed)
		local remainingTime = "-" .. ConvertTime(g_remaining)
		strTime = XmlTag("time", {elapsed = elapsedTime, remaining = remainingTime})
	else
		strTime = "<time><elapsed></elapsed><remaining></remaining></time>"
	end
	SendToProxy("TIME", strTime)
end

function ClearElapsedTime()
	local strTime = ""
	strTime = "<time><elapsed></elapsed><remaining></remaining></time>"
	SendToProxy("TIME", strTime)
end

function ConvertTime(time)
	local strTime = ""
	local minutes = ""
	local seconds = ""
	local hours = string.format("%d", time / 3600)
	time = time - (hours * 3600)

	if (hours ~= "0") then
		strTime = hours .. ":"
		minutes = string.format("%02d", time / 60)
	else
		minutes = string.format("%d", time / 60)
	end

	time = time - (minutes * 60)
	seconds = string.format("%02d", time)
	strTime = strTime .. minutes .. ":" .. seconds

	return strTime
end

function SendOfflineUI()
	strOffline = "<list><clear>true</clear><title>Offline</title><total_items>1</total_items><num_items>1</num_items><items><item><id>32004</id><text>Offline</text></item></items></list>"
	SendToProxy("LIST", strOffline)
end

function XmlTag(strName, tParams)
	local strXml = "<" .. strName .. ">"
	for k,v in pairs(tParams) do
		strXml = strXml .. "<" .. k .. ">" .. v .. "</" .. k .. ">"
	end
	strXml = strXml .. "</" .. strName .. ">"
	-- dbg(strXml)
	return strXml
end

function SendUISimpleToProxy(strName, strValue)
	local tParams = {TAG = strName, DATA = strValue}
	dbgFunction("SendUISimpleToProxy (" .. strName .. ", " .. strValue .. ")")
	C4:SendToProxy(proxyBinding, "UI_SIMPLE", tParams)
end

function SendToProxy(strCommand, tParams, ...)
	if (g_debugprint) then
--		if (strCommand ~= "TIME") then
			dbgFunction("SendToProxy (" .. strCommand .. ")")
			dbgParams(tParams)
--		end
	end

	if ... then
		local callType = ...
		C4:SendToProxy(proxyBinding, strCommand, tParams, callType)
	else
		C4:SendToProxy(proxyBinding, strCommand, tParams)
	end
end

function GetCoverArt()
	if (g_ShowCoverArt == true) then
		QueueDockCmd(CMD["GET_COVERART_RAW"], 0, 1, g_imageindex-1, 0, "")
	end
end

function SetGettingCoverArt(gettingCoverArt)
	g_gettingCoverArt = gettingCoverArt

	if (g_gettingCoverArt == true) then
		SendUISimpleToProxy("busy", "true")
	else
		ExecuteQueuedCommands()
		SendUISimpleToProxy("busy", "false")
	end
end

function ResetCoverArt()
	g_gettingCoverArt = false
	ClearQueuedCommands()
	SendUISimpleToProxy("busy", "false")
end

function ClearQueuedCommands()
	g_commandindex = 0
	g_commandqueue = {}
end

function ExecuteQueuedCommands()
	for i=1, #g_commandqueue do
		if (g_commandqueue[i].simple == true) then
			dbg ("Executing queued SendSimpleDockCmd")
			SendSimpleDockCmd(g_commandqueue[i].command)
		else
			dbg ("Executing queued SendDockCmd")
			local command = g_commandqueue[i].command
			local param0 = g_commandqueue[i].param0
			local param1 = g_commandqueue[i].param1
			local param2 = g_commandqueue[i].param2
			local param3 = g_commandqueue[i].param3
			local data = g_commandqueue[i].data
			SendDockCmd(command, param0, param1, param2, param3, data)
		end
		g_commandqueue[i] = {}
	end
	g_commandindex = 0
	g_commandqueue = {}
end


----------- -------------------------- -------------------------- ---------------

function ReceivedFromProxy(idBinding, strCommand, tParams)
	-- Handle all proxy sent commands... Transport Control and pass-through to device...
	-- Use Pack to generate commands going out...
-- =-=-=-=-=- DEBUG...  -=-=-=-=-=-=-
	dbgFunction("ReceivedFromProxy(" .. idBinding .. ", " .. strCommand .. ")")
	if (g_debugprint) then
		if (nil ~= tParams) then
			print ("tParams: ")
			for j,k in pairs(tParams) do print (" \t" .. j .. ": " .. k) end
		end
	end
-- =-=-=-=-=- DEBUG...  -=-=-=-=-=-=-
	local cmd = CMD[strCommand]

	if (cmd == nil) then
		dbg("Unhandled Command: " .. strCommand)
		return
	end

	local cmdType = type(cmd)

	if (cmdType == "number") then
		-- Handle simple Transport Control-type Commands
		SendSimpleDockCmd(cmd)
	else
		if (cmdType == "function") then
			-- Handle more complicated commands
			cmd(tParams)
		end
	end
end


function SendSimpleDockCmd(strCmd)
	SendDockCmd(strCmd, 0, 0, 0, 0, "")
end


function QueueSimpleDockCmd(strCmd)
	if (g_gettingCoverArt == true) then
		dbgFunction("QueueSimpleDockCmd (strCmd = " .. string.format("%02x", strCmd) .. " " .. GetCommandText(strCmd) .. ")")
		g_commandindex = g_commandindex + 1
		g_commandqueue[g_commandindex] = {}
		g_commandqueue[g_commandindex].simple = true
		g_commandqueue[g_commandindex].command = strCmd
	else
		SendSimpleDockCmd(strCmd)
	end
end


function SendDockCmd(strCmd, param0, param1, param2, param3, data)

	-- NOTE: All pack commands should work on little-endian values...
	-- NOTE 2: data is not allowed to be nil, but blank ("") works fine.
	-- Generate Command based on parameters passed...
	if (data == nil) then data = ""	end	-- Fixes NOTE 2 above, Control Control did not work properly without this fix.
	dataLen = string.len(data)

	local cmd = tohex("FF AA 55 AA")  -- Magic Number
	cmd = cmd .. string.pack("bb<H<l<l<l", strCmd, param0, dataLen, param1, param2, param3) .. data

	-- Calculate packet length, add to front of outgoing msg...
	local cmdhead = string.pack("<H", string.len(cmd)) .. cmd

	dbgFunction("SendDockCmd (" ..
							"strCmd = " .. string.format("%02x", strCmd) .. " " .. GetCommandText(strCmd) ..
							"\tparam0 = " .. param0 .. " (" .. string.format("%02x", param0) .. ") " ..
							"\tparam1 = " .. param1 .. " (" .. string.format("%02x", param1) .. ") " ..
							"\tparam2 = " .. param2 .. " (" .. string.format("%02x", param2) .. ") " ..
							"\tparam3 = " .. param3 .. " (" .. string.format("%02x", param3) .. ") )"
							)

	C4:SendToNetwork(6001, g_nPort, cmdhead)
end

function QueueDockCmd(strCmd, param0, param1, param2, param3, data)
	if (g_gettingCoverArt == true) then
		dbgFunction("QueueDockCmd (" ..
								"strCmd = " .. string.format("%02x", strCmd) .. " " .. GetCommandText(strCmd) ..
								"\tparam0 = " .. param0 .. " (" .. string.format("%02x", param0) .. ") " ..
								"\tparam1 = " .. param1 .. " (" .. string.format("%02x", param1) .. ") " ..
								"\tparam2 = " .. param2 .. " (" .. string.format("%02x", param2) .. ") " ..
								"\tparam3 = " .. param3 .. " (" .. string.format("%02x", param3) .. ") )"
								)

		g_commandindex = g_commandindex + 1
		g_commandqueue[g_commandindex] = {}
		g_commandqueue[g_commandindex].simple = false
		g_commandqueue[g_commandindex].command = strCmd
		g_commandqueue[g_commandindex].param0 = param0
		g_commandqueue[g_commandindex].param1 = param1
		g_commandqueue[g_commandindex].param2 = param2
		g_commandqueue[g_commandindex].param3 = param3
		g_commandqueue[g_commandindex].data = data
	else
		SendDockCmd(strCmd, param0, param1, param2, param3, data)
	end
end

function GetCommandText(strCmd)
	local commandText = ""
	if (g_debugprint) then
		if (nil == g_Command[strCmd]) then
			commandText = "Unknown"
		else
			commandText = g_Command[strCmd]
		end
	end
	return commandText
end

function NotifyIpodName(pos, dataLen, param0)
	g_videoType = param0
	g_ipodname = string.sub(g_Receivebuffer, pos, (pos + dataLen - 2))
	if (g_videoType == 0) then
		g_supportsVideo = false
	else
		g_supportsVideo = true
	end

	-- Do not send Reset with Notify.

	SendUISimpleToProxy("iportname", g_ipodname)
	SendUISimpleToProxy("videotype", g_videoType)
end

function SendCoverArtToProxy(index)
	SendToProxy("COVERART", {cover_art = C4:Base64Encode(g_imagequeue[index].image),
														width = g_imagequeue[index].width,
														height = g_imagequeue[index].height,
														left = g_imagequeue[index].left,
														top = g_imagequeue[index].top,
														right = g_imagequeue[index].right,
														bottom = g_imagequeue[index].bottom,
														format = "RGB565"})

	g_haveImage = true
	NotifyRoomOfCurrentMedia()
end

function NotifyNowPLaying(pos, param1, param2)
	pos, g_artist = string.unpack(g_Receivebuffer, "<P", pos)
	pos, g_album = string.unpack(g_Receivebuffer, "<P", pos)
	pos, g_title = string.unpack(g_Receivebuffer, "<P", pos)

	g_current = param1
	g_totalsongs = param2
	g_haveImage = false
	NotifyRoomOfCurrentMedia()
	SendProgressUI()

	if (g_imagequeue[g_current] ~= nil) then

		if ((g_imagequeue[g_current].title == "") and (g_imagequeue[g_current].artist == "") and (g_imagequeue[g_current].album == "")) then
			g_imagequeue[g_imageindex].title = g_title
			g_imagequeue[g_imageindex].artist = g_artist
			g_imagequeue[g_imageindex].album = g_album
		end

		if ((g_imagequeue[g_current].title == g_title) and (g_imagequeue[g_current].artist == g_artist) and (g_imagequeue[g_current].album == g_album)) then
			SendCoverArtToProxy(g_current)
			if (g_current < g_totalsongs) then
				if (g_imagequeue[g_current+1] == nil) then
					g_imageindex = g_current + 1
					startCoverArtTimer()
				end
			end
		else
			dbg ("Image queue out of sync, clearing image queue")
			g_imagequeue = {}
			g_imageindex = g_current
			startCoverArtTimer()
		end
	else
		g_imageindex = g_current
		startCoverArtTimer()
	end
end

function NotifyTime(param1, param2)
	g_elapsed = param1
	g_remaining = param2 - param1

	if (g_NowPlayingTimer == true) then
		g_StatusCount = g_StatusCount + 1

		-- Update the elapsed time on the Navigators every n seconds, to not overwhelm the network...
		if ((g_StatusCount >= g_NowPlayingDelay) or (g_elapsed < 2) or (g_remaining < 3)) then
			SendElapsedTimeUI()
			g_StatusCount = 0
		end
	end
end

function NotifyPlayerStatus(param0)
	local strTagData = ""

	if (param0 == 1) then
		strTagData = "Playing"
	elseif (param0 == 2) then
		SendUISimpleToProxy("busy", "false")
		strTagData = "Stopped"
		Stopped()
	elseif (param0 == 3) then
		strTagData = "Paused"
	elseif (param0 == 4) then
		dbg ("FFW")
		strTagData = "Playing"
	elseif (param0 == 5) then
		dbg ("REW")
		strTagData = "Playing"
	end
	g_playerstatus = strTagData
	dbg ("Player Status = " .. g_playerstatus)
	SendUISimpleToProxy("playstatus", strTagData)
end

function NotifyDockStatus(param0)
	if (param0 == 1) then
		-- offline
		Undocked()
	elseif (param0 == 2) then
		-- online
		Docked()
	elseif (param0 == 3) then
		-- busy
		print ("^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ DOCK IS BUSY ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^")
	elseif (param0 == 4) then
		-- initializing
		dbg ("DOCK INITIALIZING")
--		CMD.GET_FIRMWARE_VERSION("")
	elseif (param0 == 5) then
		-- dock not supported
		print ("^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ DOCK IS NOT SUPPORTED ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^")
	elseif (param0 == 6) then
		-- dock upgrade required
		print ("^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ DOCK UPGRADE REQUIRED ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^")
	end
end


function RspList(pos, dataLen, strList, numItems, curItem, param0, param1, param2, param3)
	local totalItems = 0
	local numItems = 0
	local firstItem = 0
	local clearList = true
	strListTitle = string.sub(g_Receivebuffer, pos, (pos + dataLen - 2))

	if (bit.band(param0, 0x01) == 0x01) then
		clearList = true
		strList = strList .. "<clear>true</clear>"
	else
		clearList = false
		strList = strList .. "<clear>false</clear>"
	end
	if (bit.band(param0, 0x10) == 0x10) then
		topItem = true
		totalItems = param1 + 4
		numItems = param2 + 4
		strList = strList .. "<top>true</top>"
	else
		topItem = false
		totalItems = param1
		numItems = param2
		strList = strList .. "<top>false</top>"
	end
	if (bit.band(param0, 0x80) == 0x80) then
		strList = strList .. "<alpha>true</alpha>"
	else
		strList = strList .. "<alpha>false</alpha>"
	end

	if ((g_selectedItem ~= nil) and (g_selectedItem > 0)) then
		strList = strList .. "<selected_item>" .. g_selectedItem .. "</selected_item>"
		g_selectedItem = 0
	end

	firstItem = param3
	if (clearList == true) then
		if (firstItem == -1) then
			g_hasAll = true
		else
			g_hasAll = false
		end
	end

	if (g_hasAll == true) then
		firstItem = firstItem + 1
		totalItems = totalItems + 1
	end

	strList = strList .. "<title>" .. EscapeXML(strListTitle) .. "</title><total_items>" .. totalItems .. "</total_items><num_items>" .. numItems .. "</num_items><first>" .. firstItem .. "</first>"
	if (param1 == 0) then
		strList = strList .. "<items/></list>"
		SendToProxy("LIST", strList)
	else
		strList = strList .. "<items>"
	end
	dbg("\tRspList:strList = " .. strList)
	return strList
end

function RspListItem(pos, dataLen, strList, numItems, curItem, param0, param1)
	strListItem = string.sub(g_Receivebuffer, pos, (pos + dataLen - 2))

	curItem = curItem + 1

	local itemId = param1
	if (g_hasAll == true) then
		itemId = itemId + 1
	end

	strList = strList .. "<item><id>" .. itemId .. "</id><type>" .. param0 .. "</type><text>" .. EscapeXML(strListItem) .. "</text></item>"
	dbg("\tstrListItem = " .. EscapeXML(strListItem) .. "   curItem = " .. curItem .. "   numItems = " .. numItems)
	-- hexdump(strListItem)
	if (curItem >= numItems) then
		if (topItem) then

			if ((g_ListType == LISTTYPE.MUSIC) or (g_ListType == "0")) then
				strList = strList .. "<item><id>32007</id><text>Listen</text></item>"
			else
				strList = strList .. "<item><id>32007</id><text>Watch</text></item>"
			end
			strList = strList .. "<item><id>32002</id><text>Shuffle: " .. g_shuffle[g_shufflemode]
			strList = strList .. "</text></item><item><id>32001</id><text>Repeat: " .. g_repeat[g_repeatmode]
			if (g_ShowCoverArt == true) then
				strList = strList .. "</text></item><item><id>32008</id><text>Cover Art: On"
			else
				strList = strList .. "</text></item><item><id>32008</id><text>Cover Art: Off"
			end
			strList = strList .. "</text></item>"
		end
		strList = strList .. "</items></list>"
		dbg("\tRspListItem:strList = " .. strList)
		SendToProxy("LIST", strList)
	end
	return strList, curItem
end

function RspAlphaLookup(param0, param1)
	local alphaIndex = param1
	g_selectedItem = alphaIndex
	if (g_hasAll == true) then
		g_selectedItem = g_selectedItem + 1
	end

	GetNext(alphaIndex, 20)
end

function RspCoverArt(pos, dataLen, param0, param1, param2, param3)
	if (param0 == 0) then
		SetGettingCoverArt(true)
		dbg("Cover Art Found (first).")
		SendUISimpleToProxy("loadingcoverart", "true")
		g_StartTime = os.clock()
		coverArtTable = {}
		table.insert(coverArtTable, string.sub(g_Receivebuffer, pos, (pos + dataLen - 1)))
	elseif (param0 == 1) then
		table.insert(coverArtTable, string.sub(g_Receivebuffer, pos, (pos + dataLen - 1)))
	elseif (param0 == 2) then
		dbg("Cover Art Found (last).")
		SetGettingCoverArt(false)
		if (g_NowPlayingTimer == true) then
			SendElapsedTimeUI()
		else
			ClearElapsedTime()
		end
		SendUISimpleToProxy("loadingcoverart", "false")
		dbg("RspCoverArt: " .. string.format("elapsed time: %.2f\n", os.clock() - g_StartTime))
		table.insert(coverArtTable, string.sub(g_Receivebuffer, pos, (pos + dataLen - 1)))

		g_imagequeue[g_imageindex] = {}
		g_imagequeue[g_imageindex].width = bit.rshift(param1, 16)
		g_imagequeue[g_imageindex].height = bit.band(param1, 0xFFFF)
		g_imagequeue[g_imageindex].left = bit.rshift(param2, 16)
		g_imagequeue[g_imageindex].top = bit.band(param2, 0xFFFF)
		g_imagequeue[g_imageindex].right = bit.rshift(param3, 16)
		g_imagequeue[g_imageindex].bottom = bit.band(param3, 0xFFFF)
		g_imagequeue[g_imageindex].title = ""
		g_imagequeue[g_imageindex].artist = ""
		g_imagequeue[g_imageindex].album = ""
		g_imagequeue[g_imageindex].image = table.concat(coverArtTable, "")

		if (g_imageindex == g_current) then
			SendCoverArtToProxy(g_imageindex)
			g_imagequeue[g_imageindex].title = g_title
			g_imagequeue[g_imageindex].artist = g_artist
			g_imagequeue[g_imageindex].album = g_album

			if (g_current < g_totalsongs) then
				if (g_imagequeue[g_current+1] == nil) then
					g_imageindex = g_current + 1
					startCoverArtTimer()
					return
				end
			end
		end

		if (g_imageindex > 5) then
			g_imagequeue[g_imageindex-5] = nil
		end

	elseif (param0 == 0xff) then
		dbg ("Song does not contain cover art")
		if (g_imageindex == g_current) then
			if (g_current < g_totalsongs) then
				if (g_imagequeue[g_current+1] == nil) then
					g_imageindex = g_current + 1
					startCoverArtTimer()
					return
				end
			end
		end

		if (g_imageindex > 5) then
			g_imagequeue[g_imageindex-5] = nil
		end
	end
end

function RspShuffleMode(param0)
	g_shufflemode = param0
	SendUISimpleToProxy("shufflemode", g_shuffle[g_shufflemode])
end

function RspRepeatMode(param0)
	g_repeatmode = param0
	SendUISimpleToProxy("repeatmode", g_repeat[g_repeatmode])
end

function RspFirmwareVersion(pos, dataLen)
	g_firmwareVersion = string.sub(g_Receivebuffer, pos, (pos + dataLen - 2))
	C4:UpdateProperty("Firmware Version", g_firmwareVersion)
end

function GetFWVersion()
	dbg ("Firmware Version = " .. g_firmwareVersion)
end

function DisplayGlobalVariables()
	for k,v in pairs(_G) do	-- globals`
		if (string.find(k, "^g_")  == 1) then
			print(k .. ":  " .. tostring(v)) 
		end
	end
end

function ReceivedFromNetwork(idBinding, nPort, strData)
	-- Save up things coming back on port, process it for valid message (full length found)
	g_Receivebuffer = g_Receivebuffer .. strData
	local receiveBufferLen = string.len(g_Receivebuffer)

	-- loop through messages
	local messagePos = 1
	local remainingBufferLen = receiveBufferLen

	while(remainingBufferLen > 0) do
		-- dbg("messagePos = " .. messagePos .. "  remainingBufferLen = " .. remainingBufferLen)

		-- 22 bytes, we have entire header.
		if (remainingBufferLen < 22) then
			dbgUnitTest("receive buffer does not contain full header")
			g_Receivebuffer = string.sub(g_Receivebuffer, messagePos)
			return
		end

		-- get header message
		local pos, msgLen, strHeader, strCmd, param0, dataLen, param1, param2, param3 = string.unpack(g_Receivebuffer, "<H<Lbb<H<l<l<l", messagePos)
		msgLen = msgLen + 2

		-- check for valid header
		if (strHeader ~= 2857741055) then
			-- TODO: Consider searching for a valid header and go from there.
			dbg ("^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*")
			dbgUnitTest("Critical Error: Header does not match")
			dbg ("strHeader = ".. strHeader .. "  (" .. string.format("%02x", strHeader) .. ")")
			dbg ("msgLen = " .. msgLen)
			dbg ("remainingBufferLen = " .. remainingBufferLen)
			dbg ("")
			dbg ("hexdump(strData)")
			hexdump(strData)
			dbg ("")
			dbg ("hexdump(g_Receivebuffer)")
			hexdump(g_Receivebuffer)
			dbg ("*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^*^")
			g_Receivebuffer = ""
			return
--    else
--      dbg ("strHeader = ".. strHeader .. "  (" .. string.format("%02x", strHeader) .. ")")
--      dbg ("msgLen = " .. msgLen)
--      dbg ("remainingBufferLen = " .. remainingBufferLen)
--      dbg ("")
--      dbg ("hexdump(g_Receivebuffer)")
--      hexdump(g_Receivebuffer)
		end

		-- we have entire message
		if (remainingBufferLen < msgLen) then
			dbgUnitTest("receive buffer does not contain full message")
			g_Receivebuffer = string.sub(g_Receivebuffer, messagePos)
			return
		end

		if (g_debugprint) then
--			if (strCmd ~= NOTIFY.TIME) then
				dbg("ReceivedFromNetwork(" .. GetCommandText(strCmd) .. ")")
				dbg("    strCmd = " .. string.format("%02x", strCmd) .. " " .. GetCommandText(strCmd) ..
						"\tmsgLen = " .. msgLen .. " (" .. string.format("%02x", msgLen) .. ") " ..
						"\tdataLen = " .. dataLen .. " (" .. string.format("%02x", dataLen) .. ") " ..
						"\tparam0 = " .. param0 .. " (" .. string.format("%02x", param0) .. ") " ..
						"\tparam1 = " .. param1 .. " (" .. string.format("%02x", param1) .. ") " ..
						"\tparam2 = " .. param2 .. " (" .. string.format("%02x", param2) .. ") " ..
						"\tparam3 = " .. param3 .. " (" .. string.format("%02x", param3) .. ") "
				)
	--		end
		end

		-- process messages
		-- dbg("Processing Message")
		if (strCmd == RESP.COVER_ART) then
			RspCoverArt(pos, dataLen, param0, param1, param2, param3)
		elseif (strCmd == NOTIFY.IPOD_NAME) then
			NotifyIpodName(pos, dataLen, param0)
		elseif (strCmd == NOTIFY.NOW_PLAYING) then
			NotifyNowPLaying(pos, param1, param2)
		elseif (strCmd == NOTIFY.TIME) then
			NotifyTime(param1, param2)
		elseif (strCmd == NOTIFY.PLAYER_STATUS) then
			NotifyPlayerStatus(param0)
		elseif (strCmd == NOTIFY.DOCK_STATUS) then
			NotifyDockStatus(param0)

		elseif (strCmd == RESP.LIST) then
			strList = "<list>"
			numItems = param2
			curItem = 0
			strList = RspList(pos, dataLen, strList, numItems, curItem, param0, param1, param2, param3)
		elseif (strCmd == RESP.LIST_ITEM) then
			strList, curItem = RspListItem(pos, dataLen, strList, numItems, curItem, param0, param1)
		elseif (strCmd == RESP.ALPHA_LOOKUP) then
			RspAlphaLookup(param0, param1)
		elseif (strCmd == RESP.SHUFFLE_MODE) then
			RspShuffleMode(param0)
		elseif (strCmd == RESP.REPEAT_MODE) then
			RspRepeatMode(param0)
		elseif (strCmd == RESP.FW_VERSION) then
			RspFirmwareVersion(pos, dataLen)
		end

		messagePos = messagePos + msgLen
		remainingBufferLen = receiveBufferLen - messagePos + 1
		-- dbg("new: messagePos = " .. messagePos .. "  msgLen = " .. msgLen .. "  remainingBufferLen = " .. remainingBufferLen .. "  receiveBufferLen = " .. receiveBufferLen)
	end -- end while

	g_Receivebuffer = ""
end

function OnNetworkBindingChanged(idBinding, bIsBound)
	g_NetworkBound = bIsBound
	if (bIsBound) then
		dbg("Network Binding Bound...")
	else
		dbg("Network Binding Unbound...")
		Undocked()
	end
end


function OnConnectionStatusChanged(idBinding, nPort, strStatus)
	if (idBinding == 6001) then
		if (strStatus == "ONLINE") then
			dbg("Network Connection Online...")
			CMD.GET_FIRMWARE_VERSION("")
		else
			dbg("Network Connection Offline...")
			Undocked()
		end
	end
end

function ExecuteCommand(strCommand, tParams)
	dbgFunction("ExecuteCommand(" .. strCommand .. ")")
	if (strCommand == "LUA_ACTION") then
		if tParams ~= nil then
			for cmd,cmdv in pairs(tParams) do 
				dbg (cmd,cmdv)
				if cmd == "ACTION" then
					if cmdv == "DisplayGlobals" then
						DisplayGlobalVariables()
					else
						dbg("From ExecuteCommand Function - Undefined Action")
						dbg("Key: " .. cmd .. "  Value: " .. cmdv)
					end
				else
					dbg("From ExecuteCommand Function - Undefined Command")
					dbg("Key: " .. cmd .. "  Value: " .. cmdv)
				end
			end
		end
	end

	if (strCommand == "Set LED") then
		if (tParams["Setting"] == "Off") then
			QueueDockCmd(CMD["SET_LED_RAW"], 0, 0, 0, 0, "")
		else
			QueueDockCmd(CMD["SET_LED_RAW"], 1, 0, 0, 0, "")
		end
	end
end

function OnVariableChanged(strName)
	dbgFunction("OnVariableChanged(" .. strName .. ")")
end

function OnPoll(bindingId, port)
	if (g_gettingCoverArt == true) then
		if (g_skippedPolling >= 2) then
			ResetCoverArt()
		else
			dbg ("Getting Cover Art: Skipping OnPoll command")
			g_skippedPolling = g_skippedPolling + 1
			return
		end
	end

	g_skippedPolling = 0
	dbgFunction("OnPoll id:" .. bindingId .. " port:" .. port)
	SendSimpleDockCmd(CMD["GET_FW_VERSION_RAW"])
end

-- Stack Table
-- Uses a table as stack, use <table>:push(value) and <table>:pop()
-- Lua 5.1 compatible

-- GLOBAL
Stack = {}

-- Create a Table with stack functions
function Stack:Create()

	-- stack table
	local t = {}
	-- entry table
	t._et = {}

	-- push a value on to the stack
	function t:push(...)
		if ... then
			local targs = {...}
			-- add values
			for _,v in pairs(targs) do
				table.insert(self._et, v)
			end
		end
	end

	-- pop a value from the stack
	function t:pop(num)

		-- get num values from stack
		local num = num or 1

		-- return table
		local entries = {}

		-- get values into entries
		for i = 1, num do
			-- get last entry
			if #self._et ~= 0 then
				table.insert(entries, self._et[#self._et])
				-- remove last value
				table.remove(self._et)
			else
				break
			end
		end
		-- return unpacked entries
		return unpack(entries)
	end

	-- clear table
	function t:cleartable()
		if (nil ~= t) then
			t = {}
			t._et = {}
		end
	end

	-- get entries
	function t:getn()
		return #self._et
	end

	-- list values
	function t:list()
		for i,v in pairs(self._et) do
			print (i, v)
		end
	end
	return t
end

