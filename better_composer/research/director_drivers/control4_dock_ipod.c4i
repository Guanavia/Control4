function CMD.PLAYPAUSE(tParams)
	if (g_gettingCoverArt == true) then
		dbg ("Getting Cover Art: Skipping PLAYPAUSE command")
	else
		if (g_playerstatus == "Playing") then
			SendSimpleDockCmd(CMD["PAUSE_RAW"])
			g_playerstatus = "Paused"
		else
			SendSimpleDockCmd(CMD["PLAY_RAW"])
			SendToProxy("SELECT_DEVICE", {listtype = g_ListType, roomid = tParams["ROOM_ID"]})
			g_playerstatus = "Playing"
		end
	end
end


