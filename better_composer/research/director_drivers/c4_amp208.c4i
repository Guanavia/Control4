    <script>
      <![CDATA[
      

--------------------------------------------------------------------------------------------------------
-- Variables
--------------------------------------------------------------------------------------------------------

-- debugging flags
gPermaDebug = false
gLogVerbose = false
g_debugprint = false
g_debuglog = false

-- Debug timer
g_DebugTimer = 0

-- Power settings
g_useRelayForPowerStatus = false   -- When there is no contact binding we can assume that when the relay is closed the device is on.
g_useRelayForPowerControl = false  
g_relayDeviceID = nil

-- Power Off Delay Setting
g_powerOffDelayTimer = 0
g_powerOffDelayTimerValueInSeconds = 0
g_powerOffDelayTimerValuePropertyString = "Power Off Delay Time (seconds)"

-- General Flags
g_haveToldProxyWereHandlingValidity = false

-- Prefix for the global audio properties
g_globalAudioPropertyPrefix="Zone"
g_globalAudioPropertyGlobal="Global Input"

-- Binding ID's
AVSWITCH_BINDING_ID=5001
RELAY_BINDING_ID=8000

-- Maps for command handlers
AVSWITCH_PROXY_CMD_HANDLERS={}
RELAY_PROXY_CMD_HANDLERS={}

-- Array to know if outputs are active
g_outputInUse={false, false, false, false}


--------------------------------------------------------------------------------------------------------
-- Logging Helpers
--------------------------------------------------------------------------------------------------------
function dbg(strDebugText)
  if (g_debugprint) then 
    newDebugText = "DBG: [" .. os.date("%x %X") .. "] :: " .. strDebugText
    print(newDebugText) 
  end
  if (g_debuglog) then C4:DebugLog(strDebugText) end
end

function verbose(strDebugText)
  if(gLogVerbose == false) then
    return
  end
  
  if (g_debugprint) then 
    newDebugText = "DBG: [" .. os.date("%x %X") .. "] :: " .. strDebugText
    print(newDebugText) 
  end
  if (g_debuglog) then C4:DebugLog(strDebugText) end
end
    
function err(strErrText)
  newErrorText = "ERR: [" .. os.date("%x %X") .. "] :: " .. strErrText
  print(newErrorText) 
  C4:ErrorLog(strErrText)
end

--------------------------------------------------------------------------------------------------------
-- On Property Changed Handler
--------------------------------------------------------------------------------------------------------

function OnPropertyChanged(strProperty)
  if (strProperty == "Debug Mode") then
    if (Properties[strProperty] == "Off") then
      g_debugprint = false
      g_debuglog = false
      cancelDebugTimer()
    end
    if (Properties[strProperty] == "Print") then
      g_debugprint = true
      g_debuglog = false
      startDebugTimer() 
    end
    if (Properties[strProperty] == "Log") then
      g_debugprint = false
      g_debuglog = true
      startDebugTimer() 
    end
    if (Properties[strProperty] == "Print and Log") then
      g_debugprint = true
      g_debuglog = true
      startDebugTimer()
    end
    elseif (string.find(strProperty, g_globalAudioPropertyPrefix)) then
      HandleGlobalAudioSetting(strProperty, Properties[strProperty])
    elseif (strProperty == g_powerOffDelayTimerValuePropertyString) then
      g_powerOffDelayTimerValueInSeconds = Properties[strProperty]
    end
end

function HandleGlobalAudioSetting(strProperty, strValue)
  dbg("Updating \"" .. strProperty .. "\" to be \"" .. strValue .. "\"" )
  InvalidateBindingState()
end

--------------------------------------------------------------------------------------------------------
-- timer functions
--------------------------------------------------------------------------------------------------------

function OnTimerExpired(idTimer)
  if(gPermaDebug == true) then
    if(idTimer == gDebugTimer) then
      return
    end
  end
  
  if (idTimer == gDebugTimer) then
    dbg('Turning Debug Mode back to Off [default] (timer expired)')
    C4:UpdateProperty('Debug Mode', 'Off')
    gDebugprint = false
    gDebuglog = false
    cancelDebugTimer()
  elseif (idTimer == g_powerOffDelayTimer) then
    power_off_device()
  end
end

function startDebugTimer()
  cancelDebugTimer()
  g_DebugTimer = C4:AddTimer(15, "MINUTES")
end
    
function cancelDebugTimer()
  if (g_DebugTimer ~= 0) then
    C4:KillTimer(g_DebugTimer)
  end
  g_DebugTimer = 0
end

function startPowerOffTimer()
  dbg("Starting Power Off Delay Timer.")
  cancelPowerOffTimer()
  g_powerOffDelayTimer = C4:AddTimer(g_powerOffDelayTimerValueInSeconds, "SECONDS")
end

function cancelPowerOffTimer()
  if(g_powerOffDelayTimer ~= 0) then
    C4:KillTimer(g_powerOffDelayTimer)
    g_powerOffDelayTimer = 0
  end
end

--------------------------------------------------------------------------------------------------------
-- Init and Update Functions
--------------------------------------------------------------------------------------------------------

function OnDriverInit()
  verbose("OnDriverInit")
  g_haveToldProxyWereHandlingValidity = false
  C4:UpdateProperty("Version", 14)
end

function OnDriverLateInit()
  verbose("OnDriverLate")
  for k,v in pairs(Properties) do
    OnPropertyChanged(k)
  end
  --TellProxyPowerOn() -- now that we have 12V trigger mode, we can't do this
  if (g_haveToldProxyWereHandlingValidity == false) then
    TellProxyWereInChargeOfInputOutputValidity()
     g_haveToldProxyWereHandlingValidity = true
  end

end

function OnDriverUpdate()
  C4:UpdateProperty("Version", 14)
  for k,v in pairs(Properties) do
    OnPropertyChanged(k)
  end
end

--------------------------------------------------------------------------------------------------------
-- Binding stuff
--------------------------------------------------------------------------------------------------------
function OnBindingChanged(BindingID, Class, IsBound)
  verbose("Binding ID: " .. tostring(BindingID) .. " With type: " .. Class .. " is bound: " .. tostring(IsBound))
  if (BindingID == RELAY_BINDING_ID) then
    if(IsBound == true) then
      g_relayDeviceID = C4:GetBoundProviderDevice(0, BindingID)
      if(g_relayDeviceID == 0) then
	      g_relayDeviceID = nil
      end
      g_useRelayForPowerControl = true
      g_useRelayForPowerStatus = true
    else
      g_relayDeviceID = nil
      g_useRelayForPowerControl = false
      g_useRelayForPowerStatus = false
    end
  end
end
--------------------------------------------------------------------------------------------------------
-- Proxy functions
--------------------------------------------------------------------------------------------------------

function ReceivedFromProxy(BindingID, Command, tParams)
  verbose("ReceivedFromProxy: \"" .. Command .. "\"")
  
  if(BindingID == AVSWITCH_BINDING_ID) then
    if (g_haveToldProxyWereHandlingValidity == false) then
      TellProxyWereInChargeOfInputOutputValidity()
    end
    if (AVSWITCH_PROXY_CMD_HANDLERS[Command] ~= nil) and (type(AVSWITCH_PROXY_CMD_HANDLERS[Command])=='function') then
      return AVSWITCH_PROXY_CMD_HANDLERS[Command] (tParams)
    else
      dbg(Command .. ' AVSwitch Command Handler not defined!')
      return nil
    end
  elseif (BingingID == RELAY_BINDING_ID) then
    if (RELAY_PROXY_CMD_HANDLERS[Command] ~= nil) and (type(RELAY_PROXY_CMD_HANDLERS[Command])=='function') then
      return RELAY_PROXY_CMD_HANDLERS[Command] (tParams)
    else
      dbg(Command .. ' Power Control Relay Command Handler not defined!')
      return nil
    end
  end
end

function InvalidateBindingState()
  -- currently no way to do this progmatically
end

function TellProxyWereInChargeOfInputOutputValidity()
  C4:SendToProxy(AVSWITCH_BINDING_ID, 'PROTOCOL_WILL_HANDLE_AV_VALID', {})
  g_haveToldProxyWereHandlingValidity = true
end

function TellProxyPowerOn()
  dbg("Reporting Device As On")
  C4:SendToProxy(AVSWITCH_BINDING_ID, 'ON', {})
end

function TellProxyPowerOff()
  dbg("Reporting Device As Off")
  C4:SendToProxy(AVSWITCH_BINDING_ID, 'OFF', {})
end

function CloseRelay()
  dbg("Closing Relay To Power ON!")
  C4:SendToProxy(RELAY_BINDING_ID, "CLOSE", {}, 'COMMAND', false)
end

function OpenRelay()
  dbg("Open Relay To Power OFF!")
  C4:SendToProxy(RELAY_BINDING_ID, "OPEN", {}, 'COMMAND', false)
end

------------------------------------------------
-- AVSwitch Proxy functions
------------------------------------------------

function AVSWITCH_PROXY_CMD_HANDLERS.IS_AV_OUTPUT_TO_INPUT_VALID(params)
  local source            = (tonumber(params["Consumer_idBinding"]) - 3000) -- we are consuming the source, so the consumer binding is the source
  local output            = (tonumber(params["Provider_idBinding"]) - 7000) -- we are providing the output, to the output is the provider binding
    
  -- First we need to check if the source binding is a global audio input binding (0)
  if(source == 0 or source == 1) then
     if(output == 0) then
      verbose("global or input 1 always available for output 1")
      return "True"
    end
    dbg("Received Global Input.  Checking If This Is Valid For Output: " .. tostring(output+1))
    if(Properties[g_globalAudioPropertyPrefix .. " " .. tostring(output+1)] == g_globalAudioPropertyGlobal) then
      verbose("Received From Proxy :: IS_AV_OUTPUT_TO_INPUT_VALID :: Source: (global input) Output: (" .. output .. ")   THIS IS VALID!!!!")
      return "True"
    else
      verbose("Received From Proxy :: IS_AV_OUTPUT_TO_INPUT_VALID :: Source: (global input) Output: (" .. output .. ")   THIS IS INVALID!!!!")
      return "False"
    end
  else -- else we need to check that the source is the same as the output to see if it's a one-to-one.  Add one to the output to account for the off by one introduced by the global input binding (0).
      -- if the output is seet to the use global, the one-to-one is not hooked up
      if(Properties[g_globalAudioPropertyPrefix .. " " .. tostring(output+1)] == g_globalAudioPropertyGlobal) then
          verbose("global setting on output " .. tostring(output+1) .. " invalidates one-to-one input-output linkage")
          return "False"
      end
      if(source == (output+1)) then
        verbose("Received From Proxy :: IS_AV_OUTPUT_TO_INPUT_VALID :: Source: (" .. source .. ") Output: (" .. (output+1) .. ")   THIS IS VALID!!!!")
        return "True"
      else
        verbose("Received From Proxy :: IS_AV_OUTPUT_TO_INPUT_VALID :: Source: (" .. source .. ") Output: (" .. (output+1) .. ")   THIS IS INVALID!!!!")
        return "False"
      end
    end
end


function AVSWITCH_PROXY_CMD_HANDLERS.BINDING_CHANGE_ACTION(tParams)
  --no implementation on purpose
end

function AVSWITCH_PROXY_CMD_HANDLERS.SET_ROOM_BINDING_NAME(tParams)
  --no implementation on purpose
end

function AVSWITCH_PROXY_CMD_HANDLERS.ON(tParams)
  dbg("Received From Proxy : On")
  power_on_device()
end

function AVSWITCH_PROXY_CMD_HANDLERS.OFF(tParams)
  dbg("Received From Proxy : Off")
  
  if(any_outputs_are_in_use()) then
    dbg("Outputs are still in use, not turning off.")
    return
  end
  handle_power_off_request()
end

function AVSWITCH_PROXY_CMD_HANDLERS.SET_INPUT(tParams)
  --dbg("Got SET_INPUT from proxy but we don't switch.  Ignoring.")
  verbose("Received From Proxy: SET_INPUT :: Zone(" .. tParams["OUTPUT"] ..  ") <==> Source(" .. tParams["INPUT"] .. ")") 
  -- to get the one indexed output number, subtract the binding id (7000) then add 1 to get to the one index
  local output = tonumber(tParams["OUTPUT"]) - 7000 + 1
  dbg("Marking Output: " .. output .. " As In Use.")
  g_outputInUse[output] = true
end

function AVSWITCH_PROXY_CMD_HANDLERS.GET_AUDIO_PATH(tParams)
  --dbg("Got GET_AUDIO_PATH from proxy but we don't switch.  Ignoring.")
end

function AVSWITCH_PROXY_CMD_HANDLERS.CONNECT_OUTPUT(tParams)
  --dbg("Got CONNECT_OUTPUT from proxy but we don't switch.  Ignoring.")
end

function AVSWITCH_PROXY_CMD_HANDLERS.DISCONNECT_OUTPUT(tParams)
  -- to get the one indexed output number, subtract the binding id (7000) then add 1 to get to the one index
  local output = tonumber(tParams["OUTPUT"]) - 7000 + 1
  dbg("Marking Output: " .. output .. " As NOT In Use.")
  g_outputInUse[output] = false
  if(no_outputs_are_in_use()) then
    dbg("No Outputs In Use.  Turning Off.")
    handle_power_off_request()
  end
end

function AVSWITCH_PROXY_CMD_HANDLERS.GET_AUDIO_DEVICES(tParams)
  -- no implementation on purpose
end

------------------------------------------------
-- Relay Proxy functions
------------------------------------------------
function RELAY_PROXY_CMD_HANDLERS.STATE_CLOSED(tParams)
  if(g_useContactForPowerStatus == false and g_useRelayForPowerStatus == true) then
    TellProxyPowerOn()
  end
end

function RELAY_PROXY_CMD_HANDLERS.STATE_OPENED(tParams)
  if(g_useContactForPowerStatus == true and g_useRelayForPowerStatus == true) then
    TellProxyPowerOff()
  end
end

--------------------------------------------------------------------------------------------------------
-- Functions that do the real stuff
--------------------------------------------------------------------------------------------------------
function any_outputs_are_in_use()
  for i=1,#g_outputInUse do
    if(g_outputInUse[i]) then
      dbg("Output " .. tostring(i) .. " is in use.")
      return true
    end
  end
  return false
end

function no_outputs_are_in_use()
  if(any_outputs_are_in_use()) then
    return false
  else
    return true
  end
end

function handle_power_off_request()
  if(g_powerOffDelayTimerValueInSeconds == 0) then
    power_off_device()
  else
    startPowerOffTimer()
  end
end

function power_on_device()
  if(g_powerOffDelayTimer ~= 0) then
    cancelPowerOffTimer()
  end

  if(g_useRelayForPowerControl) then
    CloseRelay()
    if(g_useRelayForPowerStatus == true and g_useContactForPowerStatus == false) then
      TellProxyPowerOn()
    end
  end
  
  -- If we have no power feedback, just assume it is on or off based on the command to turn on and off
  --  assuming that the device will power on and off using its audio sense tech.
  if(g_useRelayForPowerStatus == false and g_useContactForPowerStatus == false) then
    TellProxyPowerOn()
  end
end

function power_off_device()
  if(g_useRelayForPowerControl) then
    OpenRelay()
    if(g_useRelayForPowerStatus == true and g_useContactForPowerStatus == false) then
      TellProxyPowerOff()
    end
  end
  --  assuming that the device will power on and off using its audio sense tech.
  if(g_useRelayForPowerStatus == false and g_useContactForPowerStatus == false) then
    TellProxyPowerOff()
  end
end
