		<commands>
		</commands>
		<script>
			<![CDATA[
LIGHT_PROXY_BINDING_ID = 5001
VANTAGE_BINDING_ID = 1

ON_BUTTON_BINDING = 300
OFF_BUTTON_BINDING = 301
TOGGLE_BUTTON_BINDING = 302

----------------------------------------- property handling -----------------------------------------
function OnPropertyChanged(strProperty)
	dbg("OnPropertyChanged(): strProperty = " .. strProperty .. " changed to: " .. Properties[strProperty])

	local prop = Properties[strProperty]

	if (strProperty == "Debug Mode") then
--[[
		gDbgPrint = true; gDbgLog = true; gDbgUnitTest = true; if (true) then return end
--]]
		if (gDbgTimer > 0) then gDbgTimer = C4:KillTimer(gDbgTimer) end
		gDbgPrint, gDbgLog, gDbgUnitTest = (prop:find("Print") ~= nil), (prop:find("Log") ~= nil), (prop:find("Log") ~= nil)
		if (prop == "Off") then
			return
		end
		gDbgTimer = C4:AddTimer(45, "MINUTES")
		return
	end

	if (strProperty == "Vantage Device ID") then
		local tParams = {DEVICE_ID = C4:GetDeviceID()}
		SendToProxy(VANTAGE_BINDING_ID, "ADD_DRIVER", tParams)
		return
	elseif (strProperty == "Click Ramp Rate Up") then
		gClickRampRateUp = Properties[strProperty] * 1000		-- convert to miliseconds
	elseif (strProperty == "Click Ramp Rate Down") then
		gClickRampRateDown = Properties[strProperty] * 1000		-- convert to miliseconds
	elseif (strProperty == "Hold Ramp Rate Up") then
		gHoldRampRateUp = Properties[strProperty]
	elseif (strProperty == "Hold Ramp Rate Down") then
		gHoldRampRateDown = Properties[strProperty]
	end
end

----------------------------------------- debug functions -----------------------------------------
function dbg(strDebugText)
	if (gDbgPrint) then print (strDebugText) end
	if (gDbgLog) then C4:ErrorLog("vantage_fusion_dimmer: " .. strDebugText) end
end

function dbgUnitTest(strDebugText)
	if (gDbgUnitTest) then print (strDebugText) end
	if (gDbgLog) then C4:ErrorLog("vantage_fusion_dimmer: " .. strDebugText) end
end

function dbgFunction(strFunction)
	local debugFunction = true
	if (gDbgPrint and debugFunction) then print ("Function:\t" .. strFunction .. ":") end
	if (gDbgLog and debugFunction) then C4:ErrorLog("vantage_fusion_dimmer: " .. strFunction) end
end

----------------------------------------- timer functions -----------------------------------------
function startDebugTimer()
	if (gDbgTimer) then
		gDbgTimer = C4:KillTimer(gDbgTimer)
	end
	gDbgTimer = C4:AddTimer(45, "MINUTES")
end

function OnTimerExpired(idTimer)
	if (idTimer == gDbgTimer) then
		dbg("Turning Debug Mode Off (timer expired)")
		C4:UpdateProperty("Debug Mode", "Off")
	end

	C4:KillTimer(idTimer)
end

----------------------------------------- Connection Functions -----------------------------------------
function OnBindingChanged(idBinding, class, bIsBound)
	dbg("OnBindingChanged(), idBinding = " .. tostring(idBinding) .. ", class = " .. class .. ", bIsBound = " .. tostring(bIsBound))
	if (bIsBound) then
		local tParams = {DEVICE_ID = C4:GetDeviceID()}
		SendToProxy(VANTAGE_BINDING_ID, "ADD_DRIVER", tParams)
	else
		local tParams = {DEVICE_ID = C4:GetDeviceID()}
		SendToProxy(VANTAGE_BINDING_ID, "REMOVE_DRIVER", tParams)
	end
end

----------------------------------------- Other Functions -----------------------------------------
-- Release things this driver had allocated...
function OnDriverDestroyed()
  -- Kill open timers
  if (gDbgTimer ~= nil) then gDbgTimer = C4:KillTimer(gDbgTimer) end
end

function SendToProxy(idBinding, strCommand, tParams, ...)
	dbgFunction("SendToProxy (" .. idBinding .. ", " .. strCommand .. ")")
	if (idBinding == VANTAGE_BINDING_ID) then
		tParams["ADDRESS"] = Properties["Vantage Device ID"]
	end
	if ... then
		local callType = ...
		C4:SendToProxy(idBinding, strCommand, tParams, callType)
	else
		C4:SendToProxy(idBinding, strCommand, tParams)
	end
end

----------------------------------------- DriverWorks Functions -----------------------------------------
function ExecuteCommand(strCommand, tParams)
	dbg("ExecuteCommand function called with : " .. strCommand)
	if (tParams == nil) then
		if (strCommand =="GET_PROPERTIES") then
			local tParams = {DEVICE_ID = C4:GetDeviceID()}
			SendToProxy(VANTAGE_BINDING_ID, "ADD_DRIVER", tParams)
			SendToProxy(LIGHT_PROXY_BINDING_ID, "CLICK_RAMP_RATE_UP", gClickRampRateUp)
			SendToProxy(LIGHT_PROXY_BINDING_ID, "CLICK_RAMP_RATE_DOWN", gClickRampRateDown)
		else
			dbg ("From ExecuteCommand Function - Unutilized command: " .. strCommand)
		end
	end

	-- Proxy Commands
	if (strCommand == "LIGHT_LEVEL_CHANGED") then
		gLightLevel = tParams["LEVEL"]
		SendToProxy(LIGHT_PROXY_BINDING_ID, strCommand, gLightLevel)

		if (tonumber(gLightLevel) == 0) then gLightState = "False" else gLightState = "True" end
		SendToProxy(ON_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
		SendToProxy(OFF_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
		SendToProxy(TOGGLE_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
	elseif (strCommand == "TOP_BUTTON_PUSH") then
		SendToProxy(LIGHT_PROXY_BINDING_ID, "TOP_BUTTON_PUSH", {})
	elseif (strCommand == "TOP_BUTTON_RELEASE") then
		SendToProxy(LIGHT_PROXY_BINDING_ID, "TOP_BUTTON_RELEASE", {})
	elseif (strCommand == "CLICK_COUNT") then
		if (tParams["NUMBER"] == "1") then
			SendToProxy(LIGHT_PROXY_BINDING_ID, "CLICK_COUNT", {BUTTON = 0, COUNT = 2})
		end
	end

	-- Events
end

function ReceivedFromProxy(idBinding, strCommand, tParams)
	dbgFunction("ReceivedFromProxy (" .. idBinding .. ", " .. strCommand .. ")")
	CommandInterpreter(idBinding, strCommand, tParams)
end

function CommandInterpreter(idBinding, strCommand, tParams)
	if (strCommand ~= nill) then
		if(tParams == nill)		-- initial table variable if nill
			then tParams = {}
		end
		dbg("Received from Proxy: " .. strCommand .. " on binding " .. idBinding .. "; Call Function " .. strCommand .. "()")
		if (idBinding == LIGHT_PROXY_BINDING_ID) then

			-- notifies
			if (strCommand == "GET_LIGHT_LEVEL") then
				GET_LIGHT_LEVEL(idBinding, tParams)
			elseif (strCommand == "GET_CONNECTED_STATE") then
				SendToProxy(LIGHT_PROXY_BINDING_ID, "ONLINE_CHANGED", "True")

			-- commands
			elseif (strCommand == "TOGGLE") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "TOGGLE_PRESET") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "CLICK_TOGGLE_BUTTON") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "RELEASE_TOGGLE_BUTTON") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", tParams)
			elseif (strCommand == "PUSH_TOP_BUTTON") then
				SendToProxy(VANTAGE_BINDING_ID, "START_RAISE_DIMMER", tParams)
			elseif (strCommand == "RELEASE_TOP_BUTTON") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", tParams)
			elseif (strCommand == "PUSH_BOTTOM_BUTTON") then
				SendToProxy(VANTAGE_BINDING_ID, "START_LOWER_DIMMER", tParams)
			elseif (strCommand == "RELEASE_BOTTOM_BUTTON") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", tParams)
			elseif (strCommand == "AV_BINDINGS_CHANGED") then
				local tParams = {DEVICE_ID = C4:GetDeviceID()}
				SendToProxy(VANTAGE_BINDING_ID, "ADD_DRIVER", tParams)
			elseif (strCommand == "SET_CLICK_RAMP_RATE_DOWN") then
				gClickRampRateDown = tParams["RATE"]
				C4:UpdateProperty("Click Ramp Rate Down", gClickRampRateDown/1000)
			elseif (strCommand == "SET_CLICK_RAMP_RATE_UP") then
				gClickRampRateUp = tParams["RATE"]
				C4:UpdateProperty("Click Ramp Rate Up", gClickRampRateUp/1000)
			else
				SendToProxy(VANTAGE_BINDING_ID, strCommand, tParams)
			end
		elseif (idBinding == VANTAGE_BINDING_ID) then
			if (strCommand == "GET_PROPERTIES") then
				local tParams = {DEVICE_ID = C4:GetDeviceID()}
				SendToProxy(VANTAGE_BINDING_ID, "ADD_DRIVER", tParams)
			else
				SendToProxy(LIGHT_PROXY_BINDING_ID, strCommand, tParams)
			end
		elseif (idBinding == ON_BUTTON_BINDING) then
			if (strCommand == "DO_CLICK") then
				tParams["LEVEL"] = 100
				tParams["TIME"] = gClickRampRateUp
				SendToProxy(VANTAGE_BINDING_ID, "SET_LEVEL", tParams)
			elseif (strCommand == "DO_PUSH") then
				local tParams = {TIME = gHoldRampRateUp}
				SendToProxy(VANTAGE_BINDING_ID, "START_RAISE_DIMMER", tParams)
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(ON_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
			end
		elseif (idBinding == OFF_BUTTON_BINDING) then
			if (strCommand == "DO_CLICK") then
				tParams["LEVEL"] = 0
				tParams["TIME"] = gClickRampRateDown
				SendToProxy(VANTAGE_BINDING_ID, "SET_LEVEL", tParams)
			elseif (strCommand == "DO_PUSH") then
				local tParams = {TIME = gHoldRampRateDown}
				SendToProxy(VANTAGE_BINDING_ID, "START_LOWER_DIMMER", tParams)
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(OFF_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
			end
		elseif (idBinding == TOGGLE_BUTTON_BINDING) then
			if (strCommand == "DO_CLICK") then
				if (gRaiseDimmer) then	-- this ignores presets and should be changed if presets are implemented
					tParams["LEVEL"] = 0
					tParams["TIME"] = gClickRampRateUp
				else
					tParams["LEVEL"] = 100
					tParams["TIME"] = gClickRampRateDown
				end
				SET_LEVEL(tParams)
			elseif (strCommand == "DO_PUSH") then
				if (tonumber(gLightLevel) == 0) then
					local tParams = {TIME = gHoldRampRateUp}
					SendToProxy(VANTAGE_BINDING_ID, "START_RAISE_DIMMER", tParams)
					gRaiseDimmer = false
				elseif (tonumber(gLightLevel) == 100) then
					local tParams = {TIME = gHoldRampRateDown}
					SendToProxy(VANTAGE_BINDING_ID, "START_LOWER_DIMMER", tParams)
					gRaiseDimmer = true
				else
					if (gRaiseDimmer) then
						local tParams = {TIME = gHoldRampRateUp}
						SendToProxy(VANTAGE_BINDING_ID, "START_RAISE_DIMMER", tParams)
						gRaiseDimmer = false
					else
						local tParams = {TIME = gHoldRampRateDown}
						SendToProxy(VANTAGE_BINDING_ID, "START_LOWER_DIMMER", tParams)
						gRaiseDimmer = true
					end
				end
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(VANTAGE_BINDING_ID, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(TOGGLE_BUTTON_BINDING, "MATCH_LED_STATE", {STATE = gLightState})
			end
		end
	end
end

function GET_LIGHT_LEVEL(idBinding, tParams)
	C4:SendToProxy(idBinding, "LIGHT_LEVEL_CHANGED", tostring(gLightLevel))
	SendToProxy(VANTAGE_BINDING_ID, "REQUEST_DIMMER_LEVEL", {})
end

function SET_LEVEL(tParams)
	SendToProxy(VANTAGE_BINDING_ID, "SET_LEVEL", tParams)
end

function TOGGLE_PRESET(tParams)
	if (gLightLevel == "0") then	-- this ignores presets and should be changed if presets are implemented
		tParams["LEVEL"] = 100
		tParams["TIME"] = gClickRampRateUp
	else
		tParams["LEVEL"] = 0
		tParams["TIME"] = gClickRampRateDown
	end
	SET_LEVEL(tParams)
end

function OnVariableChanged(strName)
	dbgFunction("OnVariableChanged(" .. strName .. ")")
end

----------------------------- INIT -----------------------------
--- global variables ---
gDbgTimer = 0
gLightLevel = 0
gLightState = "False"
gRaiseDimmer = true
gClickRampRateDown = 2000
gClickRampRateUp = 1000
gHoldRampRateDown = 5
gHoldRampRateUp = 5

-- Fire On Property Changed to set the initial Headers and other Property global sets, they'll change if Property is changed.
for k,v in pairs(Properties) do
	OnPropertyChanged(k)
end

]]>
		</script>
