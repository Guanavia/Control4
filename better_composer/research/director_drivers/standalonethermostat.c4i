		  <name>HEAT_SETPOINT_CHANGED</name>
		  <description>When NAME Heat Set Point has changed</description>
		</event>
	  <event>
		  <id>6</id>
		  <name>COOL_SETPOINT_CHANGED</name>
		  <description>When NAME Cool Set Point has changed</description>
		</event>
	</events>	
