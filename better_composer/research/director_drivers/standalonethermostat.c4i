	<commands>
		<command>
			<name>SET_MODE</name>
            <description>Set the HVAC Mode of the NAME to STRING</description>
		</command>
		<command>
			<name>SET_FAN_MODE</name>
			<description>Set the Fan Mode of the NAME to STRING</description>
		</command>
		<command>
			<name>SET_SETPOINT</name>
			<description>Set the Setpoint of the NAME to INTEGER</description>
		</command>
		<command>
			<name>SET_HEAT_SETPOINT</name>
			<description>Set the Heat Setpoint of the NAME to INTEGER</description>
		</command>
		<command>
			<name>SET_COOL_SETPOINT</name>
			<description>Set the Cool Setpoint of the NAME to INTEGER</description>
		</command>
	</commands>
	<conditionals>
     <conditional>
            <id>1</id>
            <name>IF_HVACMODE</name>
            <description>the NAME HVAC Mode is STRING</description>
        </conditional>
        <conditional>
            <id>2</id>
            <name>IF_FANMODE</name>
            <description>the NAME Fan Mode is STRING</description>
        </conditional>
        <conditional>
            <id>3</id>
            <name>IF_SETPOINT</name>
            <description>the NAME Set Point is STRING</description>
        </conditional>
        <conditional>
            <id>4</id>
            <name>IF_TEMPERATURE</name>
            <description>the NAME Temperature is LOGIC INTEGER</description>
        </conditional>
        <conditional>
            <id>5</id>
            <name>IF_HEAT_SETPOINT</name>
            <description>the NAME Heat Set Point is LOGIC INTEGER</description>
        </conditional>
        <conditional>
            <id>6</id>
            <name>IF_COOL_SETPOINT</name>
            <description>the NAME Cool Set Point is LOGIC INTEGER</description>
        </conditional>
	</conditionals>
	<events>
	  <event>
		  <id>1</id>
		  <name>HVACMODE_CHANGED</name>
		  <description>When NAME HVAC Mode has changed</description>
		</event>
	  <event>
		  <id>2</id>
		  <name>FANMODE_CHANGED</name>
		  <description>When NAME Fan Mode has changed</description>
		</event>
	  <event>
