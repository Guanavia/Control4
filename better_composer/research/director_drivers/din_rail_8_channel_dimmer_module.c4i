		<dimmer>True</dimmer>
		<phases>Auto-Detect=0,Forward Phase=3,Reverse Phase=4,SSL-7A=7</phases>
		<nominal_voltages>100,110,115,120,127,220,230,240,277</nominal_voltages>
	</capabilities>
	<connections>
