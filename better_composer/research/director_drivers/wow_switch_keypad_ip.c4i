    <script>
      <![CDATA[
			
-- Driver Version
function version()

   local maj = 1
   local min = 1
   local rev = 90
   local ver = string.format("%d.%d.%d", maj, min, rev)

   return ver
end

-- Global Variables

debug_timer_ = 0
debug_print_ = false
debug_log_ = false

network_bound_ = false
connection_id_ = 6001
port_ = 21826
connected_ = false

watch_variable_timer_ = 0

update_text_fields_timer_ = 0

sleep_ = true

button_command_ = 0x221

frame_end_ = 0xc0
destination_id_ = 0x01
source_id_ = 0x00

-- protocol field lengths that are constant
frame_end_length_ = 1
source_id_length_ = 0
destination_id_length_ = 1
command_length_length_ = 2
destination_id_length_ = 1 
command_length_ = 2
crc_length_ = 1

button_changed_event_ = 1
button_pressed_event_ = 2
button_released_event_ = 3

button_changed_ = { 
"Button One Changed", 
"Button Two Changed",
"Button Three Changed",
"Button Four Changed",
"Button Five Changed",
"Button Six Changed",
"Button Seven Changed",
"Button Eight Changed",
