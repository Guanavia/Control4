--------------- helpers ---------------------
--<bitwise_operations>

function bit_value(bit_pos)

   return math.pow(2, bit_pos - 1)
end

-- finds a bit and determines if it is set or not - the bit location is one based ie. bit one is the LSB
function is_bit_set(bit_loc, byte)

   local val = byte
   local mod_val = 0

   for i = 1, bit_loc do

      mod_val = math.mod(val, 2)

      if mod_val == 1 then

	 val = val - 1
      end
      val = val / 2
   end

   return mod_val
end

function bit_shift_left(shift_count, byte)
  
  local val = byte

  if shift_count > 0 then
  
     for i = 1, shift_count do

	val = val * 2
	if val > 255 then

	   val = val - 256
	end
     end
  end

  return val
end

function bit_xor(byte_one, byte_two)

   local val = 0

   for i = 1, 8 do

      if is_bit_set(i, byte_one) > 0 then

	 if is_bit_set(i, byte_two) == 0 then

	    val = val + bit_value(i) 
	 end
      else

	 if is_bit_set(i, byte_two) > 0 then

	    val = val + bit_value(i)
	 end
      end
   end

   return val
end

function bit_and(byte_one, byte_two)

   local val = 0

   for i = 1, 8 do

      if is_bit_set(i, byte_one) > 0 then

	 if is_bit_set(i, byte_two) > 0 then

	    val = val + bit_value(i) 
	 end
      end
   end

   return val
end

--</bitwise_operations>

function hex_string_to_number(hex_string)

   return tonumber(hex_string, 16)
end

function short_to_bytes(short)

   short = short / 256
   local msb, lsb = math.modf(short)
   lsb = lsb * 256

   return { msb, lsb }
end

function long_to_bytes(long)

   long = long / 65535
   local mss, lss = math.modf(long)
   lss = lss * 65535
   local ms_tbl = short_to_bytes(mss)
   local ls_tbl = short_to_bytes(lss)

   return { ms_tbl[1], ms_tbl[2], ls_tbl[1], ls_tbl[2] }
end

function append_byte(data_table, byte)

   table.insert(data_table, byte)
end

function append_table(data_table, tbl)

	for _, v in ipairs(tbl) do

   	table.insert(data_table, v)
	end
end

function append_short(data_table, sht)

   local tbl = short_to_bytes(sht)
   append_table(data_table, tbl)
end

function append_long(data_table, lng)

   local tbl = long_to_bytes(lng)
   append_table(data_table, tbl)
end

function serialize_text_write(data_table, text)

	for i = 1, 32 do
	
		if i <= #text then
		
    		local b = string.byte(text, i) 
    		append_byte(data_table, b)
		else
		
			append_byte(data_table, 0) -- fill with 0
		end
	end
end

function tag_substitute(str, tag, sub)

	return string.gsub(str, tag, sub)
end
--------------- packet parsing & forming ---------------

function parse_binary_packet(packet)

   local i = 1
   local b = string.byte(packet, i)

   local tbl = {}

   while b do

      tbl[i] = b
      i = i + 1
      b = string.byte(packet, i)
   end

   return tbl	-- return the table
end

function parse_source_id(tbl)

	local val_tbl = { tbl[2] } -- second byte is source id
   local hex_string = form_ascii_bytes(val_tbl) -- not needed for this function but makes other parsing consistent

   return hex_string_to_number(hex_string)
end

function parse_command_length(tbl)

	local val_tbl = { tbl[3], tbl[4] } -- third and fourth bytes is the command length
   local hex_string = form_ascii_bytes(val_tbl)

   return hex_string_to_number(hex_string)
end

function parse_destination_id(tbl)

	local val_tbl = { tbl[5] } -- second byte is destination id
   local hex_string = form_ascii_bytes(val_tbl) -- not needed for this function but makes other parsing consistent

   return hex_string_to_number(hex_string)
end

function parse_command(tbl)

	local val_tbl = { tbl[6], tbl[7] } -- sixth and seventh bytes is the command
   local hex_string = form_ascii_bytes(val_tbl)

   return hex_string_to_number(hex_string)
end

function process_button_data(tbl, offset)

	local btn = 0
	local upper_offset = offset + 4 -- four bytes of argument payload
	while offset < upper_offset do

		if tbl[offset] > 0 then
		
			btn = tbl[offset]
			break
		end
		offset = offset + 1
	end
	
	return btn
end

function form_binary_packet(tbl)

   local packet = ""
   local packet_length = 0
   for i, v in ipairs(tbl) do

      local b = string.char(v)
      packet = packet .. b
      packet_length = i
   end

   return packet, packet_length
end

-- table of bytes is formed into an ascii packet
function form_ascii_bytes(tbl)

   local packet = ""
   local packet_length = 0

   for i, v in ipairs(tbl) do

      local b = string.format("%02x",  v)
      packet = packet .. b
      packet_length = i
   end

   return packet, packet_length -- return the packet as a hex string
end

function form_binary_command(cmd, cmd_args)

	local data_frame_table = {}
	append_byte(data_frame_table, frame_end_)
	local cmd_table = {}
	form_binary_header(cmd_table, cmd)
	form_binary_payload(cmd_table, cmd, cmd_args)
	form_binary_checksum(cmd_table)
	append_table(data_frame_table, cmd_table)
	append_byte(data_frame_table, frame_end_)
	
	return data_frame_table
end

function form_binary_header(data_table, cmd) -- does not have frame end delim

	append_byte(data_table, source_id_)
	local cmd_length = arg_length_dictionary_[cmd] + 2
	append_short(data_table, cmd_length)
	append_byte(data_table, destination_id_)
end

function form_binary_payload(data_table, cmd, cmd_args)

	local tbl = command_dictionary_[cmd]
	if tbl ~= nil then
	
		append_table(data_table, tbl)
		append_table(data_table, cmd_args)
	end
end

function form_binary_checksum(data_table)

	local checksum = 0
	
	for _, v in ipairs(data_table) do

  	   checksum = checksum + v
		if (checksum / 256) >= 1 then
		
			checksum = checksum - 256
		end
	end	
	cs = 256 - checksum -- negation
	append_byte(data_table, cs)
end

--------------- end packet parsing & forming ---------------

function fire_button_changed(btn)

	local evt = lookup_button_event(btn, button_changed_event_)
	debug("Button Changed Event: " .. evt)
	C4:FireEvent(evt)
end

function fire_button_pressed(btn)

	local evt = lookup_button_event(btn, button_pressed_event_)
	debug("Button Pressed Event: " .. evt)
	C4:FireEvent(evt)
end

function fire_button_released(btn)

	local evt = lookup_button_event(btn, button_released_event_)
	debug("Button Released Event: " .. evt)
	C4:FireEvent(evt)
end

function lookup_button_event(btn, event_type)

	local evt = ""
	local index = btn -- one to one on buttons
	if index > 0 and index < 10 then
	
		if event_type == button_changed_event_ then
		
			evt = button_changed_[index]
		elseif event_type == button_pressed_event_ then
		
			evt = button_pressed_[index]
		elseif event_type == button_released_event_ then
		
			evt = button_released_[index]
		end
	end
	
	return evt
end

function update_property(name, val)

	C4:UpdateProperty(name, val)
	PersistData[name] = val
end

function execute_text_write(field_name, field_text)

	for i, v in ipairs(field_property_) do
	
		if v == field_name then
		
			if field_text ~= nil then

				wow_text_write(i, field_text)
			end			
		end
	end
end

-- intelligently updates fields based on tag in field
function update_text_fields(tag)

	for _, v in ipairs(field_property_) do

		local val = Properties[v]
		if val ~= nil then
		
			if string.find(val, tag) ~= nil then
		
				execute_text_write(v, val)
			end
		end
	end
end

function update_all_text_fields()

	for _, v in ipairs(field_property_) do

		local val = Properties[v]
		if val ~= nil then
	
			if # val > 0 then
	
				execute_text_write(v, val)
			end
		end
	end
end

function init_hospitality_values()

	local guest_name = C4:GetDeviceVariable(HOSPITALITY_AGENT_ID, VARIABLE_CUSTOMER_NAME)
	local outside_temperature = C4:GetDeviceVariable(HOSPITALITY_AGENT_ID, VARIABLE_OUTSIDE_TEMPERATURE)
	
	if guest_name ~= nil then
	
		sub_values_["SUB_GN"] = guest_name
	end
	if outside_temperature ~= nil then
	
		sub_values_["SUB_OT"] = outside_temperature
	end
end

function add_variables(tbl, data_type)

	for _, v in ipairs(tbl) do
	
		C4:AddVariable(v, Properties[v], data_type)
	end
end

function delete_variables(tbl)

	for _, v in ipairs(tbl) do
	
		C4:DeleteVariable(v)
	end
end

function get_table_index(tbl, name)

	for i, v in ipairs(tbl) do

		if name == v then
		
			return i
		end
	end
end

function update_tagged_variable(name, var_tag_tbl, var_name_tbl)

	local index = get_table_index(var_name_tbl, name)
	if index ~= nil then

		local tag = var_tag_tbl[index]
		update_text_fields(tag)
	end

	return index
end

-- tag_substitute(str, tag, sub)
function tag_substitute_variables(str, var_tag_tbl, var_name_tbl)

	for i, v in ipairs(var_tag_tbl) do
	
		str = tag_substitute(str, v, Variables[var_name_tbl[i]])
	end
	
	return str
end

function persist_data()

   if PersistData ~= nil then

		for _, v in ipairs(field_property_) do

			local val = Properties[v]
			if val ~= nil then

				PersistData[v] = val
			end
		end
   else

      debug("PersistData is nil")
      PersistData = {}
      persist_data()
   end
end

function get_persisted_data()

   if PersistData ~= nil then

		for k, v in pairs(PersistData) do
		
			C4:UpdateProperty(k, v)
		end
	else
	
		PersistData = {}
   end
end

function kill_update_text_fields_timer()

	update_text_fields_timer_ = C4:KillTimer(update_text_fields_timer_)
end

function start_update_text_fields_timer()

	kill_update_text_fields_timer()
	update_text_fields_timer_ = C4:AddTimer(5, "MINUTES")
end

----------------- Driverwork callbacks -----------------
function OnDriverInit()

 	-- get persisted data and add registrars
	get_persisted_data()
	
	add_variables(var_strings_, "STRING")
	add_variables(var_numbers_, "NUMBER")
end

function OnDriverLateInit()

	start_watch_variable_timer()
	init_hospitality_values()
end

function OnDriverDestroyed()

   debug("OnDriverDestroyed called")

	delete_variables(var_strings_)
	delete_variables(var_numbers_)

	C4:UnregisterVariableListener(HOSPITALITY_AGENT_ID, VARIABLE_CUSTOMER_NAME)
	C4:UnregisterVariableListener(HOSPITALITY_AGENT_ID, VARIABLE_OUTSIDE_TEMPERATURE)
	
   -- Kill all timers
   if debug_timer_ then
  
      debug("Stopping debug timer")
      debug_timer_ = C4:KillTimer(debug_timer_)
   end
   if watch_variable_timer_ then

      watch_variable_timer_ = C4:KillTimer(watch_variable_timer_)
   end

	kill_update_text_fields_timer()
end

function OnPropertyChanged(strProperty)

	if strProperty == "Debug Mode" then
  
		if Properties[strProperty] == "Off" then
    
			debug_print_ = false
			debug_log_ = false
			debug_timer_ = 0
     	elseif Properties[strProperty] == "Print" then
    
			debug_print_ = true
			debug_log_ = false
			start_debug_timer()
     	elseif Properties[strProperty] == "Log" then
    
			debug_print_ = false
			debug_log_ = true
			start_debug_timer()
     	elseif Properties[strProperty] == "Print and Log" then
    
			debug_print_ = true
			debug_log_ = true
			start_debug_timer()
     	end
	elseif strProperty == "Guest_Name" then
		
		sub_values_["SUB_GN"] = Properties[strProperty]
	else
	
		if get_table_index(field_property_, strProperty) ~= nil then
		
			execute_text_write(strProperty, Properties[strProperty])
		else 
		
			local index = get_table_index(var_strings_, strProperty)
			if index ~= nil then
			
				C4:SetVariable(strProperty, Properties[strProperty])
				update_text_fields(tag_strings_[index])
			else
			
				index = get_table_index(var_numbers_, strProperty)
				if index ~= nil then
				
					C4:SetVariable(strProperty, Properties[strProperty])
					update_text_fields(tag_numbers_[index])
				end
			end
		end
		
		PersistData[strProperty] = Properties[strProperty]
	end
end

function OnTimerExpired(idTimer)

   if idTimer == debug_timer_ then
  
      debug("Turning Debug Mode Off (timer expired)")
      C4:UpdateProperty("Debug Mode", "Off")
      debug_timer_ = C4:KillTimer(idTimer)
	elseif idTimer == watch_variable_timer_ then

		-- register variables
		C4:RegisterVariableListener(HOSPITALITY_AGENT_ID, VARIABLE_CUSTOMER_NAME)
		C4:RegisterVariableListener(HOSPITALITY_AGENT_ID, VARIABLE_OUTSIDE_TEMPERATURE)
		watch_variable_timer_ = C4:KillTimer(idTimer)
	elseif idTimer == update_text_fields_timer_ then
	
		update_all_text_fields()
		start_update_text_fields_timer()
   end
end

function OnWatchedVariableChanged(id_device, id_variable, str_value)

	debug("Watched variable changed: ID = " .. id_device .. "; Variable = " .. id_variable .. "; Value = " .. str_value)
	
	-- HOSPITALITY_AGENT_ID, VARIABLE_CUSTOMER_NAME
	if id_device == HOSPITALITY_AGENT_ID then
	
		if id_variable == VARIABLE_CUSTOMER_NAME then
		
			sub_values_["SUB_GN"] = str_value
			C4:UpdateProperty("Guest_Name", str_value)
			update_text_fields(TAG_GN)
		elseif id_variable == VARIABLE_OUTSIDE_TEMPERATURE then
			
			sub_values_["SUB_OT"] = str_value
			update_text_fields(TAG_OT)	
		end
	end
end

function ExecuteCommand(str_command, t_params)

   debug_command("ExecuteCommand", str_command, t_params)

 	if str_command == "LUA_ACTION" then

		if t_params ~= nil then

     		for param_name, param_value in pairs(t_params) do

	    		if param_name == "ACTION" then

	      		if param_value == "sleep_wake" then

						if sleep_ then
				
							wow_sleep()
						else
				
							wow_wake()
						end
						sleep_ = not sleep_;
					elseif param_value == "page_one" then
					
						wow_activate_page(1)
					elseif param_value == "page_two" then

						wow_activate_page(2)
					elseif param_value == "page_three" then

						wow_activate_page(3)
					elseif param_value == "page_four" then

						wow_activate_page(4)
					elseif param_value == "page_five" then

						wow_activate_page(5)
					elseif param_value == "page_six" then

						wow_activate_page(6)
	      		end					
	   		end
	  		end
 		end
	elseif str_command == "Sleep" then
	
		wow_sleep()
	elseif str_command == "Wake" then
	
		wow_wake()
	elseif str_command == "Page_Activate" then
	
		local page_num = t_params["Page"]
		if page_num ~= nil then
		
			wow_activate_page(tonumber(page_num))
		end
	else
	
		if get_table_index(field_property_, str_command) ~= nil then
	
			execute_text_write(str_command, t_params["Text"])
			update_property(str_command, t_params["Text"])
		end	
	end
end

function OnNetworkBindingChanged(idBinding, bIsBound)

  	debug("Network Binding " .. idBinding .. " Changed.")
  	if bIsBound then
      
    	debug("Binding is bound.")
  	else

    	debug("Binding is not bound.")
 	end
  	network_bound_ = bIsBound
end

function OnConnectionStatusChanged(idBinding, nPort, strStatus)

	if idBinding == 6001 then
	
    	if strStatus == "ONLINE" then

			connected_ = true
			OnDriverLateInit()
			-- update the text fields
			update_all_text_fields()
			start_update_text_fields_timer()
			
			debug("OnConnectionStatusChanged: Connected = true")
   	else

			connected_ = false
			kill_update_text_fields_timer()
			debug("OnConnectionStatusChanged: Connected = false")
      end
	end
end

function ReceivedFromNetwork(idBinding, nPort, packet)

	debug("<--- incoming packet --->")	
	local tbl = parse_binary_packet(packet)
	debug("Source ID: " .. parse_source_id(tbl))
	debug("Command Length: " .. parse_command_length(tbl))
	debug("Destination ID: " .. parse_destination_id(tbl))
	local command = parse_command(tbl)
	debug("Command: " .. command)
	if command == button_command_ then
	
		local btn = process_button_data(tbl, 12)
		if btn > 0 then
		
			fire_button_changed(btn)
			-- was it a press or a release?
			if btn == process_button_data(tbl, 8) then
			
				fire_button_pressed(btn)
			else
			
				fire_button_released(btn)
			end
		end
	end
	local str_packet, packet_length = form_ascii_bytes(tbl)
	debug("Hex from network: " .. str_packet)
	packet, packet_length = form_binary_packet(tbl)
	debug("Packet length: " .. packet_length)
	debug("<--- end incoming packet --->")
	debug(" ")
end

function OnVariableChanged(name)

	update_tagged_variable(name, tag_strings_, var_strings_)
	update_tagged_variable(name, tag_numbers_, var_numbers_)
	update_property(name, Variables[name])
end

function start_debug_timer()

   if debug_timer_ then
  
      debug_timer_ = C4:KillTimer(debug_timer_)
   end
   debug_timer_ = C4:AddTimer(15, "MINUTES")
end

function start_watch_variable_timer()

	if watch_variable_timer_ then

   	watch_variable_timer_ = C4:KillTimer(watch_variable_timer_)
	end
	watch_variable_timer_ = C4:AddTimer(2, "MINUTES")
end

function debug(text)

   if debug_print_ then 

      print(text) 
   end
   if debug_log_ then 

      C4:ErrorLog(text) 
   end
end

function debug_command(method, command, t_params)

   if debug_print_ or debug_log_ then

      text = method .. ": " .. command
      if t_params ~= nil then

      	 for param, value in pairs(t_params) do

            text = text .. ", " .. param .. "=" .. value
      	 end
      end
      debug(text)	
    end
end

function send_serial(data)

   if connected_ then

      C4:SendToNetwork(6001, port_, data)
   end
end

-------------------- commands sent to switch ------------------

function wow_sleep()

	local tbl = form_binary_command("Sleep", {})
	packet, packet_length = form_ascii_bytes(tbl)
	debug("Sleep Command: Packet = " .. packet .. "; Length = " .. packet_length)
	send_serial(form_binary_packet(tbl))
end

function wow_wake()

	local tbl = form_binary_command("Wake", {})
	packet, packet_length = form_ascii_bytes(tbl)
	debug("Wake Command: Packet = " .. packet .. "; Length = " .. packet_length)
	send_serial(form_binary_packet(tbl))
end

function wow_activate_page(page_num)

	local num = tonumber(page_num)
	local tbl = form_binary_command("Page_Activate", {num})
	packet, packet_length = form_ascii_bytes(tbl)
	debug("Activate Page Command: Packet = " .. packet .. "; Length = " .. packet_length)
	send_serial(form_binary_packet(tbl))
end

function wow_text_write(field_num, text)

	local num = tonumber(field_num)
	local arg_tbl = {num}
	
	text = tag_substitute(text, TAG_GN, sub_values_["SUB_GN"]) -- guest name
	text = tag_substitute(text, TAG_OT, sub_values_["SUB_OT"]) -- outside temperature
	text = tag_substitute_variables(text, tag_strings_, var_strings_) -- variable strings
	text = tag_substitute_variables(text, tag_numbers_, var_numbers_) -- variable numbers

	serialize_text_write(arg_tbl, text)
	local tbl = form_binary_command("Text_Write", arg_tbl)
	packet, packet_length = form_ascii_bytes(tbl)
	debug("Text Write Command: Packet = " .. packet .. "; Length = " .. packet_length)
	send_serial(form_binary_packet(tbl))
end

-- Update the Version property
C4:UpdateProperty("Version", version())

  ]]></script>
  </config>
</devicedata>