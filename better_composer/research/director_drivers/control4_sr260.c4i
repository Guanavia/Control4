  <control>control4_remote_gen</control>
  <search_types>
    <type>c4:control4_sr260:C4-SR260</type>
  </search_types>
  <composer_categories>
    <category>User Interface</category>
  </composer_categories>
  <proxy>control4_sr260</proxy>
  <driver name="remote_gen">6b6e27a9-0f24-4598-9c7f-1449607c4b91</driver>
  <states/>
  <connections>
    <connection>
      <id>6001</id>
      <facing>6</facing>
      <connectionname>Remote Control</connectionname>
      <type>4</type>
      <consumer>True</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>True</linelevel>
      <classes>
        <class>
          <classname>ZIGBEE</classname>
        </class>
      </classes>
    </connection>
  </connections>
  <capabilities>
    <has_display>True</has_display>
    <is_display_background_bright>False</is_display_background_bright>
    <can_be_found>True</can_be_found>
    <can_adjust_wake_on_motion>True</can_adjust_wake_on_motion>
    <wake_on_motion_quadstate>True</wake_on_motion_quadstate>
    <button_behavior>ShowDeviceList</button_behavior>
	<can_adjust_recharge_station_enable>True</can_adjust_recharge_station_enable>
    <can_display_volume_bar>True</can_display_volume_bar>
    <!-- These numbers come from the firmware and need to be set per hardware platform -->
    <max_list_cache_size>15</max_list_cache_size>
    <max_list_item_length>254</max_list_item_length>
    <controls_string>0e</controls_string>	<!-- This is 03 04 0e 64 from c4.ln.gc, but I think the code will choke on that length, and it really isn't used anyway -->
    <can_set_text_color>True</can_set_text_color>
    <utf8>True</utf8>
    <send_ConfigMenu>True</send_ConfigMenu>
    <send_SymbolIcons>True</send_SymbolIcons>
	<display_lines>6</display_lines>
	<button_timestamps>True</button_timestamps>
  </capabilities>
  <manufacturer>Control4</manufacturer>
  <creator>Control4</creator>
  <created>09/01/2014 12:30 PM</created>
