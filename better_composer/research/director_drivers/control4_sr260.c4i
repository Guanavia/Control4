  <config>
    <identify_image>C4-SR260-Z-Identify.gif</identify_image>
    <identify_text>Press the "4" button on the System Remote four times, or type the network address below.</identify_text>
    <remote_gen>
      <buttons>
        <button keycode="0" name="ROOM_OFF"/>

        <button keycode="1" name="SELECT_LAST_WATCH"/>
        <button keycode="2" name="CONTROL4"/>
        <button keycode="3" name="SELECT_LAST_LISTEN"/>

        <button keycode="4" name="DISPLAY"/>
