function ExecuteCommand(strCommand, tParams)
	if (strCommand == "LUA_ACTION") then
		if tParams ~= nil then
			for cmd,cmdv in pairs(tParams) do
				print (cmd,cmdv)
				if cmd == "ACTION" then
					if ACTION[cmdv] ~= nil then
						ACTION[cmdv]()
					else
						g_logger:Debug("From ExecuteCommand Function - Undefined Action")
						g_logger:Debug("Key: " .. cmd .. "  Value: " .. cmdv)
					end
				else
					g_logger:Debug("From ExecuteCommand Function - Undefined Command")
					g_logger:Debug("Key: " .. cmd .. "  Value: " .. cmdv)
				end
			end
		end
	end
end



