	SetHeatCutoff(HeatCutoffVal, true)
end


function CMD.SET_COOL_CUTOFF(tParams)
	local CoolCutoffVal = tonumber(tParams["VALUE"])
	SetCoolCutoff(CoolCutoffVal, true)
end


--------------- Actions ----------------------------
ACTION = {}

function ACTION.TriggerDREventVo()
	g_logger:Debug("Trigger Fake Voluntary DR Event")

	local CurEpoch = os.time()

	DRParams =
	{
		["ID"] = gFakeDREventID,
		["START_TIME"] = CurEpoch,
		["END_TIME"] = CurEpoch + 60,
		["LEVEL"] = 5,
		["COOLING_OFFSET"] = 45,
		["HEATING_OFFSET"] = 36,
		["DUTY_CYCLE"] = 67,
	}

	CMD.DEMAND_RESPONSE_INITIATED(DRParams)
	gFakeDREventID = gFakeDREventID + 1
end


function ACTION.TriggerDREventMa()
	g_logger:Debug("Trigger Fake Mandatory DR Event")

	local CurEpoch = os.time()

	DRParams =
	{
		["ID"] = gFakeDREventID,
		["START_TIME"] = CurEpoch,
		["END_TIME"] = CurEpoch + 90,
		["LEVEL"] = 9,
		["COOLING_OFFSET"] = 45,
		["HEATING_OFFSET"] = 36,
		["DUTY_CYCLE"] = 75,
	}

	CMD.DEMAND_RESPONSE_INITIATED(DRParams)
	gFakeDREventID = gFakeDREventID + 1
end


function ACTION.EndDREvent()
	g_logger:Debug("End Fake DR Event")

	DRParams =
	{
		["ID"] = gFakeDREventID - 1,
	}
	CMD.DEMAND_RESPONSE_COMPLETED(DRParams)
end


function ACTION.QueryTimeDay()
	QueryDevice(gMIBThermostatTime)
	QueryDevice(gMIBThermostatDate)
end




---------- Traps -------------------

TRP = {}

function TRP.c4zttp(tParams)
	-- temperature
	local temp = tonumber(tParams[1], 16)
	SetTemperature(temp)
end


function TRP.c4ztmc(tParams)
	-- hvac mode
	SetHvacMode(tonumber(tParams[1]))
end


function TRP.c4ztmh(tParams)
	-- hold mode
	SetHoldMode(tonumber(tParams[1], 16))
end


function TRP.c4ztsp(tParams)
	-- set points
	local coolpoint = tonumber(tParams[1], 16)
	local heatpoint = tonumber(tParams[2], 16)

	SetCoolSetpoint(coolpoint)
	SetHeatSetpoint(heatpoint)
end


function TRP.c4ztsx(tParams)
	-- status update
	local CurTemp = tonumber(tParams[1], 16)
	local CurSet = tonumber(tParams[2], 16)
	local HvacMode = tonumber(tParams[3], 16)
	local FanMode = tonumber(tParams[4], 16)
	local BatteryLevel = tonumber(tParams[5], 16)
	local DRLCState = tParams[6]
	local RemainingTime = tParams[7]
	local StageStateBits = tonumber(tParams[8], 16)

	SetTemperature(CurTemp)
	SetHvacMode(HvacMode)
	SetFanMode(FanMode)
	SetBatteryLevel(BatteryLevel)

	if(gCurTStatState.hvacMode == gHvacModeHeat) then
		SetHeatSetpoint(CurSet)
	elseif(gCurTStatState.hvacMode == gHvacModeCool) then
		SetCoolSetpoint(CurSet)
	end

	SetStageStates(StageStateBits)

--~ 	SetRelayBits(RelayStateBits)
end

function EnterDREvent(EventID, InTimeStamp)
	NotifyDRInitiated(EventID, InTimeStamp)
end


function ExitDREvent(EventID, InTimeStampUtc)
	if(EventID == gDRLCState.curEventID) then
		if(InTimeStampUtc+60 < gDRLCState.expireTime) then -- Allow up to 60sec of skew 
			NotifyDROptOut(EventID, InTimeStamp)
		else
			NotifyDRCompleted(EventID, InTimeStamp)
		end
		ClearDREventInfo()
	end
end

function TRP.c4ztdr(tParams)
	local EventID = tonumber(tParams[1], 16)
	local StartStop = tonumber(tParams[2], 16)
	local TimeStamp = DRLCState.NewTimeStamp(tonumber(tParams[3], 16),
											  tonumber(tParams[4], 16),
											  tonumber(tParams[5], 16),
											  tonumber(tParams[6], 16))

	if(StartStop == 0) then
		EnterDREvent(EventID, TimeStamp)
	else
		ExitDREvent(EventID, TimeStamp)
	end
end

--~ function TRP.c4ztsg(tParams)
--~   -- Stage states
--~   SetStageStates(tonumber(tParams[1], 16))
--~ end



function OnDriverInit()
	gBackstop = 1294988400 -- Jan 14, 2011 (non-UTC). Same date used as backstop for SE Server Time ZCL
	PersistData = PersistData or {}
	g_logger = C4_Logger:new(OnLogTimerExpired, 15, "/var/log/tmp_selogs")

	C4:UpdateProperty( "Debug Mode", "Off" )
	g_logger:SetOutput(false, false, false)

	C4:UpdateProperty( "Log Level", "Error" )
	g_logger:SetLevel( C4_Logger.LevelMap[Properties["Log Level"]] )

	C4:UpdateProperty( "Debug Duration (mins)", 15 )
	g_logger:SetDebugTimerDuration( C4_Logger.LevelMap[Properties["Debug Duration (mins)"]] )

	PersistData.DRLCState = PersistData.DRLCState or DRLCState.new()
	gDRLCState = PersistData.DRLCState

	SetStageConstants()
	C4:AddVariable("BatteryLevel", "100", "INT", true)     -- 1001
	C4:AddVariable("HvacType", "0", "INT", true)           -- 1002
	C4:AddVariable("AuxStageType", "2", "INT", true)       -- 1003
	C4:AddVariable("EmergStageType", "2", "INT", true)     -- 1004
	C4:AddVariable("FirmwareVersion", "-", "STRING", true) -- 1005
	C4:AddVariable("DeviceID", "-", "STRING", true)        -- 1006
	C4:AddVariable("InDREvent", "False", "BOOL", true)     -- 1007
	C4:AddVariable("PrimaryHeatState", "0", "INT", true)   -- 1008
	C4:AddVariable("AuxHeatState", "0", "INT", true)       -- 1009
	C4:AddVariable("PrimaryCoolState", "0", "INT", true)   -- 1010
	C4:AddVariable("AuxCoolState", "0", "INT", true)       -- 1011
	C4:AddVariable("EmerHeatState", "0", "INT", true)      -- 1012
	C4:AddVariable("CurDRSetpoint", "0", "INT", true)      -- 1013
	C4:AddVariable("CurDRExpireTime", "0", "INT", true)    -- 1014
	C4:AddVariable("ReversingValve", "0", "INT", true)     -- 1015
	C4:AddVariable("IsMandatory", "False", "BOOL", true)   -- 1016
	C4:AddVariable("ConnectionTime", "0", "INT", true)     -- 1017
	C4:AddVariable("SignalStrength", "0", "INT", true)     -- 1018
	C4:AddVariable("RSSI", "0", "INT", true)               -- 1019
	C4:AddVariable("Noise", "0", "INT", true)              -- 1020
	C4:AddVariable("LQI", "0", "INT", true)                -- 1021
	C4:AddVariable("Channel", "0", "INT", true)            -- 1022

	gRetrySendData = C4:AddTimer(5, "MINUTES", true)
	gMyDeviceID = C4:GetDeviceID()

	SetCalibration(0, false)
	SetHeatCutoff(5, false)
	SetCoolCutoff(5, false)
	SetVacationHeatSetpoint(3041)
	SetVacationCoolSetpoint(3052)
	SetAuxStageType(gStageTypeUndefined)
	SetEmerStageType(gStageTypeUndefined)
	SetReversingValve(gRevValveUndefined)
	C4:UpdateProperty("Version", Version())

	gHeatMinK = TemperatureUnits.WToK( tonumber( C4:GetCapability( "setpoint_heat_min" ) or 31 ) )
	gHeatMaxK = TemperatureUnits.WToK( tonumber( C4:GetCapability( "setpoint_heat_max" ) or 303 ) )
	gCoolMinK = TemperatureUnits.WToK( tonumber( C4:GetCapability( "setpoint_cool_min" ) or 48 ) )
	gCoolMaxK = TemperatureUnits.WToK( tonumber( C4:GetCapability( "setpoint_cool_max" ) or 320 ) )
end


function OnDriverDestroyed()
end


-- Driver Version
function Version()
	local keywordString = "$Revision: 84514 $" -- this uses subversion keyword substitution
	local _, _, revision = keywordString:find(": (.-) %$")
	return revision
end


--------------------------

function FirePropertyChanged(property, value)
	Properties[property] = value
	C4:UpdateProperty(property, value)
	OnPropertyChanged(property)
end



function OnPropertyChanged(strProperty)

	g_logger:Debug("OnPropertyChanged: Property = " .. strProperty)
	local PropSquished = string.gsub(strProperty, " ", "")	-- take the spaces out

	if PROP[PropSquished] ~= nil then
		PROP[PropSquished]()
	else
		g_logger:Debug("Unknown Property: " .. strProperty)
	end


end

--------------------------

function ReceivedFromProxy(idBinding, strCommand, tParams)
	g_logger:Debug("ReceivedFromProxy: idBinding = " .. idBinding .. "; Command = " .. strCommand .. "; Params = " .. C4_Logger:DumpValue(tParams))

	if CMD[strCommand] ~= nil then
		CMD[strCommand](tParams)
	else
		g_logger:Debug("ReceivedFromProxy command interpreter: Unhandled command = " .. strCommand)
	end


end

-------------------------- timer handling -------------------------------------

function OnTimerExpired(idTimer)
	if (idTimer == gDateTimeUpdateTimer) then
		C4:KillTimer(idTimer)
		SetCurrentDateAndTime()
	elseif (idTimer == gInitTimer) then
		C4:KillTimer(idTimer)
		if(not gHaveRecievedResponse) then
			InitialDeviceQuery()
		end
	elseif (idTimer == gPollSignalStrength) then
		UpdateSignalStrength()
	elseif (idTimer == gRetrySendData) then
		SendDelayedData()
	else
		-- Need to call this since we've overriden this function defined in C4_Timer.
		C4_Timer:OnTimerExpired(idTimer)
	end
end

function OnLogTimerExpired()
	g_logger:Debug("Turning Debug Mode Off (timer expired)")
	
	C4:UpdateProperty( "Debug Mode", "Off" )
	OnPropertyChanged("Debug Mode")

	C4:UpdateProperty( "Log Level", "Error" )
	OnPropertyChanged("Log Level")

	C4:UpdateProperty( "Debug Duration (mins)", 15 )
	OnPropertyChanged("Debug Duration (mins)")
end

