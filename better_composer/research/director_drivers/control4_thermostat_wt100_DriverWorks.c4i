DaySchedule =
{
	Wake = "Wake",
	Leave = "Leave",
	Return = "Return",
	Sleep = "Sleep",
	Custom1 = "Custom 1",
	Custom2 = "Custom 2",

	WakeTimeDefault = 360,
	LeaveTimeDefault = 480,
	ReturnTimeDefault = 1080,
	SleepTimeDefault = 1320,
	Custom1TimeDefault = 0,
	Custom2TimeDefault = 0,
}

function DaySchedule.new(WhichDay)
	local DaySched =
	{
		[0] = ScheduleEntry.new(WhichDay, DaySchedule.Wake, DaySchedule.WakeTimeDefault),
		[1] = ScheduleEntry.new(WhichDay, DaySchedule.Leave, DaySchedule.LeaveTimeDefault),
		[2] = ScheduleEntry.new(WhichDay, DaySchedule.Return, DaySchedule.ReturnTimeDefault),
		[3] = ScheduleEntry.new(WhichDay, DaySchedule.Sleep, DaySchedule.SleepTimeDefault),
		[4] = ScheduleEntry.new(WhichDay, DaySchedule.Custom1, DaySchedule.Custom1TimeDefault),
		[5] = ScheduleEntry.new(WhichDay, DaySchedule.Custom2, DaySchedule.Custom2TimeDefault),
	}

	DaySched.DayName = WhichDay

	return DaySched
end


function DaySchedule.GetScheduleEntry(Targ, EntryIndex)
	return Targ[EntryIndex]
end


function DaySchedule.Showall(Targ)
	print(Targ.DayName)
	for EntryIndex=0,5 do
 		ScheduleEntry.Showall(Targ[EntryIndex])
	end
	print("\n")
end


--------------------------------------------------

Schedule = {}

Schedule.Sunday = "Sunday"
Schedule.Monday = "Monday"
Schedule.Tuesday = "Tuesday"
Schedule.Wednesday = "Wednesday"
Schedule.Thursday = "Thursday"
Schedule.Friday = "Friday"
Schedule.Saturday = "Saturday"

function Schedule.new(SchedName)
	local sched =
	{
		[Schedule.Sunday] = DaySchedule.new(Schedule.Sunday),
		[Schedule.Monday] = DaySchedule.new(Schedule.Monday),
		[Schedule.Tuesday] = DaySchedule.new(Schedule.Tuesday),
		[Schedule.Wednesday] = DaySchedule.new(Schedule.Wednesday),
		[Schedule.Thursday] = DaySchedule.new(Schedule.Thursday),
		[Schedule.Friday] = DaySchedule.new(Schedule.Friday),
		[Schedule.Saturday] = DaySchedule.new(Schedule.Saturday),
	}

	sched[0] = sched[Schedule.Sunday]
	sched[1] = sched[Schedule.Monday]
	sched[2] = sched[Schedule.Tuesday]
	sched[3] = sched[Schedule.Wednesday]
	sched[4] = sched[Schedule.Thursday]
	sched[5] = sched[Schedule.Friday]
	sched[6] = sched[Schedule.Saturday]

	sched.name = SchedName

	return sched
end


function Schedule.GetScheduleEntry(Targ, DayIndex, EntryIndex)
	CurDay = Targ[DayIndex]
	return DaySchedule.GetScheduleEntry(CurDay, EntryIndex)
end


function Schedule.Showall(Targ)
	print("Name is: " .. Targ.name)
	for DayIndex=0,6 do
		DaySchedule.Showall(Targ[DayIndex])
	end
end


