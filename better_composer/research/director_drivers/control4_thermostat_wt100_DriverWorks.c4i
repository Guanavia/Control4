ScheduleEntry = {}
ScheduleEntry.DefaultHeatPoint = 100
ScheduleEntry.DefaultCoolPoint = 125

function ScheduleEntry.new(WhichDay, WhichEntry, DefaultTime)
	local entry =
	{
		EntryDay = WhichDay,
		EntryName = WhichEntry,
		Enabled = false,
		SchedTime = DefaultTime,
		HeatSetpoint = ScheduleEntry.DefaultHeatPoint,
		CoolSetpoint = ScheduleEntry.DefaultCoolPoint,

	}

	return entry

end

--~ function ScheduleEntry:Showall()
--~ 	print(self.EntryName)
--~ end


function ScheduleEntry.SetHeatpoint(Targ, NewHeatPoint)
	Targ.HeatSetpoint = NewHeatPoint
end


function ScheduleEntry.SetCoolpoint(Targ, NewCoolPoint)
	Targ.CoolSetpoint = NewCoolPoint
end


function ScheduleEntry.Showall(Targ)
	print(Targ.EntryName .. " " .. ScheduleEntry.TimeStr(Targ.SchedTime) .. " " .. FSchedVal(Targ.HeatSetpoint) .. " " .. FSchedVal(Targ.CoolSetpoint))
end



function ScheduleEntry.TimeStr(InTime)
	local HourVal = InTime / 60
	local MinVal = InTime % 60

	return string.format("%d:%02d", HourVal, MinVal)
end


function FSchedVal(InRawVal)
	local CVal = InRawVal / 5
	local FVal = (CVal * (9.0 / 5.0)) + 32.0
	return tostring(FVal)
end

