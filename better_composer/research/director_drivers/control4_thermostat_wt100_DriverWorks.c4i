end

function CMD.DEMAND_RESPONSE_INITIATED(tParams)

	for k,v in pairs(tParams) do g_logger:Debug(k .. " is " .. tostring(v)) end

	local EventID = tonumber(tParams.ID)
	local StartTime = tonumber(tParams.START_TIME)
	local EndTime = tonumber(tParams.END_TIME)
	local Level = tonumber(tParams.LEVEL)
	local HeatOffset = tParams.HEATING_OFFSET and tonumber(tParams.HEATING_OFFSET) or 0
	local CoolOffset = tParams.COOLING_OFFSET and tonumber(tParams.COOLING_OFFSET) or 0
	local HeatSetpoint = tParams.HEATING_SETPOINT and tonumber(tParams.HEATING_SETPOINT) or 0
	local CoolSetpoint = tParams.COOLING_SETPOINT and tonumber(tParams.COOLING_SETPOINT) or 0
	local DutyCycle = tParams.DUTY_CYCLE and tonumber(tParams.DUTY_CYCLE) or 0

	local MandatoryFlag = (tParams.IS_MANDATORY == "True")
	local Duration = math.ceil((EndTime - StartTime) / 60)
	local RunTimeMinutes = 0
	local OffTimeMinutes = 0

	if(DutyCycle ~= nil) then
		local TotalCyclePeriod = gDefaultDutycyclePeriod		-- adjust this as needed
		RunTimeMinutes = math.ceil((TotalCyclePeriod * DutyCycle) / 100)
		OffTimeMinutes = TotalCyclePeriod - RunTimeMinutes
	end

	local TargCool = gCurTStatState.refCoolSetpoint + TemperatureUnits.WToK_Interval(CoolOffset)
	local TargHeat = gCurTStatState.refHeatSetpoint - TemperatureUnits.WToK_Interval(HeatOffset)

	if(HeatSetpoint ~= 0) then
		TargHeat = TemperatureUnits.WToK( math.floor( HeatSetpoint / 10 ) ) -- HeatSetpoint received as Celsius * 100. Convert to Kelvin * 10
		
	end

	if(CoolSetpoint ~= 0) then
		TargCool = TemperatureUnits.WToK( math.floor( CoolSetpoint / 10 ) ) -- CoolSetpoint received as Celsius * 100. Convert to Kelvin * 10
	end

	TargHeat = TargHeat > 0 and TargHeat < gHeatMinK and gHeatMinK or TargHeat > gHeatMaxK and gHeatMaxK or TargHeat
	TargCool = TargCool > 0 and TargCool < gCoolMinK and gCoolMinK or TargCool > gCoolMaxK and gCoolMaxK or TargCool

	-- Save the target heating and cooling setpoints being applied
	tParams.HEATING_SETPOINT = TemperatureUnits.KToW(TargHeat) * 10
	tParams.COOLING_SETPOINT = TemperatureUnits.KToW(TargCool) * 10
	tParams.HEATING_OFFSET = nil
	tParams.COOLING_OFFSET = nil
	SetupDREventInfo(tParams)

	g_logger:Debug("DR INITIATED: HOffset: " .. HeatOffset .. " COffset: " .. CoolOffset .. " Duration: " .. Duration)

	C4:SetVariable("IsMandatory", tostring(MandatoryFlag))
	SetCurrentDateAndTime()
	SendDRLCToDevice(EventID, Duration, TargCool, TargHeat, RunTimeMinutes, OffTimeMinutes, MandatoryFlag)

end


function CMD.DEMAND_RESPONSE_COMPLETED(tParams)
	local EventID = tonumber(tParams["ID"])
	SendDRLCToDevice(EventID, tonumber(0), tonumber(0), tonumber(0), tonumber(0), tonumber(0), tonumber(0))
	ClearDREventInfo()
end


function CMD.DEMAND_RESPONSE_CANCELED(tParams)
	local EventID = tonumber(tParams["ID"])
	SendDRLCToDevice(EventID, tonumber(0), tonumber(0), tonumber(0), tonumber(0), tonumber(0), tonumber(0))
	ClearDREventInfo()
end


