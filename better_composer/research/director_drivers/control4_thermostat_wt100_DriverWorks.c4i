function SetRelayBits(AllBits)
--~ 	local WorkBits = tonumber(AllBits)

--~ 	local Bit_01 = WorkBits % 2	-- poor man's bit extracting
--~ 	WorkBits = math.(WorkBits / 2)		-- poor man's bit shift
--~ 	local Bit_02 = WorkBits % 2
--~ 	WorkBits = math.floor(WorkBits / 2)
--~ 	local Bit_04 = WorkBits % 2
--~ 	WorkBits = math.floor(WorkBits / 2)
--~ 	local Bit_08 = WorkBits % 2
--~ 	WorkBits = math.floor(WorkBits / 2)
--~ 	local Bit_10 = WorkBits % 2

--~ 	g_logger:Debug("Relay Bits are: " .. Bit_10 .. " " .. Bit_08 .. " " .. Bit_04 .. " " .. Bit_02 .. " " .. Bit_01)

--~ 	SetFanState((Bit_01 == 0) and gFanStateOff or gFanStateOn)

--~ 	if(gHVacType == gHvacTypeHPump) then
--~ 		-- Heat pump settings
--~ 		if(Bit_08 == 0) then
--~ 			-- Heating direction
--~ 			SetPrimaryCoolRelay(0)
--~ 			SetPrimaryHeatRelay(Bit_02)
--~ 			SetAuxCoolRelay(0)
--~ 			SetAuxHeatRelay(Bit_04)
--~ 		else
--~ 			-- Cooling direction
--~ 			SetPrimaryCoolRelay(Bit_02)
--~ 			SetPrimaryHeatRelay(0)
--~ 			SetAuxCoolRelay(Bit_04)
--~ 			SetAuxHeatRelay(0)
--~ 		end

--~ 		SetEmerHeatRelay(Bit_10)

--~ 	else
--~ 		-- conventional settings
--~ 		SetPrimaryCoolRelay(Bit_02)
--~ 		SetPrimaryHeatRelay(Bit_04)
--~ 		SetAuxCoolRelay(0)
--~ 		SetAuxHeatRelay(0)
--~ 		SetEmerHeatRelay(0)

--~ 		if((Bit_02 ~= 0) or (Bit_04 ~= 0)) then
--~ 			SetHvacState((Bit_02 ~= 0) and gHvacStateCool or gHvacStateHeat)
--~ 		else
--~ 			SetHvacState(gHvacStateOff)
--~ 		end
--~ 	end
end


function SetStageConstants()
	gStageFanMask = 0x01
	gStagePriHeatMask = 0x02
	gStageSecHeatMask = 0x04
	gStageAuxHeatMask = 0x08
	gStageEmeHeatMask = 0x10
	gStagePriCoolMask = 0x20
	gStageSecCoolMask = 0x40
	gStageHeatingMask = bit.bor(gStagePriHeatMask, gStageSecHeatMask, gStageAuxHeatMask, gStageEmeHeatMask)
	gStageCoolingMask = bit.bor(gStagePriCoolMask, gStageSecCoolMask)
	gStageHvacMask = bit.bor(gStageHeatingMask, gStageCoolingMask)
end


function SetStageStates(StateBits)

--~ 	-------------------------------------------------------------------
--~ 	local FanBit = bit.band(StateBits, gStageFanMask)
--~ 	local PriHeatBit = bit.rshift(bit.band(StateBits, gStagePriHeatMask), 1)
--~ 	local SecHeatBit = bit.rshift(bit.band(StateBits, gStageSecHeatMask), 2)
--~ 	local AuxHeatBit = bit.rshift(bit.band(StateBits, gStageAuxHeatMask), 3)
--~ 	g_logger:Debug("Relay Bits are: " .. StateBits .. " ".. AuxHeatBit .. " "  .. SecHeatBit .. " " .. PriHeatBit .. " " .. FanBit)
--~ 	-------------------------------------------------------------------

	SetFanState((bit.band(StateBits, gStageFanMask) ~= 0) and gFanStateOn or gFanStateOff)
	SetPrimaryHeatRelay(bit.rshift(bit.band(StateBits, gStagePriHeatMask), 1))
-- 	SetSecondaryHeatRelay(0)	-- WT100 doesn't have Secondary Heat
	SetAuxHeatRelay(bit.rshift(bit.band(StateBits, gStageAuxHeatMask), 3))
	SetEmerHeatRelay(bit.rshift(bit.band(StateBits, gStageEmeHeatMask), 4))
	SetPrimaryCoolRelay(bit.rshift(bit.band(StateBits, gStagePriCoolMask), 5))
-- 	SetAuxCoolRelay(0)	-- WT100 doesn't have Secondary Cool

	if(bit.band(StateBits, gStageHvacMask) ~= 0) then
		SetHvacState((bit.band(StateBits, gStageCoolingMask) ~= 0) and gHvacStateCool or gHvacStateHeat)
	else
		SetHvacState(gHvacStateOff)
	end
end

function ScheduleEntryToDevice(InDayIndex, InEntryIndex, InTargEntry)
	local DayOfWeekMasks =
	{
		[0] = 0x01,	-- Sunday
		[1] = 0x02,	-- Monday
		[2] = 0x04,	-- Tueday
		[3] = 0x08,	-- Wednesday
		[4] = 0x10,	-- Thursday
		[5] = 0x20,	-- Friday
		[6] = 0x40,	-- Saturday
	}
	local HourVal = InTargEntry.SchedTime / 60
	local MinuteVal = InTargEntry.SchedTime % 60

	if (InTargEntry.Enabled) then
		MinuteVal = MinuteVal + 0x80
	end
	local HeatVal = TemperatureUnits.KToS(InTargEntry.HeatSetpoint)
	local CoolVal = TemperatureUnits.KToS(InTargEntry.CoolSetpoint)

	local MIBParmsStr = string.format("%02x %02x %02x %02x %02x %02x",
										DayOfWeekMasks[InDayIndex],
										InEntryIndex,
										HourVal,
										MinuteVal,
										CoolVal,
										HeatVal)

	SendData(FormMibPacket(gC4MIBInvoke, gMIBScheduleEdit , MIBParmsStr))

end

function UpdateScheduleEntry(EntryTab)
	local DayIndex = tonumber(EntryTab["DayOfWeek"])
	local EntryIndex = tonumber(EntryTab["EntryIndex"])
 	g_logger:Debug("UpSchedEnt: DayIndex is: " .. DayIndex .. "  EntryIndex is: " .. EntryIndex)

	TargEntry = Schedule.GetScheduleEntry(gMasterSchedule, DayIndex, EntryIndex)
 	g_logger:Debug("UpSchedEnt: Day is: " .. TargEntry.EntryDay .. "  Entry name is: " .. TargEntry.EntryName)

	ScheduleEntry.SetHeatpoint(TargEntry, tonumber(EntryTab["HeatSetpoint"]))
	ScheduleEntry.SetCoolpoint(TargEntry, tonumber(EntryTab["CoolSetpoint"]))
	TargEntry.Enabled = (string.lower(EntryTab["IsEnabled"]) == "true")
	TargEntry.SchedTime = tonumber(EntryTab["EntryTime"])

	NotifyScheduleEntry(DayIndex, EntryIndex, TargEntry)
	ScheduleEntryToDevice(DayIndex, EntryIndex, TargEntry)

end


function SetCalibration(NewCalib, SendToDevice)
	if(gCurTStatState.calibration ~= NewCalib) then
		gCurTStatState.calibration = NewCalib
		local calibration = TemperatureUnits.ScaleIntervalValue(gCurTStatState.calibration)
		C4:UpdateProperty("Temp Calibration", tostring(calibration))
		NotifyProxy( "CALIBRATION_CHANGED", { CALIBRATION = gCurTStatState.calibration } )
		if(SendToDevice) then
			local MibStr = string.format("%02x", (gCurTStatState.calibration % 256))
			SendData(FormMibPacket(gC4MIBSet, gMIBCalibration , MibStr))
		end
	end
end


function SetHeatCutoff(CutoffVal, SendToDevice)
	if(gCurTStatState.heatCutoff ~= CutoffVal) then
		gCurTStatState.heatCutoff = CutoffVal

		-- For display purposes, the cutoff value is scaled to the current temperature units
		local scaledCutoff = TemperatureUnits.ScaleIntervalValue(gCurTStatState.heatCutoff, 1)
		C4:UpdateProperty( "Heat Cutoff Point", string.format("%.1f", scaledCutoff) )

		if(SendToDevice) then
			local MibStr = string.format("%02x 00 01", gCurTStatState.heatCutoff)
			SendData(FormMibPacket(gC4MIBSet, gMIBHeatCoolCutoffs , MibStr))
		end
	end
end


function SetCoolCutoff(CutoffVal, SendToDevice)
	if(gCurTStatState.coolCutoff ~= CutoffVal) then
		gCurTStatState.coolCutoff = CutoffVal

		-- For display purposes, the cutoff value is scaled to the current temperature units
		local scaledCutoff = TemperatureUnits.ScaleIntervalValue(gCurTStatState.coolCutoff, 1)
		C4:UpdateProperty( "Cool Cutoff Point", string.format("%.1f", scaledCutoff) )

		if(SendToDevice) then
			local MibStr = string.format("00 %02x 02", gCurTStatState.coolCutoff)
			SendData(FormMibPacket(gC4MIBSet, gMIBHeatCoolCutoffs , MibStr))
		end
	end
end

function UpdateSignalStrength()
	local rssi = "-"
	local noise = "-"
	local lqi = "-"
	local rx_lqi = "-"
	local tx_lqi = "-"
	local signalStrength = 0
	local rssiNumber = 0
	local noiseNumber = 0
	local lqiNumber = 0
	local rx_lqiNumber = 0
	local tx_lqiNumber = 0
	local channelNumber = 0

	local znodeInfo = C4:GetZnodeInfo( Properties["MAC"] )
	if znodeInfo then
		rssi = znodeInfo.rssi
		noise = znodeInfo.noise
		rx_lqi = znodeInfo.rx_lqi
		tx_lqi = znodeInfo.tx_lqi
		rssiNumber = tonumber(rssi) or rssiNumber
		noiseNumber = tonumber(noise) or noiseNumber
		rx_lqiNumber = tonumber(rx_lqi) or rx_lqiNumber
		tx_lqiNumber = tonumber(tx_lqi) or tx_lqiNumber

		if rx_lqiNumber < tx_lqiNumber then
			lqi = rx_lqi
			lqiNumber = rx_lqiNumber
		else
			lqi = tx_lqi
			lqiNumber = tx_lqiNumber
		end

		channelNumber = tonumber(znodeInfo.channel) or channelNumber

		g_lqiHistory = g_lqiHistory or {}
		table.insert( g_lqiHistory, lqiNumber )
		while #g_lqiHistory > 3 do
			table.remove( g_lqiHistory, 1 )
		end

		local averageLQI = 0
		if #g_lqiHistory > 0 then
			for _, iteratedLQI in ipairs( g_lqiHistory ) do
				averageLQI = averageLQI + iteratedLQI
			end
			averageLQI = averageLQI / #g_lqiHistory
		end

		signalStrength =	averageLQI > 244 and 5 or
							averageLQI > 233 and 4 or
							averageLQI > 222 and 3 or 
							averageLQI > 211 and 2 or 
							averageLQI > 199 and 1 or signalStrength
	end

	C4:UpdateProperty("Znode RSSI", rssi)
	C4:UpdateProperty("Znode Noise", noise)
	C4:UpdateProperty("Znode LQI", lqi)
	C4:SetVariable("SignalStrength", signalStrength)
	C4:SetVariable("RSSI", rssiNumber)
	C4:SetVariable("Noise", noiseNumber)
	C4:SetVariable("LQI", lqiNumber)
	C4:SetVariable("Channel", channelNumber)

	g_logger:Debug( "PROP: RSSI = " .. tostring( rssi ) .. " and LQI = " .. tostring( lqi ) )
end





PROP = {}
function PROP.DebugMode()
	-- Assume "Off" or a property we don't understand
	local debugProp = Properties["Debug Mode"]
	local outputPrint, outputLog, outputReport = false, false, false
	if(debugProp == "Print") then
		outputPrint = true
	elseif(debugProp == "Log") then
		outputLog = true
	elseif debugProp == "Report" then
		outputReport = true
	elseif(debugProp == "Print and Log") then
		outputPrint = true
		outputLog = true
	end
	g_logger:SetOutput(outputPrint, outputLog, outputReport)
end

function PROP.LogLevel()
	g_logger:SetLevel(C4_Logger.LevelMap[Properties["Log Level"]])
end

PROP["DebugDuration(mins)"] = function()
	local strDuration = Properties["Debug Duration (mins)"]
	local duration = tonumber(strDuration) or 15
	g_logger:SetDebugTimerDuration(duration)
end

function PROP.HVACType()
	local CurType = Properties["HVAC Type"]
	g_logger:Debug("PROP: HVACType is " .. CurType)
	SetHvacType(gHvacTypes[CurType])
end


function PROP.TempCalibration()
	local Calibration = tonumber(Properties["Temp Calibration"])
	g_logger:Debug("PROP: Temp Calibration is " .. Calibration)
	SetCalibration(TemperatureUnits.NormalizeIntervalValue(Calibration), true)
end


function PROP.HeatCutoffPoint()
	local HeatCutoffVal = tonumber(Properties["Heat Cutoff Point"])
	g_logger:Debug("PROP: Heat Cutoff is " .. HeatCutoffVal)
	SetHeatCutoff(TemperatureUnits.NormalizeIntervalValue(HeatCutoffVal), true)
end


function PROP.CoolCutoffPoint()
	local CoolCutoffVal = tonumber(Properties["Cool Cutoff Point"])
	g_logger:Debug("PROP: Cool Cutoff is " .. CoolCutoffVal)
	SetCoolCutoff(TemperatureUnits.NormalizeIntervalValue(CoolCutoffVal), true)
end

function PROP.ZnodeRefreshIntervalSeconds()
	if gZigbeeOnline == true then
		if (gPollSignalStrength ~= nil) then
			C4:KillTimer(gPollSignalStrength)
		end

		gPollSignalStrength = C4:AddTimer( Properties["Znode Refresh Interval Seconds"], "SECONDS", true )
	end
end





