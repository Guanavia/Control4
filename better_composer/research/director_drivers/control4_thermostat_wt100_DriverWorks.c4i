    <script>
<![CDATA[

----------------------------------------------------------
--------------------- Generic Class Def  -----------------
----------------------------------------------------------

function C4_Class( baseClass )

    local new_class = {}
    local class_mt = { __index = new_class }
	local interface = nil

    function new_class:create(parentInst)
        local newinst = {}
        if (interface) then
        	newinst.interface = interface
        end

		-- Copy parent instance member variables.
		if (parentInst) then
			for k,v in pairs(parentInst) do
				newinst[k] = v
			end
		end

        setmetatable( newinst, class_mt )
        new_class:checkInterfaceMethods()
        return newinst
    end

    if baseClass ~= nil then
        setmetatable( new_class, { __index = baseClass } )
    end

    -- Implementation of additional OO properties starts here --

    -- Return the class object of the instance
    function new_class:instance()
        return new_class
    end

    -- Return the super class object of the instance
    function new_class:base()
		return baseClass
    end

    -- Return true theClass is an instance of the caller  
    function new_class:isa( theClass )
        local b_isa = false

		if (not theClass) then
			return b_isa
		end
		
        local cur_class = theClass
        
		if (theClass.instance and theClass:instance() == new_class) then
			b_isa = true
		end
		
        while ( cur_class ~= nil ) and ( b_isa == false ) do
            if cur_class == new_class then
                b_isa = true
            else
                if (cur_class.base) then
                	cur_class = cur_class:base()
                else
                	cur_class = nil
                end
            end
        end

        return b_isa
    end

    -- Checks to make sure class implements methods on interface.
    function new_class:implements( theInterface )
    	if (not theInterface) then
    		error("IMPLEMENTING NULL INTERFACE.  Check requires and syntax.")
    	end
    	
    	interface = theInterface
    	return new_class
    end
    
    -- Returns the class name found in global scope
    -- PERFORMANCE HIT as this traverse the _G variable!
    function new_class:classname() 
    	if (new_class._classname) then
    		return new_class._classname
    	end
    	
    	for k,v in pairs(_G) do
    		if (v == new_class) then
    			new_class._classname = k
    			return new_class._classname
    		end
    	end
    	error ("Class Name not found in Global scope")
    end
    
    function new_class:checkInterfaceMethods()
    	if (not interface) then
    		return
    	end
    	
		local interfaceMethods = interface:methods()

		for k,v in pairs(interfaceMethods) do
			if (type(v) == 'function' and not new_class[k]) then
				local classname = 'Class'
				if (new_class.classname) then
					classname = new_class:classname()
				end
				error(classname .. " must implement method " .. k, 3)
			end
		end
	end
	
	return new_class
end



------------------------------------------------------------------
------------------- Timer Class -----------------------------------
--~ Class is used to encapsulate the C4 Timers.
------------------------------------------------------------------

C4_Timer = C4_Class()

C4_Timer.SECONDS = "SECONDS"
C4_Timer.MINUTES = "MINUTES"

C4_Timer.Handlers = {}

----------------------------------------------------
--- Creates an instance of a C4_Timer
-- @param interval      An integer value representing the inteval in 'units'
-- @param units         A string value representing units.  ('SECONDS' | 'MINUTES')
-- @param callback      Function to invoke when timer expires.
-- @param name          Optional: string value used for diagnostic purposes. Default 'NO_NAME_TIMER'
-- @param restart       Optional: true: automatically restart timer on expiry. Otherwise false (default).
-- @param logger        Optional: C4_Logger instance used for diagnostics.
-- @return Instance of newly created C4_Timer
---------------------------------------------------
function C4_Timer:new(interval, units, callback, restart, name, logger)
	local obj = C4_Timer:create()
	obj.interval = tonumber(interval)
	obj.units = units
	obj.callback = callback
	obj.restart = restart or false
	obj.name = name or 'NO_NAME_TIMER'
	obj.logger = logger or C4_Logger:new()
	obj.id = nil
	
	return obj
end

----------------------------------------------------
--- Starts the timer.  If timer is currently active,
-- the timer is first stopped then started.
-- @param interval      Optional: An integer value representing the inteval in 'units'
-- @param units         Optional: A string value representing units.  ('SECONDS' | 'MINUTES')
-- @return true if timer was started.  false otherwise
---------------------------------------------------
function C4_Timer:Start(interval, units)
	self.interval = interval or self.interval
	self.units = units or self.units
	
	self:Stop()
	self.id = C4:AddTimer(self.interval, self.units, self.restart)
	
	-- Register callback with global OnTimerExpire
	if (self.id) then
		C4_Timer.Handlers[self.id] = self
	end

	if (self.id) then
		return true
	end
	
	return false
end

----------------------------------------------------
--- Stops the timer
---------------------------------------------------
function C4_Timer:Stop()
	if (self.id) then
		C4_Timer.Handlers[self.id] = nil
		self.id = C4:KillTimer(self.id)
	end
end

----------------------------------------------------
--- Static OnTimerExpire Function invoked when system
-- timers expire.
---------------------------------------------------
function C4_Timer:OnTimerExpired(timerId)

	if (self ~= C4_Timer) then
		error("Invalid call to static method")
	end

	local funcName = "C4_Timer:OnTimerExpired"

	if (C4_Timer.Handlers[timerId] == nil) then
		return
	end
	
	-- Fetch timer from static handlers
	local timer = C4_Timer.Handlers[timerId];
	if (timer) then
--		timer.logger:Debug(funcName .. ": Processing Timer '" .. timer.name .. "'")
		
		if (timer.callback) then
			-- invoke callback
			timer.callback(timerId)
		end
	end
	
	-- Remove timer from handlers if auto restart is false.
	if (not timer or not timer.restart) then
		C4_Timer.Handlers[timerId] = nil
	end

end

function C4_Timer:StopAll()
	if (self ~= C4_Timer) then
		error("Invalid call to static method")
	end

	for timerId, timer in pairs(C4_Timer.Handlers) do
		timer:Stop()
	end
end

function OnTimerExpired(idTimer)
	C4_Timer:OnTimerExpired(idTimer)
end




C4_StringBuilder = C4_Class()

----------------------------------------------------
-- This class provides an optimal way to build a string
----------------------------------------------------
function C4_StringBuilder:new()
	local obj = C4_StringBuilder:create()

	obj.data = {}

	return obj
end

----------------------------------------------------
-- Append a value to the StringBuilder
-- @param v       value to be appended to the string
-- @return self
----------------------------------------------------
function C4_StringBuilder:Append(v)
	table.insert(self.data, v)
	return self
end

----------------------------------------------------
-- returns the string representing this string builder
-- @return string representing this string builder
----------------------------------------------------
function C4_StringBuilder:ToString()
	return table.concat(self.data)
end

----------------------------------------------------
-- Clears the internal buffer
-- @return self
----------------------------------------------------
function C4_StringBuilder:Clear()
	self.data = {}
	return self
end



------------------------------------------------------------------
------------------- DateTime Class -----------------------------------
--~ Class is used to represent a date/time object and provides functionality
--~ to convert between UTC and local times.  It also exposes functions to
--~ serailize/deserilize and pefrom DateTime Addition
--~
--~ Note:  This class gets pretty complicated when adjusting for DST times.
--~ Use the "Test UTC Time Conversion" action and verify the times are correct
--~ around the DST on/off dates
------------------------------------------------------------------

C4_DateTime = C4_Class()

-- contants used for Date Addition
C4_DateTime.PERIOD_MONTH = 1
C4_DateTime.PERIOD_WEEK = 2
C4_DateTime.PERIOD_DAY = 3
C4_DateTime.PERIOD_HOUR = 4
C4_DateTime.PERIOD_MINUTE = 5
C4_DateTime.PERIOD_SECOND = 6
C4_DateTime.PERIOD_YEAR = 7

-- static logger class the main driver should set
C4_DateTime.Logger = nil

----------------------------------------------------
-- Constructor takes an optional string and boolean parameter.
-- If the strings is not nil then it is used to populate the DateTime.
-- Otherwise the DateTime is initialized to Now.
-- Inputs:
--       tStr -  DateTime string in the format "YYYY-mm-ddTHH:MM:SS"
--       isUtc - if true, then the passed in string is in UTC time
---------------------------------------------------
function C4_DateTime:new(tStr,isUtc)
	local obj = C4_DateTime:create()

	if (tStr) then
		obj:FromString(tStr,isUtc)
	else
		obj.value = os.time()  -- value stored in local time
	end
	return obj
end

----------------------------------------------------
-- Function for getting the time offset between local and Utc
-- time in sections:
--
-- NOTE: Do not cache this value as it will change when DST kick on/off
--
-- Returns:
--       secs - number of seconds offset between local and utc time
---------------------------------------------------
function C4_DateTime:GetUtcOffsetSecs()
	local now = os.time()

	-- this function appears to not account for DST
	-- for PST, os.difftime(now, os.time(os.date("!*t", now))) always returns -8 hrs
	local diff = os.difftime(now, os.time(os.date("!*t", now)))
	local val = self.value
	diff = diff + self:GetDstAdjust(val)

	return  diff
end

----------------------------------------------------
-- Function to return adjustment for DST time.  The os.time(os.date("!*t", secs))
-- does conversion based on the current UTC offiset.  This function
-- checks the isdst field of the passed in val (or the self.value)
-- and adjust the utc offset if it is set
--
-- Note: for PST, os.difftime(now, os.time(os.date("!*t", now))) always returns -8 hrs regardless of DST
--
-- Returns:
--       secs - number of seconds to adjust the UtcOffset by
---------------------------------------------------
function C4_DateTime:GetDstAdjust(value)

	value = value or self.value
	local wasdst = os.date("*t", value).isdst

	local adjust = wasdst and 3600 or 0
	return adjust

end

----------------------------------------------------
-- This function return the DataTime as the number of seconds from the epoch
-- Inputs:
--       utc -  if true then the returned secs will be in UTC time
-- Returns:
--       secs - number of seconds from the epoc
---------------------------------------------------
function C4_DateTime:GetDateTime(utc)
	local secs = self.value
	if (utc) then
		-- local to utc
		secs = secs - self:GetUtcOffsetSecs()
	end
	return secs
end

----------------------------------------------------
-- This function returns the DataTime as a table
-- Inputs:
--       utc -  if true then the returned table will be in UTC time
-- Returns:
--       table - lua tabel containing date
---------------------------------------------------
function C4_DateTime:GetDateTimeTable(utc)
	return os.date("*t", self:GetDateTime(utc))
end

----------------------------------------------------
-- This function returns the DataTime as a string in the format "YYYY-mm-ddTHH:MM:SS"
-- or "YYYY-mm-dd"
-- Inputs:
--       utc -  if true then the returned string will be in UTC time
--       dateOnly -  if true then the string will only contain the date portion
-- Returns:
--       string - string representing the DateTime
---------------------------------------------------
function C4_DateTime:ToString(utc, dateOnly)
	local prefix = utc and "!" or ""

	local format = dateOnly and prefix.."%Y-%m-%d" or prefix.."%Y-%m-%dT%H:%M:%S"
	return os.date(format, self:GetDateTime())
end

----------------------------------------------------
-- This function populates the DataTime from a string.  The passed in
-- string must be in the format "YYYY-mm-ddTHH:MM:SS"
--
-- Inputs:
--       tStr -  DateTime string in one of the following formats
--            "YYYY-mm-ddTHH:MM:SS"
--            "YYYY-mm-ddTHH:MM:SSZ" -- UTC time zone indicator
--            "YYYY-mm-ddTHH:MM"     -- No Seconds
--            "YYYY-mm-ddTHH:MMZ"    -- No Seconds with UTC time zone indicator
--       isUtc - if true, then the passed in string is in UTC time
---------------------------------------------------
function C4_DateTime:FromString(tStr,isUtc)
	local _,_,yr,mth,d,hr,m,s,tz = tStr:find("(%d*)%-(%d*)%-(%d*)T(%d*):(%d*):?(%d*)(%a*)")

	if (tz == 'Z') then
		isUtc = true
	end

	if (not (yr and mth and d and hr and m and s)) then
		if (C4_DateTime.Logger ~= nil) then
			C4_DateTime.Logger:Error("Invalid date:"..tStr..".  Date should be in the following format: 2010-01-01T00:00:00")
		end
	end

	self:FromTable({year=yr,month=mth,day=d,hour=hr,min=m,sec=s}, isUtc)
	return self
end
----------------------------------------------------
-- This function populates the DataTime from a table.
-- Table should be compatable w/ what is returned from os.date("*t")
--
-- Inputs:
--       tbl -  table containing date/time
--       isUtc - if true, then the passed in tbl is in UTC time
---------------------------------------------------
function C4_DateTime:FromTable(tbl,isUtc)
	local secs = os.time(tbl)
	self:FromSeconds(secs, isUtc)
	return self
end

----------------------------------------------------
-- This function populates the DataTime from a number of seconds
--
-- Inputs:
--       secs - number of seconds from the epoc
--       isUtc - if true, then the passed in secs is in UTC time
---------------------------------------------------
function C4_DateTime:FromSeconds(secs,isUtc)
	self.value = secs
	if (isUtc) then
		-- utc to local
		secs = secs + self:GetUtcOffsetSecs()
	end
	self.value = secs

	return self
end

----------------------------------------------------
-- This function adds the specified interval to the date time
--
-- Inputs:
--       val -  value to be added to the DateTime
--       period - PERIOD cost that specifies which part of the DateTime
--               should be added to (Month, Weeek, Day, etc)
---------------------------------------------------
function C4_DateTime:AddToDate(val, period)
	local dt = os.date("*t",self.value)

	if (period == C4_DateTime.PERIOD_MONTH) then
		dt.month = dt.month + val
	elseif (period == C4_DateTime.PERIOD_WEEK) then
		dt.day = dt.day + (7*val)
	elseif (period == C4_DateTime.PERIOD_DAY) then
		dt.day = dt.day + val
	elseif (period == C4_DateTime.PERIOD_HOUR) then
		dt.hour = dt.hour + val
	elseif (period == C4_DateTime.PERIOD_MINUTE) then
		dt.min = dt.min + val
	elseif (period == C4_DateTime.PERIOD_SECOND) then
		dt.sec = dt.sec + val
	elseif (period == C4_DateTime.PERIOD_YEAR) then
		dt.year = dt.year + val
	end

	-- account for the crossing the DST bounrdy
	local wasdst = dt.isdst
	self.value = os.time(dt)
	local isdst = os.date("*t", self.value).isdst

	local adjust = 0
	if (isdst ~= wasdst) and ((period ~= C4_DateTime.PERIOD_HOUR) and
									(period ~= C4_DateTime.PERIOD_MINUTE) and
									(period ~= C4_DateTime.PERIOD_SECOND)) then
--	if (isdst ~= wasdst) then
--print(	isdst, wasdst)
		adjust = isdst and -3600 or 3600
	end
	self.value = self.value + adjust

	return self

end

----------------------------------------------------
-- Function to round date down to nearest PERIOD
--
-- Inputs:
--       period -  PERIOD to round date down to
--       utc - if true rounding will occur on the date in utc time
---------------------------------------------------
function C4_DateTime:FloorToPeriod(period, utc)
	local dt = self:GetDateTimeTable(utc)

	if (period == C4_DateTime.PERIOD_YEAR) then
		dt.month = 1
		dt.day = 1
		dt.hour = 0
		dt.min= 0
		dt.sec = 0
	elseif (period == C4_DateTime.PERIOD_MONTH) then
		dt.day = 1
		dt.hour = 0
		dt.min= 0
		dt.sec = 0
	elseif (period == C4_DateTime.PERIOD_DAY) then
		dt.hour = 0
		dt.min= 0
		dt.sec = 0
	elseif (period == C4_DateTime.PERIOD_HOUR) then
		dt.min= 0
		dt.sec = 0
	elseif (period == C4_DateTime.PERIOD_MINUTE) then
		dt.sec = 0
	else
		if (C4_DateTime.Logger ~= nil) then
			C4_DateTime.Logger:Error("C4_DateTime:FloorToPeriod:  Period "..period.." is not supported")
		end
		return
	end

	self:FromTable(dt, utc)

	return self
end



----------------------------------------------------------
--------------------- Logger Class Def  ------------------
----------------------------------------------------------

C4_Logger = C4_Class()

C4_Logger.OFF   = 0x00
C4_Logger.FATAL = 0x01
C4_Logger.ERROR = 0x02
C4_Logger.WARN  = 0x03
C4_Logger.PROFILE  = 0x04
C4_Logger.INFO  = 0x05
C4_Logger.DEBUG = 0x06

C4_Logger.LevelMap = {
	['Off']   = C4_Logger.OFF,
	['Fatal'] = C4_Logger.FATAL,
	['Error'] = C4_Logger.ERROR,
	['Warn']  = C4_Logger.WARN,
	['Profile']  = C4_Logger.PROFILE,
	['Info']  = C4_Logger.INFO,
	['Debug'] = C4_Logger.DEBUG,
}


function C4_Logger:new(timerCallback, timerDuration, reportDirectory)
	local obj = C4_Logger:create()

	obj.Level = C4_Logger.ERROR

	obj.DebugReport = false
	obj.DebugPrint = false
	obj.DebugLog = false

	obj.ReportDirectory = reportDirectory
	obj.DebugTimerDuration = timerDuration or 15
	obj.DebugTimer = C4_Timer:new(obj.DebugTimerDuration, "MINUTES", function() obj.StopDebugTimer(obj) end, false, 'DebugTimer', obj)

	obj.timerCallback = timerCallback

	return obj
end

function C4_Logger:SetLevel(level)
	self.Level = level
	self:RestartDebugTimer()
end

function C4_Logger:SetOutput(outputPrint, outputLog, outputReport)
	self.DebugReport = outputReport
	self.DebugPrint = outputPrint
	self.DebugLog = outputLog
end

function C4_Logger:SetDebugTimerDuration(timerDuration)
	self.DebugTimerDuration = timerDuration or 15
	self:RestartDebugTimer()
end

function C4_Logger:RestartDebugTimer()
	if (self.Level > C4_Logger.ERROR) then
		self.DebugTimer:Start(self.DebugTimerDuration)
	end
end

function C4_Logger:StopDebugTimer()
	if (self.timerCallback) then
		self.timerCallback()
	end
end

function C4_Logger:Fatal(message)
	self:Log("[FATAL]: "..message, C4_Logger.FATAL)
end

function C4_Logger:Error(message)
	self:Log("[ERROR]: "..message, C4_Logger.ERROR)
end

function C4_Logger:Warn(message)
	self:Log("[WARN]: "..message, C4_Logger.WARN)
end

function C4_Logger:Info(message)
	self:Log("[INFO]: "..message, C4_Logger.INFO)
end

function C4_Logger:Profile(message)
	self:Log("[PROFILE]: "..message, C4_Logger.PROFILE)
end

function C4_Logger:Debug(message)
	self:Log("[DEBUG]: "..message, C4_Logger.DEBUG)
end

function C4_Logger:Log(message, level)
	if (self == C4_Logger) then
		error("INVALID STATIC CALL")
	end

	if (self.Level >= level) then
		self:Write(message)
	end
end

function C4_Logger:Write(text, alwaysWrite)
	if (self == C4_Logger) then
		error("INVALID STATIC CALL")
	end

	local temp = string.gsub(text, "%%", "?")
	if(self.DebugReport or alwaysWrite) then
		if (self.ReportDirectory) then
			C4:FileSetDir(self.ReportDirectory)
			local dateTimeNow = C4_DateTime:new()
			
			local todayFile = string.format( "%s_%s", C4_DateTime:new():ToString(nil, true), "debug.log" )
			local handle = C4:FileOpen(todayFile)
			if(C4:FileIsValid(handle)) then
				local deviceId = C4:GetDeviceID()
				local deviceName = C4:ListGetDeviceName(deviceId)
				local entry = string.format( "%s - %s (%s) - %s\n", dateTimeNow:ToString(), deviceName, deviceId, temp )
				C4:FileWrite(handle, string.len(entry), entry)
				C4:FileClose(handle)
			end
		end
	end
	if(self.DebugPrint or alwaysWrite) then C4_Logger_Helper:Print(temp) end
	if(self.DebugLog or alwaysWrite) then C4:ErrorLog(temp) end

end

function C4_Logger:IsDebugEnabled()
	return (self.Level == C4_Logger.DEBUG)
end

function C4_Logger:IsWarnEnabled()
	return (self.Level >= C4_Logger.WARN)
end

function C4_Logger:IsProfileEnabled()
	return (self.Level >= C4_Logger.WARN)
end


function C4_Logger:DebugStringToHex(value)
	if (type(value) == 'number') then
		local padding = 2
		if (0xFF < value and value <= 0xFFFF) then
			padding = 4
		elseif (0xFFFF < value and value <= 0xFFFFFFFF) then
			padding = 8
		end
		return '0x' .. string.format('%0'..padding..'X', value)
	end

	return value
end

function C4_Logger:DumpValue(value, showHex)
	local result = ''
	if (value == nil) then
		result = 'nil'
	elseif (type(value) == 'table') then
		result = self:DumpTable(value, showHex)
	elseif (type(value) == 'function') then
		result = tostring(value)
	elseif (type(value) == 'number') then
		result = showHex and self:DebugStringToHex(value) or tostring(value)
	elseif (type(value) == 'boolean') then
		if (value) then
			result = 'true'
		else
			result = 'false' end
	elseif (type(value) == 'string') then
		-- Print both HEX and String representations

		if (showHex) then
			for i=1,string.len(value) do
				result = result .. string.format("%02X ", string.byte(value,i))
			end
			-- Replace carrage return and new line characters with hex value.
			value = string.gsub(value, "\n", "\0A")
			value = string.gsub(value, "\r", "\0D")
			result = result .. " -- "
		end
		result = result .. string.format("%q", value)
	end
	return result
end

function C4_Logger:DumpTable(table, showHex, depth, redundantTable)
	local result = C4_StringBuilder:new()
	redundantTable = redundantTable or {}
	depth = depth or 0
	local unindent = ''
	for i = 1, depth do
		unindent = unindent .. '\t'
	end
	local indent = unindent .. '\t'

	local size = 0
	if redundantTable[table] then
		result:Append( tostring(table) )
		size = -1
	else
		redundantTable[table] = true
		result:Append( "{\n" )
		for key, value in pairs(table) do
			if size > 0 then
				result:Append( ",\n" )
			end
			if (type(table[key]) == 'table') then
				value = self:DumpTable( table[key], showHex, depth+1, redundantTable)
			else
				value = self:DumpValue( value, showHex )
			end
			local keyType = type(key)
			key = 	keyType == "string" and string.format( "\"%s\"", key )
					or keyType == "number" and key
					or tostring(key)
			result:Append( string.format( "%s[%s] = %s", indent, key, value ) )
			size = size + 1
		end
		result:Append( string.format( "\n%s}", unindent ) )
	end

	local strResult = size == 0 and "{}" or result:ToString()
	return strResult
end

