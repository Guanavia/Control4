function CMD.SET_VACATION_MODE(tParams)
	local VacModeStr = tParams["MODE"]

	-- Turn off current hold mode when trying to turn on vacation hold
	if VacModeStr == "On" then 
		CMD.SET_MODE_HOLD( {MODE = "Off"} )
	end

	SetVacationMode(VacModeStr == "On" and gVacStatusOn or gVacStatusOff)
 	SendData(FormMibPacket(gC4MIBInvoke, gMIBVacationMode , gCurTStatState.vacationMode.MIBVal))
end

