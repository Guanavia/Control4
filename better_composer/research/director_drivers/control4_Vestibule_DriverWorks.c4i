	-- program mode 
	gBoardID = {}
	gProgramMode = 0
	gProgramPacketCount = 0
	gProgramPackets = {}
	gProgramTable = {}
	gBlock = 0

	-- program mode state machine
	gState = ""
	SendStartCode = "Sending Start Code"
	SendCheckSum = "Sending Check Sum"
	SendProgramData = "Sending Program Data"
	SendTransferCode = "Sending Transfer Code"
	SendStopCode = "Sending Stop Code"
	SendGetProgramVersion = "Sending Get Program Version"
	ProgramModeComplete = "Completing Program Mode"

	-- debug	
	gDebugPrint = false
	gDebugLog = false

	gZigbeeBinding = 6001
	gZigbeeOnline = false

	-- set gSequenceNumber (Zigbee Packet Sequence) to 1 after a reconnect and on startup...
	gSequenceNumber = 1
	gDoNotDisturbName = "Do Not Disturb"
	gHousekeepingName = "Housekeeping"
	gMasterName= "Master"
	gDoorbellName = "Doorbell"
	gDoorbellPropName = "Vestibule Station Doorbell"
	gDoorbellRingName = "Doorbell Ring"

	gfalse = "false"
	gtrue = "true"
	gBool_Attribute = 16

	-- Axxess server support

	gBootLoaderStatus = "Boot Loader Status"
	gAxxessServerSynchronized = "Axxess Server Synchronized"

	gServerBinding = 6060
	gIsAxxessServerConnected = false
	gAxxessServerConnectionName = "Axxess Server Connection"
	gAxxessServerAddressName = "Axxess Server Address"
	gAxxessServerPortName = "Axxess Server Port"

	C4:AddVariable(gDoNotDisturbName, "", "BOOL")
	C4:AddVariable(gHousekeepingName, "", "BOOL")
	C4:AddVariable(gMasterName, "", "BOOL")
	
	gVersionName = "Version"
	C4:UpdateProperty(gVersionName, Version())
	FirePropertyChanged()

	if gIsAxxessServerConnected then

		local port = Properties[gAxxessServerPortName]
		local address = Properties[gAxxessServerAddressName]
		C4:CreateNetworkConnection(gServerBinding, address, port)
		C4:NetConnect(gServerBinding, port, "UDP")
	end

	--CreateAxxessServer()
	--ConnectAxxessServer()

	gServerAxxessSync = false
	tmrAxxessServerSync = C4:AddTimer(1,"MINUTES",true)

----------------- End Init --------------------

