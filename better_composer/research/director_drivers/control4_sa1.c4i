                <control name="Enable" type="toggle">
                    <commands> 
                        <command name="SET_AUDIO_OUT_TONECONTROL-enable" when="true">
                            <params>
                                <param name="OUTPUT" type="integer"/>
                                <param name="BAND" type="string"/>
