    <type>c4:control4_sr250:C4-SR250</type>
    <type>c4:control4_sr250b:C4-SR250B</type>
  </search_types>
  <composer_categories>
    <category>User Interface</category>
  </composer_categories>
  <proxy>control4_sr250</proxy>
  <driver name="remote_gen">18F9571B-25EE-44d6-95E7-575257488307</driver>
  <states/>
  <connections>
    <connection>
      <id>6001</id>
      <facing>6</facing>
      <connectionname>Remote Control</connectionname>
      <type>4</type>
      <consumer>True</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>True</linelevel>
      <classes>
        <class>
          <classname>ZIGBEE</classname>
        </class>
      </classes>
    </connection>
  </connections>
  <capabilities>
    <has_display>True</has_display>
    <is_display_background_bright>False</is_display_background_bright>
    <can_be_found>True</can_be_found>
    <can_adjust_wake_on_motion>True</can_adjust_wake_on_motion>
    <button_behavior>ShowDeviceList</button_behavior>
    <can_display_volume_bar>False</can_display_volume_bar>
	<can_adjust_recharge_station_enable>True</can_adjust_recharge_station_enable>
    <!-- These number come from the firmware and need to be set per hardware platform -->
    <max_list_cache_size>8</max_list_cache_size>
    <max_list_item_length>23</max_list_item_length> <!-- number of viewable characters not including outer "s. Icon will take a character -->
    <controls_string>0e</controls_string>
    <display_lines>4</display_lines>
  </capabilities>
  <manufacturer>Control4</manufacturer>
  <creator>Control4</creator>
  <created>5/09/2005 12:30 PM</created>
