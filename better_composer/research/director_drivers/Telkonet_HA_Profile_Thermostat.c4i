SZL.Scenes = {}
function SZL.Scenes.AddScene(sceneid, groupid, tt, name, data)
  SZL.SendClusterCommand(SZL.ClusterID.Scenes, 0x00, string.pack("<Hb<Hp", groupid, sceneid, tt, name) .. data)
end

function SZL.Scenes.RemoveScene(sceneid, groupid)
