----------------------------------  Basic Cluster  ----------------------------------
SZL.Basic = {}
function SZL.Basic.GetMandatoryAttributes()
  -- Reads the Attributes that correspond to the 'defined' Basic Cluster attributes (Mandatory only)...
  SZL.ReadAttributes(SZL.ClusterID.Basic, 0x00, 0x07, 0x12)
end

function SZL.Basic.ResetToFactoryDefaults()
  SZL.SendClusterCommand(SZL.ClusterID.Basic, 0x00, "")
end

---------------------------------  Identify Cluster  ---------------------------------
SZL.Identify = {}
function SZL.Identify.GetIdentifyTime()
  SZL.ReadAttributes(SZL.ClusterID.Identify, 0x00)
end

function SZL.Identify.SetIdentifyTime(nTime)
  local ntime = tonumber(nTime)
  SZL.WriteAttributes(SZL.ClusterID.Identify, {[0x00] = {[SZL.name_to_attrtype["Unsigned 16-Bit Integer"]] = ntime}})
end

function SZL.Identify.DoIdentify(nTime)
  local ntime = tonumber(nTime)
  SZL.SendClusterCommand(SZL.ClusterID.Identify, 0x00, string.pack("<H", ntime))
end

function SZL.Identify.DoIdentifyQuery()
  SZL.SendClusterCommand(SZL.ClusterID.Identify, 0x01, "")
end


---------------------------------  Groups Cluster  ---------------------------------
SZL.Groups = {}
function SZL.Groups.AddGroup(groupID, groupName)
  groupName = groupName or ""
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x00, string.pack("<Hp", groupID, groupName))
end

function SZL.Groups.ViewGroup(groupID)
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x01, string.pack("<H", groupID))
end

function SZL.Groups.GetGroupMembership(tGroupList)
  local data = string.pack("b", #tGroupList)
  for k,v in pairs(tGroupList) do
    data = data .. string.pack("<H", v)
  end
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x02, data)
end

function SZL.Groups.RemoveGroup(groupID)
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x03, string.pack("<H", groupID))
end

function SZL.Groups.RemoveAllGroups()
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x04, "")
end

function SZL.Groups.AddGroupIfIdentifying(groupID, groupName)
  groupName = groupName or ""
  SZL.SendClusterCommand(SZL.ClusterID.Groups, 0x05, string.pack("<Hp", groupID, groupName))
end

