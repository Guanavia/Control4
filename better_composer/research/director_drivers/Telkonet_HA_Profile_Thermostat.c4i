---------------------------------  OnOff Cluster  ----------------------------------
SZL.OnOff = {}
function SZL.OnOff.Off()
  SZL.SendClusterCommand(SZL.ClusterID.OnOff, 0x00, "")
end

function SZL.OnOff.On()
  SZL.SendClusterCommand(SZL.ClusterID.OnOff, 0x01, "")
end

function SZL.OnOff.Toggle()
  SZL.SendClusterCommand(SZL.ClusterID.OnOff, 0x02, "")
end


-------------------------------  LevelControl Cluster  --------------------------------
SZL.LevelControl = {}
function SZL.LevelControl.MoveToLevel(Level, TTime, cmd)
  cmd = cmd or 0x00
  SZL.SendClusterCommand(SZL.ClusterID.LevelControl, cmd, string.pack("b<H", Level, TTime))
end


function SZL.LevelControl.Move(strMode, Rate, cmd)
  cmd = cmd or 0x01
  strMode = string.upper(strMode)
  local md

  if (strMode == "UP") then
    md = 0x00
  else if (strMode == "DOWN") then
          md = 0x01
        end
  end
  if (md == nil) then
    SZL.dbg(strMode .. " is not a valid Mode.")
    return
  end
  SZL.SendClusterCommand(SZL.ClusterID.LevelControl, cmd, string.pack("bb", md, Rate))
end


function SZL.LevelControl.Step(strMode, StepSize, TTime, cmd)
  cmd = cmd or 0x02
  strMode = string.upper(strMode)
  local md

  if (strMode == "UP") then
    md = 0x00
  else if (strMode == "DOWN") then
          md = 0x01
        end
  end
  if (md == nil) then
    SZL.dbg(strMode .. " is not a valid Mode.")
    return
  end
  SZL.SendClusterCommand(SZL.ClusterID.LevelControl, cmd, string.pack("bb<H", md, StepSize, TTime))
end


function SZL.LevelControl.Stop(cmd)
  cmd = cmd or 0x03
  SZL.SendClusterCommand(SZL.ClusterID.LevelControl, cmd, "")
end


function SZL.LevelControl.MoveToLevelWithOnOff(Level, TTime)
  SZL.LevelControl.MoveToLevel(Level, TTime, 0x04)
end


function SZL.LevelControl.MoveWithOnOff(strMode, Rate)
  SZL.LevelControl.Move(strMode, Rate, 0x05)
end


function SZL.LevelControl.StepWithOnOff(strMode, StepSize, TTime)
  SZL.LevelControl.Step(strMode, StepSize, TTime, 0x06)
end


function SZL.LevelControl.StopWithOnOff()
  SZL.LevelControl.Stop(0x07)
end

-------------------------------  Thermostat Cluster  --------------------------------
SZL.Thermostat = {}
function SZL.Thermostat.GetMandatoryAttributes()
  -- Reads the Attributes that correspond to the 'defined' Thermostat Cluster attributes (Mandatory only)...
  SZL.ReadAttributes(SZL.ClusterID.Thermostat, 0x0000, 0x0011, 0x0012, 0x001b, 0x001c, 0xf01c)
end

function SZL.Thermostat.ConfigureReportingOn()
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x00] = SZL.name_to_attrtype["Signed 16-Bit Integer"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x11] = SZL.name_to_attrtype["Signed 16-Bit Integer"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x12] = SZL.name_to_attrtype["Signed 16-Bit Integer"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x1b] = SZL.name_to_attrtype["8-Bit Enumeration"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x1c] = SZL.name_to_attrtype["8-Bit Enumeration"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0x02] = SZL.name_to_attrtype["8-Bit Bitmap"]})
  SZL.ConfigureReporting(SZL.ClusterID.Thermostat, {[0xf01c] = SZL.name_to_attrtype["8-Bit Enumeration"]})
end


function SZL.Thermostat.SetpointRaiseLower(strMode, nVal)
  -- Handle negative values, turn them into two's compliment values (byte)...
  if (nVal > 127) then
    nVal = 127
  end
  if (nVal < 0) then
    nVal = (0x100 + nVal)
  end
  if (strMode == "Heat") then
    SZL.SendClusterCommand(SZL.ClusterID.Thermostat, 0x00, string.pack("bb", 0, nVal))
  end
  if (strMode == "Cool") then
    SZL.SendClusterCommand(SZL.ClusterID.Thermostat, 0x00, string.pack("bb", 1, nVal))
  end
  if (strMode == "Both") then
    SZL.SendClusterCommand(SZL.ClusterID.Thermostat, 0x00, string.pack("bb", 2, nVal))
  end
end


-------------------------------  Fan Control  --------------------------------
SZL.FanControl = {}
function SZL.FanControl.GetMandatoryAttributes()
  -- Reads the Attributes that correspond to the 'defined' Thermostat Cluster attributes (Mandatory only)...
  SZL.ReadAttributes(SZL.ClusterID.FanControl, 0x0000, 0x0001, 0xf000)
end


function SZL.FanControl.ConfigureReportingOn()
  SZL.ConfigureReporting(SZL.ClusterID.FanControl, {[0x00] = SZL.name_to_attrtype["8-Bit Enumeration"]})
  SZL.ConfigureReporting(SZL.ClusterID.FanControl, {[0x01] = SZL.name_to_attrtype["8-Bit Enumeration"]})
  SZL.ConfigureReporting(SZL.ClusterID.FanControl, {[0xf000] = SZL.name_to_attrtype["8-Bit Enumeration"]})
end



