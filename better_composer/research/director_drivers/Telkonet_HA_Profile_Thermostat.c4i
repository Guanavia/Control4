HVAC_STATE_TO_NAME = {"Cool","Cool","Cool", "Heat", "Heat", "Heat", "Cool", "Heat", "Off",}
HVAC_STATE_TO_NAME[0] = "Off"
FAN_STATE_TO_NAME = {"Low", "Medium", "High", "On", "Auto", "Smart"}
FAN_STATE_TO_NAME[0] = "Off"

HVAC_MODE_TO_NAME = {"Auto", "", "Cool", "Heat", "Emerg", "Precool", "Fan Only"}
HVAC_MODE_TO_NAME[0] = "Off"

HVAC_NAME_TO_MODE = {}
for k,v in pairs(HVAC_MODE_TO_NAME) do
  HVAC_NAME_TO_MODE[v] = k
end

FAN_MODE_TO_NAME = {"Low", "Medium", "High", "On", "Auto", "Smart"}
FAN_MODE_TO_NAME[0] = "Off"

FAN_NAME_TO_MODE = {}
for k,v in pairs(FAN_MODE_TO_NAME) do
  FAN_NAME_TO_MODE[v] = k
end



function dbgStatus(strStatus)
  dbg("-----> Status: " .. strStatus)
  C4:UpdateProperty("Last Status", strStatus)
end


function OnZigbeePacketIn(packet, idProfileID, idClusterID, idGroupID, sourceEndpoint, destinationEndpoint)
    SZL.ProcessZigbee(packet, idProfileID, idClusterID, idGroupID, sourceEndpoint, destinationEndpoint)
end


function OnZigbeePacketSuccess(packet, idProfileID, idClusterID, idGroupID, sourceEndpoint, destinationEndpoint)
  dbg("OnZigbeePacketSuccess.. Profile: " .. string.format("0x%04x", idProfileID) .. " Cluster: " .. string.format("0x%04x", idClusterID) .. " SE: " .. sourceEndpoint .. " DE: " .. destinationEndpoint)
  if (idProfileID == TSE_PROFILE and idClusterID ~= TKN_CLI_CLUSTER_ID) then
    dbg("Sending ACK response to server...")
    replyPkt = string.pack("b", 0x06)
    C4:SendToNetwork(TKN_SERVER_BINDING, SZL.TKN_ServerPort, replyPkt)
  end
end


function OnZigbeePacketFailed(packet, idProfileID, idClusterID, idGroupID, sourceEndpoint, destinationEndpoint)
  dbg("OnZigbeePacketFailed.. Profile: " .. idProfileID .. " Cluster: " .. idClusterID .. " SE: " .. sourceEndpoint .. " DE: " .. destinationEndpoint)
  if (idProfileID == TSE_PROFILE and idClusterID ~= TKN_CLI_CLUSTER_ID) then
    dbg("Sending NACK response to server...")
    replyPkt = string.pack("b", 0x15)
    replyPkt = replyPkt .. packet
    hexdump(replyPkt)
    C4:SendToNetwork(TKN_SERVER_BINDING, SZL.TKN_ServerPort, replyPkt)
  end
end


function OnNetworkBindingChanged(idBinding, bIsBound)

	local isbound = "false"
	if (bIsBound) then
		isbound = "true"
	end

  dbg("OnNetworkBindingChanged: Binding = " .. idBinding .. "; Bound = " .. isbound)

  if (idBinding == 6001) then
    gZigbeeBound = bIsBound
    dbg("ZigBee binding 6001")
    if (bIsBound) then
      if (gConfigureReportingTimer) then gConfigureReportingTimer = C4:KillTimer(gConfigureReportingTimer) end
      gConfigureReportingTimer = C4:AddTimer(45, "SECONDS")
    end
  end
end


function OnZigbeeOnlineStatusChanged(strStatus, strVersion, strSKU)
	dbg("OnZigbeeOnlineStatusChanged: Status = " .. strStatus .. " Version = " .. strVersion .. " SKU = " .. strSKU)
	gZigbeeOnline = (strStatus == "ONLINE")
        if (strStatus == "ONLINE") then
          --Thermostat is back on line, read the properties
          GetProperties()
        end
     SZL.ResetSequenceNumber()
end


function OnDriverDestroyed()
  SZL.OnDriverDestroyed()
  if (gDbgTimer) then gDbgTimer = C4:KillTimer(gDbgTimer) end
  if (gConfigureReportingTimer) then gConfigureReportingTimer = C4:KillTimer(gConfigureReportingTimer) end
  if (gPollTimer) then gPollTimer = C4:KillTimer(gPollTimer) end
end

SCALEVAL = {}
SCALEVAL["CELSIUS"] = "C"
SCALEVAL["FAHRENHEIT"] = "F"


TIMERLOOKUP = {}
TIMERLOOKUP ["30 Seconds"] = 30
TIMERLOOKUP ["1 Minute"] = 60
TIMERLOOKUP ["5 Minutes"] = 60 * 5
TIMERLOOKUP ["15 Minutes"] = 60 * 15
TIMERLOOKUP ["30 Minutes"] = 60 * 30


function OnPropertyChanged(strProperty)
  local prop = Properties[strProperty]
  dbg("OnPropertyChanged: " .. strProperty .. " Prop: " .. prop)

  if (strProperty == "Debug Mode") then
    if (gDbgTimer > 0) then gDbgTimer = C4:KillTimer(gDbgTimer) end
    gDbgPrint, gDbgLog = (prop:find("Print") ~= nil), (prop:find("Log") ~= nil)
    if (prop == "Off") then
      return
    end
    gDbgTimer = C4:AddTimer(240, "MINUTES")
    return
  end

  if (strProperty == "Basic Cluster Endpoint") then
    SZL.Endpoints = SZL.Endpoints or {}
    SZL.Endpoints[SZL.ClusterID.Basic] = tonumber(prop)
  end
  if (strProperty == "Identify Cluster Endpoint") then
    SZL.Endpoints = SZL.Endpoints or {}
    SZL.Endpoints[SZL.ClusterID.Identify] = tonumber(prop)
  end
  if (strProperty == "Thermostat Cluster Endpoint") then
    SZL.Endpoints = SZL.Endpoints or {}
    SZL.Endpoints[SZL.ClusterID.Thermostat] = tonumber(prop)
  end
  if (strProperty == "FanControl Cluster Endpoint") then
    SZL.Endpoints = SZL.Endpoints or {}
    SZL.Endpoints[SZL.ClusterID.FanControl] = tonumber(prop)
  end

  if (strProperty == "Keepalive Poll") then
    gPollTimer = gPollTimer or 0
    if (gPollTimer > 0) then
      gPollTimer = C4:KillTimer(gPollTimer)
    end
    if (prop ~= "Polling Off") then
      gPollTimer = C4:AddTimer(TIMERLOOKUP[prop], "SECONDS", true)
    end
  end

  if (strProperty == "Telkonet Server") then
  	SZL.TKN_ServerName = Properties["Telkonet Server"]
  end

  if (strProperty == "Telkonet Server Port") then
  	SZL.TKN_ServerPort = Properties["Telkonet Server Port"]
  end

  if (strProperty == "Telkonet Server Status") then
  dbg("-----Telkonet Server Status")
  end

  -- Save Properties that have changed...
  C4:InvalidateState()
end


function dbg(strDebugText)
  if (gDbgPrint) then print(strDebugText) end
  if (gDbgLog) then C4:ErrorLog(strDebugText) end
end


function OnTimerExpired(idTimer)
  if (SZL.OnTimerExpired(idTimer)) then
    return
  end

  if (idTimer == gConfigureReportingTimer) then
    gConfigureReportingTimer = C4:KillTimer(gConfigureReportingTimer)
    SZL.Thermostat.ConfigureReportingOn()
    SZL.FanControl.ConfigureReportingOn()
  end

  if (idTimer == gPollTimer) then
    dbg("Polling...")
    SZL.ReadAttributes(SZL.ClusterID.Thermostat, 0x0000)
    return
  end

  if (idTimer == gDbgTimer) then
    dbg("Turning Debug Mode Off (timer expired)")
    C4:UpdateProperty("Debug Mode", "Off")
    OnPropertyChanged("Debug Mode")
    gDbgTimer = C4:KillTimer(gDbgTimer)
  end
if (idTimer == startup_timer) then
    GetProperties()
end

  C4:KillTimer(idTimer)
end

-- Telkonet Thermostat attribute IDs
PROFILE_ATT_ID = 0xf0
DOOR_EVENT_ATT_ID = 0xf1

--------------- Actions ----------------------------
ACTION = {}

function ACTION.ACT_SET_PROFILE_UNSOLD()
  dbg("Write attr, set profile 3 (unsold)");
  SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[PROFILE_ATT_ID] = {[0x20] = 3}})
end

function ACTION.ACT_SET_PROFILE_SOLD()
  dbg("Write attr, set profile 1 (sold)");
  SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[PROFILE_ATT_ID] = {[0x20] = 1}})
end

function ACTION.ACT_REPORT_DOOR_EVENT()
  SZL.ReportAttributes(SZL.ClusterID.Thermostat, {[DOOR_EVENT_ATT_ID] = {[0x20] = 1}})
end

function ACTION.ACT_READ_OCCUPANCY()
  SZL.ReadAttributes(SZL.ClusterID.Thermostat, 0x02)
end

function ACTION.GET_PROPERTIES()
  GetProperties()
end

function ExecuteCommand(strCommand, tParams)
  if (strCommand == "LUA_ACTION") then
    if tParams ~= nil then
      for cmd,cmdv in pairs(tParams) do
  	print (cmd,cmdv)
  	if cmd == "ACTION" then
  	  if ACTION[cmdv] ~= nil then
  	  	ACTION[cmdv]()
  	  else
  	  	Debug("From ExecuteCommand Function - Undefined Action")
  	  	Debug("Key: " .. cmd .. "  Value: " .. cmdv)
  	  end
  	else
  	  Debug("From ExecuteCommand Function - Undefined Command")
  	  Debug("Key: " .. cmd .. "  Value: " .. cmdv)
  	end
      end
    end
  else
    --Command is from Programmed event
    dbg("__ExecuteCommand: " .. strCommand)
    if (nil ~= tParams) then for k,v in pairs(tParams) do dbg(k .. ": " .. v) end end
    if (strCommand == "Set Room Sold Profile") then
      ACTION.ACT_SET_PROFILE_SOLD()
      return
    end

    if (strCommand == "Set Room Unsold Profile") then
      ACTION.ACT_SET_PROFILE_UNSOLD()
      return
    end

    if (strCommand == "Report Door Event") then
      ACTION.ACT_REPORT_DOOR_EVENT()
      return
    end

  end
end

function ReceivedFromProxy(idBinding, strCommand, tParams)
  dbg("ReceivedFromProxy[" .. idBinding .. "]: " .. strCommand)
  if (nil ~= tParams) then for k,v in pairs(tParams) do dbg(k .. ": " .. v) end end

  if (PersistData.Scale == nil) then
    PersistData.Scale = "F"
  end

  if (strCommand == "CURRENT_SETTINGS") then
    GetProperties()
  end

  if (strCommand == "QUERY_CURRENT_SETTINGS") then
    GetProperties()
  end

  if (strCommand == "QUERY_THERMOSTAT_INFO") then
    GetProperties()
  end

  if (strCommand == "GET_CONNECTED_STATE") then
    C4:SendToProxy(5001, "ONLINE_CHANGED", "True")
  end

  -- Zigbee Cluster-specific attribute 1 == HVAC MODE...
  if (strCommand == "SET_MODE_HVAC") then
    -- Send Attribute for proper mode...
    local mode = tParams["MODE"]
    SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[0x1c] = {[0x30] = HVAC_NAME_TO_MODE[mode]}})
    dbg("MODE CHANGE")
  end

  -- Zigbee Cluster-specific attribute 2 == Heat Setpoint...
  if (strCommand == "SET_SETPOINT_HEAT") then
    local setpoint = tParams["SETPOINT"]
    if (PersistData.Scale == "F") then
      SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[0x12] = {[0x29] = round(FtoC(setpoint) * 100)}})
    else
      SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[0x12] = {[0x29] = round(setpoint * 100)}})
    end
  end

  if (strCommand == "SET_SETPOINT_COOL") then
    local setpoint = tParams["SETPOINT"]
    if (PersistData.Scale == "F") then
	dbg("Setpoint F " .. setpoint )
      SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[0x11] = {[0x29] = round(FtoC(setpoint) * 100)}})
    else
      SZL.WriteAttributes(SZL.ClusterID.Thermostat, {[0x11] = {[0x29] = round(setpoint * 100)}})
	dbg("Setpoint C " .. setpoint )
    end
  end

  if (strCommand == "SET_SCALE") then
    PersistData.Scale = tParams["SCALE"] or ""
     if (PersistData.Scale == "") then return end
     PersistData.Scale = SCALEVAL[PersistData.Scale] or "F"
    if (PersistData.Scale == "F") then
    	SZL.WriteAttributes(SZL.ClusterID.ThermostatUIConfiguration, {[0x0] = {[0x30] = 1}})
    	dbg("fSet_Scale " .. tParams["SCALE"] )
    else
    	SZL.WriteAttributes(SZL.ClusterID.ThermostatUIConfiguration, {[0x0] = {[0x30] = 0}})
	dbg("cSet_Scale " .. tParams["SCALE"] )
    end
    C4:InvalidateState()
    C4:SendToProxy(5001, "SCALE_CHANGED", {SCALE = tParams["SCALE"]})
    GetProperties()
  end

  if (strCommand == "SET_MODE_FAN") then
    -- Send Attribute for proper mode...
    local mode = tParams["MODE"]
    SZL.WriteAttributes(SZL.ClusterID.FanControl, {[0x00] = {[0x30] = FAN_NAME_TO_MODE[mode]}})
  end
end


function HandleAttributes(ClusterID, att)
  local clustername = SZL.Cluster[ClusterID] or "Unknown Cluster"
  dbg("HandleAttributes... ClusterID: " .. clustername)

  -- Handle temperature and setpoint change from ZNIC...
  if (clustername == "Thermostat") then
    if (att[0] ~= nil) then  -- Temperature
      -- Set to C/F, send to Proxy...
      local tempC = att[0].value / 100
      C4:SendToProxy(5001, "TEMPERATURE_CHANGED", {TEMPERATURE = round(CtoF(tempC)), SCALE = "F"})
    end

    if (att[0x12] ~= nil) then  -- Heat Setpoint (Occupied)
      -- Set to C/F, send to Proxy...
      local SP = att[0x12].value / 100
      C4:SendToProxy(5001, "HEAT_SETPOINT_CHANGED", {SETPOINT = round(CtoF(SP)), SCALE = "F"})
    end

    if (att[0x11] ~= nil) then  -- Cool Setpoint (Occupied)
      -- Set to C/F, send to Proxy...
      local SP = att[0x11].value / 100
      --if (PersistData.Scale == "C") then
	C4:SendToProxy(5001, "COOL_SETPOINT_CHANGED", {SETPOINT = round(CtoF(SP)), SCALE = "F"})
	dbg("Send to Proxy -C");
      --else
      --	C4:SendToProxy(5001, "COOL_SETPOINT_CHANGED", {SETPOINT 77}, {SCALE F})
      --	dbg("Send to Proxy -F Setpoint " .. round(CtoF(SP)));
      -- end
    end

    --OFF / AUTO / COOL / HEAT / EMERG / PRECOOL / FAN ONLY  (0-3)
    -- TODOs:  Things I could to do improve this driver:
    -- Set the possible dropdowns on Navigator programmatically according to the ControlSequenceOfOperation Values?
        -- How: send notify: SYSTEMMODES_CHANGED (MODES = "Off,Heat,Cool,Auto")
    -- Set the possible dropdowns for Fan on Navigator
        -- How: send notify: FANMODES_CHANGED (COUNT = 0-3 (0 == "Auto", 1 = "Auto,On", 2 = "Auto,Low,High", 3 = "Auto,Low,Medium,High")
    -- Send OUTDOOR_TEMPERATURE_CHANGED (TEMPERATURE) notify when outdoor temp changes

    if (att[0x1c] ~= nil) then  -- System Mode
      C4:SendToProxy(5001, "HVAC_MODE_CHANGED", {MODE = HVAC_MODE_TO_NAME[att[0x1c].value]})
    end
    if (att[0xf01c] ~= nil) then  -- System State
     dbg("HVAC state change: " ..  att[0xf01c].value)
     C4:SendToProxy(5001, "HVAC_STATE_CHANGED", {STATE = HVAC_STATE_TO_NAME[att[0xf01c].value]})
    end
    if (att[0x02] ~= nil) then  -- Occupancy
      if (att[0x02].value == 0) then
	dbg(os.date("%D %H:%M:%S") .. " Room Unoccupied")
	C4:FireEvent("Room Unoccupied")
      else
        dbg(os.date("%D %H:%M:%S") .. " Room Occupied")
	C4:FireEvent("Room Occupied")
      end
    end
  end


  if (clustername == "FanControl") then
    if (att[0x00] ~= nil) then  -- Fan Mode
      C4:SendToProxy(5001, "FAN_MODE_CHANGED", {MODE = FAN_MODE_TO_NAME[att[0x00].value]})
    end
    if (att[0xf000] ~= nil) then  -- Fan Mode
      dbg("Fan state change: " ..  att[0xf000].value)
      C4:SendToProxy(5001, "FAN_STATE_CHANGED", {STATE = FAN_STATE_TO_NAME[att[0xf000].value]})
    end
  end
end
SZL.SetAttributeHandler(HandleAttributes)


function HandleCommands(ClusterID, cmd, data)
  dbg("Handlecommands: " .. cmd)
  hexdump(data, dbg)

end
SZL.SetCommandHandler(HandleCommands)


function FtoC(nF)
  return (nF - 32) * 5 / 9
end


function CtoF(nC)
  return (nC * 9 / 5) + 32
end


function round(num)
  return math.floor(num + 0.5)
end


function GetProperties()
  SZL.Thermostat.GetMandatoryAttributes()
  SZL.FanControl.GetMandatoryAttributes()
end


function ReceivedFromNetwork(idBinding, nPort, strData)
  -- Save up things coming back on HTTP port, process when done sending to us...
  g_ReceiveBuffer = g_ReceiveBuffer .. strData

  dbg("ReceivedFromNetwork: " .. strData)
  hexdump(strData);
   _, C4_Header = string.unpack(strData, "b", 1)
  if (C4_Header == 0xC4) then
     _, DestEndpoint = string.unpack(strData, "b", 2)
     _, ClusterID = string.unpack(strData, "<H", 3)
     _, Profile = string.unpack(strData, "<H", 5)
     _, SrcEndpoint = string.unpack(strData, "b", 7)
     _, GroupID = string.unpack(strData, "<H", 8)
    dbg("Profile: " .. Profile .. " ClusterID: " .. ClusterID .. " DE: " .. DestEndpoint .. " SE: " .. SrcEndpoint .. " Group: " .. GroupID)
    -- strip off the 9 byte header
    s2 = string.sub(strData,10,-1)
    hexdump(s2);
    C4:SendZigbeePacket(s2, Profile, ClusterID, GroupID, SrcEndpoint, DestEndpoint)
  else dbg("Ignoring packet from server - header is not 0xC4")
  end
end

function OnConnectionStatusChanged(idBinding, nPort, strStatus)
	dbg("OnConnectionStatusChanged")
  if (idBinding == TKN_SERVER_BINDING) then
    SZL.TKN_ServerStatus = strStatus

    if (strStatus == "ONLINE") then

      -- Connect was successful.
      dbg("TKN Server Online...")
      C4:UpdateProperty("Telkonet Server Status", "Online")

      -- If g_TransmitBuffer is not empty, send it now
      if ((g_TransmitBuffer == nil) or (g_TransmitBuffer == "")) then
        return
      end
      C4:SendToNetwork(TKN_SERVER_BINDING, SZL.TKN_ServerPort, g_TransmitBuffer)
      g_TransmitBuffer = ""
    else

      -- OFFLINE... This means the receive buffer is full and ready to process...
      dbg("Disconnected from TKN Server ...")
      dbg("Received: " .. g_ReceiveBuffer)

      C4:UpdateProperty("Telkonet Server Status", "Offline")

      -- Check for error in receiving data...
      if (nil == g_ReceiveBuffer) or (nil ~= g_ReceiveBuffer:find("Access Denied"))
                                              or (nil ~= g_ReceiveBuffer:find("Invalid Hostname")) then
        ErrorOut("Error Accessing Data.")
        ErrorOut(g_ReceiveBuffer)
        return
      end

      g_Receivebuffer = ""
    end
  end
end


----------------------- INIT START -------------------------
PersistData = PersistData or {}
startup_timer = C4:AddTimer(20, "SECONDS")
SZL.ResetSequenceNumber()

HA_PROFILE = 0x104
TSE_PROFILE = 0x0f04
TKN_CLI_CLUSTER_ID = 0x00a0

SZL.Initialize(HA_PROFILE, {
                               SZL.ClusterID.Basic,
                               SZL.ClusterID.Identify,
                               SZL.ClusterID.Thermostat,
                               SZL.ClusterID.FanControl,
			       SZL.ClusterID.ThermostatUIConfiguration
                                }, 1, 1, 1)

SZL.SetAttributeHandler(HandleAttributes)
SZL.SetCommandHandler(HandleCommands)
SZL.SetDbgHandler(dbg)
SZL.SetSendMode(false, 15, 1)  -- Don't use Queue, wait for 15 seconds, 1 retry

gZigbeeBound = false
gDbgTimer = 0

gDbgPrint, gDbgLog = false, false

-- Fire On Property Changed to set Property global sets, they'll change if Property is changed.
OnPropertyChanged("Debug Mode")
OnPropertyChanged("Basic Cluster Endpoint")
OnPropertyChanged("Identify Cluster Endpoint")
OnPropertyChanged("Thermostat Cluster Endpoint")
OnPropertyChanged("FanControl Cluster Endpoint")
OnPropertyChanged("Keepalive Poll")

-- PersistData.Scale = PersistData.Scale or "F"
PersistData.Scale = "F"

