  tellDeviceToUpgrade()
end

--------------------------------------------------------------------------------------------------------
-- Commands and Properties and Variables
--------------------------------------------------------------------------------------------------------

function ExecuteCommand(Command, tParams)
  if(gLogVerbose) then
    dbg('Execute Command: ' .. Command)
    if(tParams ~= nil) then
      for name,value in pairs(tParams) do
	dbg("Param (" .. name .. ") :: Value (" .. value .. ")")
      end
    end
  end

  if (PROXY_CMDS[Command] ~= nil) and (type(PROXY_CMDS[Command])=='function') then
    PROXY_CMDS[Command] (tParams, Command)
  elseif (PROXY_CMDS[Command] ~= nil) then
    --emit(PROXY_CMDS[Command] , Command)
  elseif Command == 'LUA_ACTION' then
    if tParams ~= nil then
      for cmd,cmdv in pairs(tParams) do
	if cmd == 'ACTION' then
	  if ACTIONS[cmdv] then
	    ACTIONS[cmdv]()
	  else
	    err("Unknown Action (" .. cmdv .. ") with no handler.")
	  end
	else
	  err('From ExecuteCommand Function - Undefined Command Key: ' .. cmd .. '  Value: ' .. cmdv)
	end
      end
    end
  elseif Command == 'Lock Zone To HDMI Source' then
    -- in this method the zones come in 1 indexed.
    lockZone(tParams["Zone"])
  elseif Command == 'Unlock Zone From HDMI Source' then
    -- in this method the zones come in 1 indexed.
    unlockZone(tParams["Zone"])
  else
    err(Command .. ' Command not defined!')
  end
end

function OnVariableChanged(strVariable)
  gSettingPropertyFromVariableContext = true

  -- we are only currently working with audio delays with values from 0 to 255, make sure it is sanitized
  if(tonumber(Variables[strVariable]) > 255) then
    err("Variable given invalid value(" .. tostring(Variables[strVariable]) .. ").  Setting to max of 255.")
    Variables[strVariable] = 255
  end
  if(tonumber(Variables[strVariable]) < 0) then
    err("Variable given invalid value(" .. tostring(Variables[strVariable]) .. ").  Setting to min of 0.")
    Variables[strVariable] = 0
  end

  dbg("Set Variable (" .. strVariable .. ") To (" .. Variables[strVariable] .. ")")
  if    (strVariable == gAudioDelay1VariableString) then
    C4:UpdateProperty(gAudioDelay1PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay1PropertyString)
  elseif(strVariable == gAudioDelay2VariableString) then
    C4:UpdateProperty(gAudioDelay2PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay2PropertyString)
  elseif(strVariable == gAudioDelay3VariableString) then
    C4:UpdateProperty(gAudioDelay3PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay3PropertyString)
  elseif(strVariable == gAudioDelay4VariableString) then
    C4:UpdateProperty(gAudioDelay4PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay4PropertyString)
  elseif(strVariable == gAudioDelay5VariableString) then
    C4:UpdateProperty(gAudioDelay5PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay5PropertyString)
  elseif(strVariable == gAudioDelay6VariableString) then
    C4:UpdateProperty(gAudioDelay6PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay6PropertyString)
  elseif(strVariable == gAudioDelay7VariableString) then
    C4:UpdateProperty(gAudioDelay7PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay7PropertyString)
  elseif(strVariable == gAudioDelay8VariableString) then
    C4:UpdateProperty(gAudioDelay8PropertyString, Variables[strVariable])
    OnPropertyChanged(gAudioDelay8PropertyString)
  else
    err("OnVariableChanged :: Unknown strVariable: " .. strVariable)
  end
  gSettingPropertyFromVariableContext = false
end

function OnPropertyChanged(strProperty)
  dbg("Set Property (" .. strProperty .. ") To (" .. Properties[strProperty] .. ")")
  if(gPermaDebug == true) then
    if (strProperty == 'Debug Mode') then
      gDebugprint = true 
      gDebuglog = true 
      return
    end
  end
    
  if (strProperty == 'Debug Mode') then
    if (Properties[strProperty] == 'Off') then
      gDebugprint = false
      gDebuglog = false
      cancelDebugTimer()
    end
    if (Properties[strProperty] == 'Print') then
      gDebugprint = true
      gDebuglog = false
      startDebugTimer()
    end
    if (Properties[strProperty] == 'Log') then
      gDebugprint = false
      gDebuglog = true
      startDebugTimer()
    end
    if (Properties[strProperty] == 'Print and Log') then
      gDebugprint = true
      gDebuglog = true
      startDebugTimer()
    end
  elseif (strProperty == 'Prevent Source Stealing') then
    gPreventSourceStealing = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 1') then
    gPreventLockOnSource1 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 2') then
    gPreventLockOnSource2 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 3') then
    gPreventLockOnSource3 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 4') then
    gPreventLockOnSource4 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 5') then
    gPreventLockOnSource5 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 6') then
    gPreventLockOnSource6 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 7') then
    gPreventLockOnSource7 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Prevent Lock Of Source 8') then
    gPreventLockOnSource8 =  propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Always On') then
    gNeverPowerDown = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'IR 1 Direction') then
    gIR1DirectionFromSwitchToBalun = propertyIRDirectionToBoolean(Properties[strProperty])
    setIRDirection(1)
  elseif (strProperty == 'IR 2 Direction') then
    gIR2DirectionFromSwitchToBalun = propertyIRDirectionToBoolean(Properties[strProperty])
    setIRDirection(2)
  elseif (strProperty == 'IR 3 Direction') then
