function ReceivedFromProxy(idBinding, strCommand, tParams)
  if (PROXY_CMDS[strCommand] ~= nil) and (type(PROXY_CMDS[strCommand])=='function') then
    return PROXY_CMDS[strCommand] (tParams)
  else
    dbg(strCommand .. ' Command Handler not defined!')
    return nil
  end
end

