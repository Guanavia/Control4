function ACTIONS.ACTION_calibrate()
  dbg("Received ACTION Calibrate")
  SendMessageToSwitch(MESSAGES.CALIBRATE) -- send this before we set our flag, otherwise stuff gets jammed up on the currently calibrating flag
  gCurrentlyCalibrating = true
  startCalibrationStatusTimer()
end

