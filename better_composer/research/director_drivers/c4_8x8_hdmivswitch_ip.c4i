  if(gDebounceFailedSourceMappingInZone1Timer) then
    C4:KillTimer(gDebounceFailedSourceMappingInZone1Timer)
  end
  gDebounceFailedSourceMappingInZone1Timer = C4:AddTimer(gDebounceFailedSourceMappingInZoneTimerValueInMilliseconds, "MILLISECONDS")
