-- use this one if you want to debug the IS_AV_OUTPUT_TO_INPUT_VALID command
function PROXY_CMDS.IS_AV_OUTPUT_TO_INPUT_VALID_debug(params)
--     if(params ~= nil) then
--       for name,value in pairs(params) do
-- 	dbg("Param (" .. name .. ") :: Value (" .. value .. ")")
--       end
--     end
    
    local room_id           = tonumber(params["Params_idRoom"])
    local current_source_id = tonumber(params["Params_idCurrentSource"])
    local new_source_id     = tonumber(params["Params_idSource"])
    local source            = sanitizeInputValueFromProxy(tonumber(params["Consumer_idBinding"])) -- we are consuming the source, so the consumer binding is the source
    local output            = sanitzeOutputValueFromProxy(tonumber(params["Provider_idBinding"])) -- we are providing the output, to the output is the provider binding
    
    -- Room name does not work?  Why?
    --local room_name           = C4:GetDeviceDisplayName(room_id)
    local new_source_name     = C4:GetDeviceDisplayName(new_source_id)
    local current_source_name = C4:GetDeviceDisplayName(current_source_id)
    
    dbg("Received From Proxy :: IS_AV_OUTPUT_TO_INPUT_VALID :: New Source: (" .. new_source_name .. ") In room: (" .. room_id .. ").  Previous source: (" .. current_source_name .. ")")
    
    return "True"
end

-- this one have a modest performance enhancement when tons of pathing is going on
function PROXY_CMDS.IS_AV_OUTPUT_TO_INPUT_VALID(params)
    return "True"
end

function PROXY_CMDS.SET_INPUT(params)
  local source = sanitizeInputValueFromProxy(tonumber(params["INPUT"]))
  local output = sanitzeOutputValueFromProxy(tonumber(params["OUTPUT"]))
  local isAudio = (tonumber(params["OUTPUT"]) >= 4000)

  if(isAudio) then
    dbg("Received From Proxy: SET_INPUT for AUDIO:: Zone(" .. output ..  ") <==> Source(" .. source .. ")")   
  else
    dbg("Received From Proxy: SET_INPUT :: Zone(" .. output ..  ") <==> Source(" .. source .. ")") 
  end

  -- If this is audio then skip the check and just map the input ot output
  if(isAudio == false and dontNeedToSwitch(output-1, source)) then
    dbg("Don't Need To Switch.  Zone(" .. output ..  ") Already Mapped To Source(" .. source .. ")")
  else
    if(isAudio) then
      mapSourceToOutputAudio(source, output)
    else
      mapSourceToOutput(source, output)
    end
  end
  return nil
end

function PROXY_CMDS.DISCONNECT_OUTPUT(params)
  local output = sanitzeOutputValueFromProxy(tonumber(params["OUTPUT"]))
  local isAudio = (tonumber(params["OUTPUT"]) >= 4000)

  if(isAudio) then
    dbg("Received From Proxy: DISCONNECT_OUTPUT for AUDIO:: Zone(" .. output ..  ")")   
  else
    dbg("Received From Proxy: DISCONNECT_OUTPUT :: Zone(" .. output ..  ")") 
  end

  if(Properties[gLeaveSourcesConnectedPropertyString] == "true") then
    dbg("Property Set To Leave Sources Connected To Zone.  Not Disconnecting.")
  else
    if(isAudio) then
      disconnectOutputAudio(output)
    else
      disconnectOutput(output)
    end
  end
  
  return nil
end

--------------------------------------------------------------------------------------------------------
-- All network connection stuff
--------------------------------------------------------------------------------------------------------

function OnConnectionStatusChanged(idBinding, nPort, strStatus)
  dbg("Connection Status Changed.  Binding(" .. idBinding .. ")  Port(" .. nPort .. ")  Status(" .. strStatus .. ")")
  if (idBinding == 6001) then
    if (strStatus == "ONLINE") then
      -- once we connect, wait for our first success on one of our priority queue messages (like power on or calibration status or something) before sending all of our normal non priority stuff like settings and config.
      gWaitingForFirstSuccessfulReceiveFromNetwork = true
      startCalibrationStatusTimer() -- the calibration messages get stuffed in the priority queue, so we need to start the timer for them to ensure we don't miss them.
      gNetConnected = true
      C4:UpdateProperty('Connected To Network','true')
      if(gNeverPowerDown) then
        powerOn()
      else
        startPowerOnStatusDetectionTimer()
      end
      startPollingTimer()
      -- now that we should be all setup... call initialize to set all of our properties and what not
      initialize()
    else
      gNetConnected = false
      C4:UpdateProperty('Connected To Network','false')
      cancelPollingTimer()
      cancelPowerOnStatusDetectionTimer()
      cancelCalibrationStatusTimer()
    end
  end
end

function ReceivedFromNetwork(idBinding, nPort, strData)
  if(gLogVerbose ==true) then
    local logdata = string.gsub(strData, "\r", "").gsub(strData, "\n", "")
    dbg("Received From Network.  Binding(" .. idBinding .. ")  Port(" .. nPort .. ") Data(" .. logdata .. ")")
  end
  
  gReceiveBuf = gReceiveBuf .. strData

  local start, lengthOfCommandFromDevice, commandFromDevice
  start, lengthOfCommandFromDevice = string.find( gReceiveBuf , ']' )
  --dbg('start = ' .. (start or 0) )

  while(start ~= nil ) do
    commandFromDevice = string.sub(gReceiveBuf, 1, start )	-- Copy string to process
    --dbg('commandFromDevice = ' .. commandFromDevice)
    gReceiveBuf = string.sub(gReceiveBuf, lengthOfCommandFromDevice + 1) -- Remove string to process
    --dbg('New Buffer = ' .. gReceiveBuf)
    
    -- don't bother sending ping/poll repsonses to the response handler, they don't parse and 
    --  we don't care.
    if(string.find(commandFromDevice,"LEAF%[.*,.*,.*]")~=nil) then
      switchResponseHandler(commandFromDevice)
    elseif(string.find(commandFromDevice,"LEAF%[*]")~=nil) then
      -- we got a poll response, so go ahead and move on to the next message since the device is ready
      cancelInterCommandDelayTimer() 
      processSendQueue()
    end
    
    -- see if there is another message waiting in the buf
     start, lengthOfCommandFromDevice = string.find( gReceiveBuf , ']' )
    --dbg('start = ' .. (start or 0) )
  end
end

function SendIt(message, force)
  if( force == false and canSendMessage() ~= true ) then
    if(gLogVerbose) then
      dbg("Can not send right now.  Will try again later.")
    end
    return false
  end
  if(gLogVerbose) then
    dbg("Sending To Device: \"" .. string.gsub(message, "\n", "") .. "\"")
  end
  C4:SendToNetwork(6001, gPort, message)
  startInterCommandDelayTimer()
  return true
end

