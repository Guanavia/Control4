    setIRDirection(8)
  elseif (strProperty == gAudioDelay1PropertyString) then
    gAnalogAudio1Delay = tonumber(Properties[strProperty])
    setAudioDelay(1)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay1VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay2PropertyString) then
    gAnalogAudio2Delay = tonumber(Properties[strProperty])
    setAudioDelay(2)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay2VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay3PropertyString) then
    gAnalogAudio3Delay = tonumber(Properties[strProperty])
    setAudioDelay(3)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay3VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay4PropertyString) then
    gAnalogAudio4Delay = tonumber(Properties[strProperty])
    setAudioDelay(4)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay4VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay5PropertyString) then
    gAnalogAudio5Delay = tonumber(Properties[strProperty])
    setAudioDelay(5)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay5VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay6PropertyString) then
    gAnalogAudio6Delay = tonumber(Properties[strProperty])
    setAudioDelay(6)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay6VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay7PropertyString) then
    gAnalogAudio7Delay = tonumber(Properties[strProperty])
    setAudioDelay(7)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay7VariableString, Properties[strProperty]) 
    end
  elseif (strProperty == gAudioDelay8PropertyString) then
    gAnalogAudio8Delay = tonumber(Properties[strProperty])
    setAudioDelay(8)
    if(gSettingPropertyFromVariableContext == false) then
      C4:SetVariable(gAudioDelay8VariableString, Properties[strProperty]) 
    end
--   elseif (strProperty == 'Analog Audio 1 Volume') then
--     gAnalogAudio1Volume = tonumber(Properties[strProperty])
--     setAudioProps(1)
--   elseif (strProperty == 'Analog Audio 2 Volume') then
--     gAnalogAudio2Volume = tonumber(Properties[strProperty])
--     setAudioProps(2)
--   elseif (strProperty == 'Analog Audio 3 Volume') then
--     gAnalogAudio3Volume = tonumber(Properties[strProperty])
--     setAudioProps(3)
--   elseif (strProperty == 'Analog Audio 4 Volume') then
--     gAnalogAudio4Volume = tonumber(Properties[strProperty])
--     setAudioProps(4)
--   elseif (strProperty == 'Analog Audio 5 Volume') then
--     gAnalogAudio5Volume = tonumber(Properties[strProperty])
--     setAudioProps(5)
--   elseif (strProperty == 'Analog Audio 6 Volume') then
--     gAnalogAudio6Volume = tonumber(Properties[strProperty])
--     setAudioProps(6)
--   elseif (strProperty == 'Analog Audio 7 Volume') then
--     gAnalogAudio7Volume = tonumber(Properties[strProperty])
--     setAudioProps(7)
--   elseif (strProperty == 'Analog Audio 8 Volume') then
--     gAnalogAudio8Volume = tonumber(Properties[strProperty])
--     setAudioProps(8)
  elseif (strProperty == 'Zone 1 Auto Locks') then
    gAutoLockOnOutputZone1Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 2 Auto Locks') then
    gAutoLockOnOutputZone2Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 3 Auto Locks') then
    gAutoLockOnOutputZone3Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 4 Auto Locks') then
    gAutoLockOnOutputZone4Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 5 Auto Locks') then
    gAutoLockOnOutputZone5Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 6 Auto Locks') then
    gAutoLockOnOutputZone6Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 7 Auto Locks') then
    gAutoLockOnOutputZone7Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == 'Zone 8 Auto Locks') then
    gAutoLockOnOutputZone8Selection = propertyStringBoolToBoolean(Properties[strProperty])
  elseif (strProperty == gAutoUpdateProperty) then
    dbg("Setting Auto Update Mode To: " .. Properties[strProperty])
    if(Properties[strProperty] == "Automatic") then
      gAutoUpdate = true
    else
      gAutoUpdate = false
    end
    getFWVersionOnServerFromDevice() -- when this data comes back, if auto upgrade is enabled it will kick off
  elseif (strProperty == gUpdateURLProperty) then
    sendFirmwareLocation()
  end
end


--------------------------------------------------------------------------------------------------------
-- Driver stuff
--------------------------------------------------------------------------------------------------------

function OnDriverDestroyed()
  cancelDebugTimer()
  cancelInterCommandDelayTimer()
  cancelPollingTimer()
end

function OnDriverUpgrade()
  C4:UpdateProperty("Version", 34) -- This 34 is replaced / Fixed up by the combine script.
end

function OnDriverInit()
  local systemVersionString = C4:GetVersionInfo()["version"]
  gSystemVersionMajor, gSystemVersionMinor, gSystemVersionPatch, gSystemVersionBuild = string.match(systemVersionString, "(%d+).(%d+).(%d+).(%d+)")
  C4:AddVariable(gAudioDelay1VariableString, Properties[gAudioDelay1PropertyString], "INT", false, false) --1001
  C4:AddVariable(gAudioDelay2VariableString, Properties[gAudioDelay2PropertyString], "INT", false, false) --1002
  C4:AddVariable(gAudioDelay3VariableString, Properties[gAudioDelay3PropertyString], "INT", false, false) --1003
  C4:AddVariable(gAudioDelay4VariableString, Properties[gAudioDelay4PropertyString], "INT", false, false) --1004
  C4:AddVariable(gAudioDelay5VariableString, Properties[gAudioDelay5PropertyString], "INT", false, false) --1005
  C4:AddVariable(gAudioDelay6VariableString, Properties[gAudioDelay6PropertyString], "INT", false, false) --1006
  C4:AddVariable(gAudioDelay7VariableString, Properties[gAudioDelay7PropertyString], "INT", false, false) --1007
  C4:AddVariable(gAudioDelay8VariableString, Properties[gAudioDelay8PropertyString], "INT", false, false) --1008
end

function initialize()
  sendFirmwareLocation() -- send the fw location first so it can chew on it for a bit.  This will also kick off a timer to go get the FW version on the server.
  getAllCurrentOutputToInputMappings() -- Same as above.  Regular queue, no timer required.
  getAllCurrentOutputToLockedInputMappings() -- Same as above.  Reqular queue, no timer required.
  gInitialized = true -- set to true so we will now send all the properties to the device.  Then when properties change one by one, they will be sent also.  Should only be set to false once in the "Main" section below to prevent setting the same property twice on startup.
  setAllPropertiesFromDriverToDevice()
  getUpgradeStatus()
  getFWVersionFromDevice() -- The fw version messages are in the regular queue, so we won't request them until we know we can get them.  Since those messages use the regular queue we don't use a timer to go get them.
end

function updateFWVersionProperty()
  if(gFWMajor ~= "-1" and gFWMinor ~= "-1") then
    C4:UpdateProperty("Firmware Version", gFWMajor .. "." .. gFWMinor)
  end
end

function updateFWServerVersionProperty()
  if(gFWServerMajor == "00" and gFWServerMinor == "00") then
    startURLSetGetFWVersionTimer()
    return
  end
    
  if(gFWServerMajor ~= "-1" and gFWServerMinor ~= "-1") then
    C4:UpdateProperty(gServerFWVersionProperty, gFWServerMajor .. "." .. gFWServerMinor)
    if(gFWServerMajor ~= "-1" and gFWServerMinor ~= "-1" and gAutoUpdate) then
      dbg("Got Firmware Major and Minor From Server Version and Firmware Upgrade Mode is set to automatic.  Kick It Off.")
      initiateFirmwareUpgrade() -- the initiate upgrade process will do the version checking
    end
  end
end

function getFWVersionFromDevice()
  dbg("Get FW Version From Device")
  gFWMajor="-1"  -- set to -1 so when we get the responses we don't kick off multiple upgrades, plus lets just ensure the data is correct and up to date.
  gFWMinor="-1"  -- set to -1 so when we get the responses we don't kick off multiple upgrades, plus lets just ensure the data is correct and up to date.
  
  SendMessageToSwitch(MESSAGES.GET_FW_MAJOR)
  SendMessageToSwitch(MESSAGES.GET_FW_MINOR)
end

function getFWVersionOnServerFromDevice()
  dbg("Get FW Version On Server From Device")
  
  gFWServerMajor="-1"
  gFWServerMinor="-1"
  
  SendMessageToSwitch(MESSAGES.GET_SRV_FW_MAJOR)
  SendMessageToSwitch(MESSAGES.GET_SRV_FW_MINOR)
end

function getCalibrationState()
  dbg("Get Calibration State")
  SendMessageToSwitchImmediately(MESSAGES.GET_CALIBRATION_STATE)
end

function getCalibratingStatus()
  dbg("Get Status Of Calibration Process")
  SendMessageToSwitchImmediately(MESSAGES.GET_CALIBRATION_ACTIVITY)
end

function switchResponseHandler(retMessage)
  -- Example Response: LEAF[2d,01,00]
  if(gLogVerbose) then
    local commandFromDevice = retMessage
    if(string.find(commandFromDevice, "LEAF%[9f")~=nil) then
      dbg('Switch Response Handler: ' .. commandFromDevice)
    else
      commandFromDevice = string.gsub(commandFromDevice, "\r", "")
      commandFromDevice = string.gsub(commandFromDevice, "\n", "")
      dbg('Switch Response Handler: ' .. commandFromDevice)
    end
  end
  
  -- set this flag to false now that we have received something and we can assume the device is ready to take more commands.
  --  this is to accomodate the case when the device has just booted, is connected, but not ready to receive a bunch of commands
  --  which results in many lost commands and no responses.
  gWaitingForFirstSuccessfulReceiveFromNetwork = false
  
  local commandIndex
  local command
  local paramSSIndex
  local paramSS
  local paramZZIndex
  local paramZZ
  
  commandIndex = string.find(retMessage, "[", nil, true)+1
  command = string.sub(retMessage, commandIndex, commandIndex+1)
  paramSSIndex = string.find(retMessage, ",", commandIndex, true)+1
  paramSS = string.sub(retMessage, paramSSIndex, paramSSIndex+1)
  paramZZIndex = string.find(retMessage, ",", paramSSIndex, true)+1
  paramZZ = string.sub(retMessage, paramZZIndex, paramZZIndex+1)
  
  if(command == "2d") then
    DEVICE_RESPONSE_HANDLERS["STATUS"](paramSS, paramZZ)
  elseif(command == "0e") then
    DEVICE_RESPONSE_HANDLERS["POWER_OFF"](paramSS, paramZZ)
  elseif(command == "0d") then
    DEVICE_RESPONSE_HANDLERS["POWER_ON"](paramSS, paramZZ)
  elseif(command == "35") then
    DEVICE_RESPONSE_HANDLERS["QUERY_ZONE"](paramSS, paramZZ)
  elseif(command == "31") then
    DEVICE_RESPONSE_HANDLERS["QUERY_ZONE_AUDIO"](paramSS, paramZZ)
  elseif(command == "33" or command == "5d") then
    DEVICE_RESPONSE_HANDLERS["QUERY_LOCK"](paramSS, paramZZ)
  elseif(command == "48" or command == "47") then
    DEVICE_RESPONSE_HANDLERS["ZONE_CHANGE"](paramSS, paramZZ)
  elseif(command == "b0" or command == "b1") then
    DEVICE_RESPONSE_HANDLERS["AUDIO_CHANGE"](paramSS, paramZZ)
  end
  
  -- we got a response, so go ahead and move on to the next message since the device is ready
  cancelInterCommandDelayTimer() 
  processSendQueue()
end

function setAllPropertiesFromDriverToDevice()
  local i
  
  for i=1,gNumberOutputs do
    setAudioProps(i)
  end
  
  for i=1,gNumberOutputs do
    setIRDirection(i)
  end
end

function getAllCurrentOutputToInputMappings()
  local i
  for i=0,(gNumberOutputs-1) do
    getZoneMapping(i)
  end
end

function getAllCurrentOutputToLockedInputMappings()
  local i
  for i=0,(gNumberOutputs-1) do
    getZoneLockMapping(i)
  end
end

function getAudioZoneMapping(zone)
  SendMessageToSwitch(MESSAGES.QUERY_AUDIO_ZONE .. convertFromNumberToHexString(zone))
end

function getZoneMapping(zone)
  SendMessageToSwitch(MESSAGES.QUERY_AV_ZONE .. convertFromNumberToHexString(zone))
end

function getZoneLockMapping(zone)
  SendMessageToSwitch(MESSAGES.QUERY_AV_LOCK .. convertFromNumberToHexString(zone))
end

function processSendQueue()
  priority = false
  
  if(#gSendQueue <= 0 and #gPrioritySendQueue <=0) then
    --dbg("processSendQueue : Nothing to send.")
    return
  end
  
  if(#gPrioritySendQueue >0) then
    priority = true
  end
  
  if(gLogVerbose) then
    dbg("Process Send Queue")
  end
  
  local message
  if(priority) then
    message = gPrioritySendQueue[1]
  else
    message = gSendQueue[1]
  end
  
  -- if this is not a "raw message" it needs an ending square bracket
  if( messageIsRawMessage(message) ~= true ) then
    message = message .. "]"
  end
  
  -- make sure it ends in a newline
  message = message .. "\n"
    
  -- if we successfully send the message, pop it off the front
  if(priority) then
    if( SendIt(message, true) == true ) then
      table.remove(gPrioritySendQueue, 1)
    end
  else
    if( SendIt(message, false) == true ) then
      table.remove(gSendQueue, 1)
    end
  end
end

function processPoll()
  if(#gSendQueue == 0 and #gPrioritySendQueue == 0) then
    SendMessageToSwitch(MESSAGES.POLL)
  else
    if(gLogVerbose) then
      dbg("Not polling because there are other messages in the queue.");
    end
    processSendQueue()
  end
end

function messageIsRawMessage(message)
  if( string.find(message, 'UPDATEURL') ~= nil ) then
    return true
  else
    return false
  end
end

function SendMessageToSwitch(message)
  if(gLogVerbose) then
    if(messageIsRawMessage(message)) then
      dbg("Send Message To Switch.  Queueing message: \"" .. message .. "\"")
    else
      dbg("Send Message To Switch.  Queueing message: \"" .. message .. "]\"")
    end
  end
  
  if(#gSendQueue > gSendQueuesMaxSizes) then
    err("Send Queue Is Full.  Not Queueing Any More Messages.  Something Is Wrong.")
    return
  end
  
  table.insert(gSendQueue, message)
  processSendQueue()
end

function SendMessageToSwitchImmediately(message)
  if(gLogVerbose) then
    dbg("Send Message To Switch Immediately.  Sending message: \"" .. message .. "]\"")
  end
  
   if(#gPrioritySendQueue > gSendQueuesMaxSizes) then
    err("Priority Send Queue Is Full.  Not Queueing Any More Messages.  Something Is Wrong.")
    return
  end
  
  table.insert(gPrioritySendQueue, message)
  processSendQueue()
end

function getAsciiInfo()
  dbg("Get Ascii Info")
  SendMessageToSwitch(MESSAGES.GET_ASCII_INFO)
end

function getPowerStatus()
  dbg("Get Power Status")
  SendMessageToSwitchImmediately(MESSAGES.GET_POWER_STATUS)
end

function powerOn()
  if(gPowerOn~=true) then
    dbg("Power On")
    if(gNetConnected == false) then
      dbg("Unable to power on or check because we're not net connected.")
      return
    end
    SendMessageToSwitchImmediately(MESSAGES.POWER_ON) -- make sure to send this message before setting the waiting flag, otherwise the flag will prevent sending
    gWaitingForPowerOn = true
    startPowerOnStatusDetectionTimer()
    getPowerStatus() -- call this now, if we're already on then we can circumvent waiting one cycle of the request
  end
end

function powerOff()
  if(gNeverPowerDown) then
    dbg("Received power off command but flag is set to stay on all the time.  Ignoring.")
    return
  end
  
  if(gPowerOn==true) then 
    dbg("Power Off")
    SendMessageToSwitch(MESSAGES.POWER_OFF)
  else
    dbg("Received power off command, but we're already off.")
  end
end

function setAudioProps(output)
  if(gInitialized) then
    SendMessageToSwitch(MESSAGES.SET_AUDIO_VOLUME .. getCommandParamsForAnalogAudioVolume(output))
  end
end

function setAudioDelay(source)
  local numOuts = (gNumberOutputs-1)
  for i=0,numOuts do
    dbg("Checking Output: " .. makeZoneLoggable(i) .. " To see if its source (".. gOutputToInputAudioMap[convertFromNumberToHexString(i)] ..") Is Bound To Source: " .. tostring(source))
    if(gOutputToInputAudioMap[convertFromNumberToHexString(i)] == convertFromNumberToHexString(source)) then
      dbg("Setting Audio Delay For Output(".. makeZoneLoggable(i) ..") which is mapped to source(".. gOutputToInputAudioMap[convertFromNumberToHexString(i)]..")")
      -- becuase of the weirdness with the indexes between this method and the methods from director, we need to add one before we pass this into the audio delay params function
      local params = getCommandParamsForAudioDelay(i+1)
      if(params ~= "") then
        SendMessageToSwitch(MESSAGES.SET_AUDIO_DELAY .. params)
      end
    end
  end

end

function setIRDirection(output)
  if(gInitialized) then
    SendMessageToSwitch(MESSAGES.SET_IR_DIRECTION .. getCommandParamsForIRDirection(output))
  end
end

function disconnectOutput(output)
  local commandArgs = getCommandParamsForOutputDisconnect(output)
  SendMessageToSwitch(MESSAGES.AV_ZONE_OFF .. commandArgs)
  -- output comes in 1 indexed.  Make sure to account for that in our map which is 0 indexed
  gOutputToInputMap[convertFromNumberToHexString(output-1)] = "00"
  gOutputToInputZoneLockMap[convertFromNumberToHexString(output-1)] = "00"
end

function disconnectOutputAudio(output)
  local commandArgs = getCommandParamsForOutputDisconnect(output)
  SendMessageToSwitch(MESSAGES.ANALOG_AUDIO_OFF .. commandArgs)
  -- output comes in 1 indexed.  Make sure to account for that in our map which is 0 indexed
  gOutputToInputAudioMap[convertFromNumberToHexString(output-1)] = "00"
end

-- zone should be zero indexed
function sourceSelectionFailedInZone(zone)
  dbg("Source Selection Failed In Zone: " .. makeZoneLoggable(zone))
  if(zone == 0) then
    debounceSourceMappingInZone1Failure()
  elseif(zone == 1) then
    debounceSourceMappingInZone2Failure()
  elseif(zone == 2) then
    debounceSourceMappingInZone3Failure()
  elseif(zone == 3) then
    debounceSourceMappingInZone4Failure()
  elseif(zone == 4) then
    debounceSourceMappingInZone5Failure()
  elseif(zone == 5) then
    debounceSourceMappingInZone6Failure()
  elseif(zone == 6) then
    debounceSourceMappingInZone7Failure()
  elseif(zone == 7) then
    debounceSourceMappingInZone8Failure()
  else
    err("Source Selction Failed Method: INVALID Zone : " .. makeZoneLoggable(zone))
  end
end

function sourceSelectionStolenInZone(zone)
  dbg("EVENT: Source Selection Stolen In Zone: " .. makeZoneLoggable(zone))
  if(zone == 0) then
    C4:FireEvent("Zone 1 Source Lost")
  elseif(zone == 1) then
    C4:FireEvent("Zone 2 Source Lost")
  elseif(zone == 2) then
    C4:FireEvent("Zone 3 Source Lost")
  elseif(zone == 3) then
    C4:FireEvent("Zone 4 Source Lost")
  elseif(zone == 4) then
    C4:FireEvent("Zone 5 Source Lost")
  elseif(zone == 5) then
    C4:FireEvent("Zone 6 Source Lost")
  elseif(zone == 6) then
    C4:FireEvent("Zone 7 Source Lost")
  elseif(zone == 7) then
    C4:FireEvent("Zone 8 Source Lost")
  else
    err("Source Selction Stolen Method: INVALID Zone : " .. makeZoneLoggable(zone))
  end
end

function sourceSelectionStealingPreventedInZone(zone)
  dbg("EVENT: Source Selection Prevented Stealing In Zone: " .. makeZoneLoggable(zone))
  if(zone == 0) then
    C4:FireEvent("Zone 1 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 1) then
    C4:FireEvent("Zone 2 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 2) then
    C4:FireEvent("Zone 3 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 3) then
    C4:FireEvent("Zone 4 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 4) then
    C4:FireEvent("Zone 5 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 5) then
    C4:FireEvent("Zone 6 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 6) then
    C4:FireEvent("Zone 7 Failed Lock, Multiple Zones Viewing Source")
  elseif(zone == 7) then
    C4:FireEvent("Zone 8 Failed Lock, Multiple Zones Viewing Source")
  else
    err("Source Selction Prevented Stealing Method: INVALID Zone : " .. makeZoneLoggable(zone))
  end
  
end

--sone should be zero indexed
function dontNeedToSwitch(zone, source)
  local zz = convertFromNumberToHexString(zone)
  local ss = convertFromNumberToHexString(source)
  
  --dbg("CHECKING ZONE (".. makeZoneLoggable(zz) ..")  :: CURRENT SOURCE (".. tonumber(gOutputToInputMap[zz]) ..")  :: NEW SOURCE (".. tonumber(ss) ..")")
  
  if(tonumber(gOutputToInputMap[zz]) == tonumber(ss)) then
    return true -- don't need to switch
  else
    --dbg("Need to switch.  Zone: " .. makeZoneLoggable(zz) .. " Is mapped to source: " .. ss)
    return false
  end
end


-- source should be zero indexed
function isSourceAvailable(source)
  local zz
  local ss
  
  for zz,ss in pairs(gOutputToInputZoneLockMap) do
    if(tonumber(ss) ~= 0) then
      if(tonumber(ss) == tonumber(source)) then
	dbg("isSourceAvailable:: Zone(" .. makeZoneLoggable(zz) .. ") Has Lock On Source(" .. convertFromNumberToHexString(source) .. ")")
	return false
      end
    end
  end
  return true
end

-- returns true if the source would be stolen
function sourceWouldBeStolen(zone_number, source)
  local zz
  local ss

  for zz,ss in pairs(gOutputToInputMap) do
    if(tonumber(ss) == tonumber(source)) then		-- if the source (ss, source) is already in use
      if(zone_number ~= tonumber(zz)) then		-- and the zone that has is (zz) is not the zone locking it (zone_number), it's stolen
	      return true
      end
    end
  end
  
  return false
end

function ifSourceIsInUseAndBeingLockedHandleIt(zone_number, source)
  local zz
  local ss
  
  for zz,ss in pairs(gOutputToInputMap) do
    if(tonumber(ss) == tonumber(source)) then		-- if the source (ss, source) is already in use
      if(zone_number ~= tonumber(zz)) then		-- and the zone that has is (zz) is not the zone locking it (zone_number), it's stolen
	  sourceSelectionStolenInZone(tonumber(zz))
      end
    end
  end
end

function unlockZone(zone)
  local source
  local source_number
  -- the zones come into this method from programming in Control4.  In that context all zones are 1 indexed.  We need to 
  --  be zero indexed here, so subtract one from the given zone to get our zone_number
  local zone_number = tonumber(zone) - 1

  -- make sure the data that came in is sane
  if(zone_number < 0 or zone_number > (gNumberOutputs-1)) then
    err("Invalid zone to lock (" .. makeZoneLoggable(zone_number) .. ")")
    return
  end

  -- make sure we're acutally locked before we try to unlock
  if(gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)] == "00") then
    err("Zone (" .. makeZoneLoggable(zone_number) .. ") is not locked.  So it can not be unlocked.")
    return
  end

  -- source is a hex string at this point
  source = gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)]
  source_number = tonumber(source)
  dbg("Unlocking zone (" .. makeZoneLoggable(zone_number) .. ").  To unlock we will reslect the source(" .. source .. ") without the lock command.")

  -- to make sure the mapping of the source and the output goes smoothly, and that the source is 
  --  available in other zones now, flag the zone lock map for the zone to be not locked to a source
  --  (which means that the selected source will not appear in the zone lock map, thus unlocking the source)
  gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)] = "00"

  -- The mapSourceToOutput method expects output to come in 1 indexed.  So use the original zone. 
  --  It also expects number so make sure the args are in the number format
  mapSourceToOutput(source_number, tonumber(zone))

end



function lockZone(zone)
  local source
  -- the zones come into this method from programming in Control4.  In that context all zones are 1 indexed.  We need to 
  --  be zero indexed here, so subtract one from the given zone to get our zone_number
  local zone_number = tonumber(zone) - 1
  
  -- check that the zone is valid.  Less than zero and greater than outputs minus one beacuse the zones (outputs) are zero based.
  if(zone_number < 0 or zone_number > (gNumberOutputs-1)) then
    err("Invalid zone to lock (" .. makeZoneLoggable(zone_number) .. ")")
    return
  end
  
  -- now grab the source and make sure it is valid.
  source = gOutputToInputMap[convertFromNumberToHexString(zone_number)]
  if( source == "00" )then
    err("Zone requesting lock does not have a valid source.")
    return
  end
  
  if(sourceCanNotBeLocked(source) == true) then
    dbg("Source(".. source ..") can not be locked.  The configuration option to never lock this source is set.")
    sourceSelectionStealingPreventedInZone(zone_number)
    -- we are going to prevent the locking, but we still want it to switch...  So fire that off.
    return
  end
  
  -- make sure no one else has a lock on the zone, if they do then send up the error via the method call
  if(isSourceAvailable(source)) then
    dbg("Locking Zone(" .. makeZoneLoggable(zone_number) .. ") to Source(" .. source .. ")")
  else
    dbg("There is a lock.  See if the zone requesting the source is the one that has it.  Source Requested: " .. source .. ".  Source (" .. gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)] .. ") locked in zone(" .. makeZoneLoggable(zone_number) .. ") ")
    if(convertFromNumberToHexString(source) ~= gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)]) then
      sourceSelectionFailedInZone(zone_number)
      return
    else
      dbg("Already Have Lock, but will send command again.  Locking Zone(" .. makeZoneLoggable(zone_number) .. ") to Source(" .. source .. ")")
    end
  end
  
  -- if the source is going to be stolen, but the flag is set to prevent it, fire the events and bail.
  if(sourceWouldBeStolen(zone_number, source) and gPreventSourceStealing == true) then
    dbg("Source(".. source ..") would be stolen and the global flag preventing source stealing is set to true")
    sourceSelectionStealingPreventedInZone(zone_number)
    return
  end
  
  -- if the source is being stolen, or turned off in some zones, due to this lock then handle the situation appropriately
  ifSourceIsInUseAndBeingLockedHandleIt(zone_number, source)
  
  -- if we're locking, and the source was not already locked, then set the zone's locked source in the map.
  --  We want to mark this right away instead of waiting for the response from the device.  If software is selecting a bunch of 
  --  mappings we need this info to be correct before getting the response back as the delay from command send to response may
  --  cause stuff to get out of whack and the system thinks multiple zones have a source when only one has it locked.
  gOutputToInputZoneLockMap[convertFromNumberToHexString(zone_number)] = convertFromNumberToHexString(source)
  
  -- ugh.  The getCommandParamsForSourceToOutput method expects a 1 indexed zone.  So use the zone given instead of the zone_number
  commandArgs = getCommandParamsForSourceToOutput(source, zone)
  SendMessageToSwitch(MESSAGES.AV_ZONE_LOCK .. commandArgs)
end

function sourceCanNotBeLocked(source)
  source_number = tonumber(source)
  if(source_number == 1 and gPreventLockOnSource1 == true) then
    return true
  elseif(source_number == 2 and gPreventLockOnSource2 == true) then
    return true
  elseif(source_number == 3 and gPreventLockOnSource3 == true) then
    return true
  elseif(source_number == 4 and gPreventLockOnSource4 == true) then
    return true
  elseif(source_number == 5 and gPreventLockOnSource5 == true) then
    return true
  elseif(source_number == 6 and gPreventLockOnSource6 == true) then
    return true
  elseif(source_number == 7 and gPreventLockOnSource7 == true) then
    return true
  elseif(source_number == 8 and gPreventLockOnSource8 == true) then
    return true
  elseif(source_number < 0 or source_number > 8) then
    err("sourceCanNotBeLocked : Received bogus source: (" .. source .. ")" )
    return true
  end
  
  return false
end

--NOTE: output, or zone, in this function comes in 1 indexed.
function mapSourceToOutput(source, output)
  local commandArgs = getCommandParamsForSourceToOutput(source, output)
  local doingLock = false
  
  -- If the source is not available then we won't bother sending any messages to the 
  --  device, and we can fire an error event back to the system for programming purposes
  if(isSourceAvailable(source) ~= true) then
    dbg("There is a lock.  See if the zone requesting the source is the one that has it.  Source Requested: " .. convertFromNumberToHexString(source) .. ".  Source (" .. gOutputToInputZoneLockMap[convertFromNumberToHexString(output-1)] .. ") locked in zone(" .. makeZoneLoggable(output-1) .. ") ")
    if(convertFromNumberToHexString(source) ~= gOutputToInputZoneLockMap[convertFromNumberToHexString(output-1)]) then
      sourceSelectionFailedInZone(output-1)
      return
    else
      dbg("Already Have Lock, but will send command again.  Locking Zone(" .. makeZoneLoggable(output-1) .. ") to Source(" .. source .. ")")
    end
    return
  end
  
  if(output == 1) then
    if(gAutoLockOnOutputZone1Selection) then
      doingLock = true
    end
  elseif(output == 2) then
    if(gAutoLockOnOutputZone2Selection) then
      doingLock = true
    end
  elseif(output == 3) then
    if(gAutoLockOnOutputZone3Selection) then
      doingLock = true
    end
  elseif(output == 4) then
    if(gAutoLockOnOutputZone4Selection) then
      doingLock = true
    end
  elseif(output == 5) then
    if(gAutoLockOnOutputZone5Selection) then
      doingLock = true
    end
  elseif(output == 6) then
    if(gAutoLockOnOutputZone6Selection) then
      doingLock = true
    end
  elseif(output == 7) then
    if(gAutoLockOnOutputZone7Selection) then
      doingLock = true
    end
  elseif(output == 8) then
    if(gAutoLockOnOutputZone8Selection) then
      doingLock = true
    end
  else
    err("mapSourceToOutput : Received bogus output: (" .. makeZoneLoggable(output-1) .. ")" )
    return
  end
  
  -- output is 1 indexed and our map is zero indexed.  For logging leave it as is.
  if(doingLock) then
    
    if(sourceCanNotBeLocked(source) == true) then
      dbg("Source(".. source ..") can not be locked.  The configuration option to never lock this source is set.  Just Select it instead.")
      -- we are going to prevent the locking, but we still want it to switch...  So fire that off.
      SendMessageToSwitch(MESSAGES.AV_ZONE_ON .. commandArgs)
      sourceSelectionStealingPreventedInZone(output-1)
      return
    end
    
    -- if the source is going to be stolen, but the flag is set to prevent it, fire the events and bail.
    if(sourceWouldBeStolen(output-1, source) and gPreventSourceStealing == true) then
      dbg("Source(".. source ..") would be stolen and the global flag preventing source stealing is set to true")
      sourceSelectionStealingPreventedInZone(output-1)
      
      -- we are going to prevent the stealing, but we still want it to switch...  So fire that off.
      SendMessageToSwitch(MESSAGES.AV_ZONE_ON .. commandArgs)
      
      return
    end
    
    -- now print our debug message
    dbg("Auto Locking Zone(" .. convertFromNumberToHexString(output) .. ") to Source(" .. source .. ")")
    
    -- send the message to the switch
    SendMessageToSwitch(MESSAGES.AV_ZONE_LOCK .. commandArgs)
    
    -- set this zone as locked.
    --  We want to mark this right away instead of waiting for the response from the device.  If software is selecting a bunch of 
    --  mappings we need this info to be correct before getting the response back as the delay from command send to response may
    --  cause stuff to get out of whack and the system thinks multiple zones have a source when only one has it locked.
    gOutputToInputZoneLockMap[convertFromNumberToHexString(output-1)] = convertFromNumberToHexString(source)
    
    -- if the source is being stolen, or turned off in some zones, due to this lock then handle the situation appropriately
    ifSourceIsInUseAndBeingLockedHandleIt(output-1, source)
  else
    
    -- send the message to the switch
    SendMessageToSwitch(MESSAGES.AV_ZONE_ON .. commandArgs)
    
    -- set this zone as not locked.
    --  We want to mark this right away instead of waiting for the response from the device.  If software is selecting a bunch of 
    --  mappings we need this info to be correct before getting the response back as the delay from command send to response may
    --  cause stuff to get out of whack and the system thinks multiple zones have a source when only one has it locked.
    gOutputToInputZoneLockMap[convertFromNumberToHexString(output)] = "00"
    dbg("Select  Zone(" .. convertFromNumberToHexString(output) .. ") to Source(" .. source .. ")")
  end
  
end

function mapSourceToOutputAudio(source, output)
  dbg("Select Audio Output!!! Source: " .. source .. " Output: " .. output)
  local commandArgs = getCommandParamsForSourceToOutput(source, output)
  SendMessageToSwitch(MESSAGES.MAP_ANALOG_AUDIO .. commandArgs)
  
  --next store off the mapping, then send the delay for the source to this output
  gOutputToInputAudioMap[convertFromNumberToHexString(output-1)] = convertFromNumberToHexString(source)

  local commandArgsAudio =  getCommandParamsForAudioDelay(output)
  SendMessageToSwitch(MESSAGES.SET_AUDIO_DELAY .. commandArgsAudio)

  dbg("Mapping For Audio.  Output Index: ".. convertFromNumberToHexString(output-1) .. " To Source: " .. gOutputToInputAudioMap[convertFromNumberToHexString(output-1)])
end

function DEVICE_RESPONSE_HANDLERS.STATUS(paramSS, paramZZ)
  if(paramZZ == "00") then -- this is a power status
    cancelPowerOnStatusDetectionTimer() -- now that we have a status, turn off the timer
    if(paramSS == "01") then
      gPowerOn = true
      C4:UpdateProperty("Power Status", "On")
      gWaitingForPowerOn = false
      dbg("Device Is Powered On")
      TellProxyPowerOn()
    elseif(paramSS == "00") then
      gPowerOn = false
      C4:UpdateProperty("Power Status", "Standby")
      dbg("Device Is In Standby")
      TellProxyPowerOff()
      
      -- if we are a never power down state, or we are waiting to power on, 
      --   and we just got the power status that we're in standby, send the 
      --   power on command.  Check separately so the log makes sense
      if(gNeverPowerDown) then
	dbg("Received power off status but we're supposed to be on all the time.  Sending Power On Command.")
	powerOn()
      end
      if(gWaitingForPowerOn) then
	dbg("Received power off status but we're waiting for power on.  Sending Power On Command Again.")
	powerOn()
      end
      
    end
  elseif(paramZZ == "10") then -- FW Major Version
    dbg("Got FW Major Number: " .. paramSS)
    gFWMajor = paramSS
    updateFWVersionProperty()
  elseif(paramZZ == "11") then -- FW Minor Version
    dbg("Got FW Minor Number: " .. paramSS)
    gFWMinor = paramSS
    updateFWVersionProperty()
  elseif(paramZZ == "14") then -- FW SERVER Major Version
    dbg("Got Server FW Major Number: " .. paramSS)
    gFWServerMajor = paramSS
    updateFWServerVersionProperty()
  elseif(paramZZ == "15") then -- FW SERVER Minor Version
    dbg("Got Server FW Minor Number: " .. paramSS)
    gFWServerMinor = paramSS
    updateFWServerVersionProperty()
  elseif(paramZZ == "b9") then -- Update available
    if(paramSS == "00") then
      err("FW Response To Update Available: NO FILE AVAILABLE")
    elseif(paramSS == "01") then
      if(gForceUpdate == true) then
	dbg("FW Response To Update Available: NO UPDATE AVAILABLE, but the force flag is set.  Fire it off.")
	tellDeviceToUpgrade()
      else
	dbg("FW Response To Update Available: NO UPDATE AVAILABLE")
      end
    elseif(paramSS == "02") then
      dbg("FW Response To Update Available: UPDATE AVAILABLE")
      if(gAutoUpdate) then
	tellDeviceToUpgrade()
      end
    elseif(paramSS == "03") then
      dbg("FW Response To Update Available: UPDATE TRIGGERED")
      C4:UpdateProperty(gLastUpdateProperty, gUpgradingString)
    else
      err("FW Response To Update Available : UNKNOWN RESPONSE: " .. paramSS)
    end
  elseif(paramZZ == "ba") then -- Last firmware upgrade
    if(paramSS == "00") then
      C4:UpdateProperty("Last Upgrade Status", "No Status")
      dbg("Received Upgrade Status : No Status")
    elseif(paramSS == "01") then
      C4:UpdateProperty("Last Upgrade Status", "Success")
      dbg("Received Upgrade Status : SUCCESS!")
      cancelUpgradeStatusTimer()
      getFWVersionFromDevice()
    elseif(paramSS == "02") then
      C4:UpdateProperty("Last Upgrade Status", "FAILED")
      err("Received Upgrade Status : FAILED!!!")
      cancelUpgradeStatusTimer()
    else
      err("FW Response To Last Update Status: UNKNOWN RESPONSE: " .. paramSS)
    end
  elseif(paramZZ == "62") then -- Calibration State
    if(paramSS == "00") then
      C4:UpdateProperty("Calibration Status", "NOT Calibrated")
      dbg("Received Status : NOT Calibrated")
    else 
      C4:UpdateProperty("Calibration Status", "Calibrated")
      dbg("Received Status : Calibrated")
    end
  elseif(paramZZ == "63") then -- Calibration Activity
    if(paramSS == "01") then
      C4:UpdateProperty("Calibration Status", "Calibrating")
      dbg("Received Status : Calibrating")
      gCurrentlyCalibrating = true
    else
      dbg("Received Status : Not Currently Calibrating")
      gCurrentlyCalibrating = false
      getCalibrationState()
      cancelCalibrationStatusTimer()
    end
  else
    dbg("Got Status For Something We Don't Care About")
  end
end

function DEVICE_RESPONSE_HANDLERS.POWER_OFF(paramSS, paramZZ)
  startPowerOnStatusDetectionTimer()
end

function DEVICE_RESPONSE_HANDLERS.POWER_ON(paramSS, paramZZ)
  startPowerOnStatusDetectionTimer()
end

function DEVICE_RESPONSE_HANDLERS.QUERY_ZONE(paramSS, paramZZ)
  dbg("QUERY ZONE RESPONSE.  Zone(" .. makeZoneLoggable(paramZZ) .. ") <--> Source(" .. paramSS .. ")" )
  gOutputToInputMap[paramZZ] = paramSS
  local inputBinding=tostring(tonumber(paramSS)-1+1000)
  local outputBinding=tostring(tonumber(paramZZ+2000))
  
  -- if we end up with a 999, this means we're disconnected and we need to do a -1
  if(tonumber(inputBinding) == 999) then
    inputBinding = -1
  end
  
  -- if we just switch sources in an "unlocked" mode, make sure if we had a previous lock on a source we release it
  gOutputToInputZoneLockMap[paramZZ] = "00"
  TellProxyInputOutputChanged(inputBinding, outputBinding)
end

function DEVICE_RESPONSE_HANDLERS.QUERY_ZONE_AUDIO(paramSS, paramZZ)
  dbg("QUERY ZONE AUDIO RESPONSE.  Zone(" .. makeZoneLoggable(paramZZ) .. ") <--> Source(" .. paramSS .. ")" )
  gOutputToInputAudioMap[paramZZ] = paramSS
  local inputBinding=tostring(tonumber(paramSS)-1+1000)
  local outputBinding=tostring(tonumber(paramZZ+4000))
  
  -- if we end up with a 999, this means we're disconnected and we need to do a -1
  if(tonumber(inputBinding) == 999) then
    inputBinding = -1
  end
  
  -- if we just switch sources in an "unlocked" mode, make sure if we had a previous lock on a source we release it
  TellProxyInputOutputAudioChanged(inputBinding, outputBinding)
end

function DEVICE_RESPONSE_HANDLERS.QUERY_LOCK(paramSS, paramZZ)
  dbg("QUERY LOCK RESPONSE.  Zone(" .. makeZoneLoggable(paramZZ) .. ") <--> Source(" .. paramSS .. ")" )

  local inputBinding=tostring(tonumber(paramSS)-1+1000)
  local outputBinding=tostring(tonumber(paramZZ+2000))
  
  gOutputToInputZoneLockMap[paramZZ] = paramSS   -- the zone is locked so mark it as such, or if we have no lock ("00") then setting that as not locked is equally important
  if(paramSS ~= "00") then                       -- if we have not lock, it does not mean we have no regular mapping, so only set the regular mapping if we have a lock.
    gOutputToInputMap[paramZZ] = paramSS         -- we have a lock, but that also implies we have the source to zone mapping as well
    TellProxyInputOutputChanged(inputBinding, outputBinding) -- only report the input output changed stuff if the source is not "00", else we end up with goofy values and stuff not working.
  end
end

function DEVICE_RESPONSE_HANDLERS.ZONE_CHANGE(paramSS, paramZZ)
  dbg("Zone Changed (" .. makeZoneLoggable(paramZZ) .. ").  Go Get the new source mapping for this zone.")
  getZoneMapping(paramZZ)
end

function DEVICE_RESPONSE_HANDLERS.AUDIO_CHANGE(paramSS, paramZZ)
  dbg("Audio Changed (" .. makeZoneLoggable(paramZZ) .. ").  Go Get the new source mapping for this zone for audio.")
  getAudioZoneMapping(paramZZ)
end

--------------------------------------------------------------------------------------------------------
-- Firmware Upgrade and methods to support it
--------------------------------------------------------------------------------------------------------
function sendFirmwareLocation()
  dbg("UPGRADE_TRACE : sendFirmwareLocation")
  local updateUrl = Properties["Update URL"]
  local updateMsg = "LEAF:UPDATEURL="
  SendMessageToSwitch(updateMsg .. updateUrl)
  startURLSetGetFWVersionTimer() -- when this timer expires we will go get the fw version on the server, and then when the data comes back if auto upgrade is enabled it will kick off
end

function initiateFirmwareUpgrade()
  dbg("UPGRADE_TRACE : initiateFirmwareUpgrade")
  -- ALWAYS call need to upgrade.  This does at least a sanity check that there is something out there.
  --  then if the force flag is set and we have a valid file out there, we can kick it off then.
  needToUpgrade()
end

function getUpgradeStatus()
  dbg("UPGRADE_TRACE : getUpgradeStatus")
  SendMessageToSwitch(MESSAGES.LAST_UPDATE_STATUS)
end

function tellDeviceToUpgrade()
  dbg("UPGRADE_TRACE : tellDeviceToUpgrade")
  local args=""
  if(gForceUpdate == true) then
    args="01"
    gForceUpdate=false -- make sure we don't upgrade in an infinite loop by setting this to false
  else
    args="00"
  end
  dbg("Tell Switch To Upgrade Now.")
  C4:UpdateProperty("Last Upgrade Status", gUpgradingString)
  startUpgradeStatusDelayTimer()
  SendMessageToSwitch(MESSAGES.UPDATE_NOW .. args)
end

function needToUpgrade()
  dbg("UPGRADE_TRACE : needToUpgrade")
  SendMessageToSwitch(MESSAGES.UPDATE_IS_AVAILABLE)
end

--------------------------------------------------------------------------------------------------------
-- Main entry point of script
--------------------------------------------------------------------------------------------------------

gInitialized = false --to prevent setting properties twice (once in OnPropertyChanged and once in setAllPropertiesFromDriverToDevice), set this flag to false

for k,v in pairs(Properties) do
  OnPropertyChanged(k)
end

C4:UpdateProperty("Version", 34) -- This 34 is replaced / Fixed up by the combine script.
C4:UpdateProperty("Power Status", "Unknown")
C4:UpdateProperty("Connected To Network", "false")
C4:UpdateProperty("Firmware Version", "Unknown") 
C4:UpdateProperty(gServerFWVersionProperty, "Unknown") 
C4:UpdateProperty("Calibration Status", "Unknown")
C4:UpdateProperty("Always On", "true")
gTicketIdForFirmwareFileGet = 0
gHaveToldProxyWeWillHandleAvPathValid = false
gNetConnected = false
gFWMajor="-1"
gFWMinor="-1"


    ]]>
  </script>
</config>
</devicedata>
