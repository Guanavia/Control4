  </properties>
  <script>
    <![CDATA[
    -- Table containing all the messages we will send the device.  Leave off last square
--  bracket as its appended as the message leaves.  This also allows the individual methods
--  to put their data in.
MESSAGES={
  ['POLL']                     ='LEAF[.',
  ['POWER_ON']                 ='LEAF[0D,00,00',
  ['POWER_OFF']                ='LEAF[0E,00,00',
  ['CALIBRATE']                ='LEAF[62,00,00',
  ['RESET']                    ='LEAF[FE,FE,FE',
  ['GET_ASCII_INFO']           ='LEAF[9F,00,00',
  ['DEBUG_0']                  ='LEAF[9F,02,00',
  ['DEBUG_1']                  ='LEAF[9F,E1,00',
  ['DEBUG_2']                  ='LEAF[9F,E2,00',
  ['DEBUG_3']                  ='LEAF[9F,E3,00',
  ['DEBUG_4']                  ='LEAF[9F,E4,00',
  ['DEBUG_5']                  ='LEAF[9F,E5,00',
  ['DEBUG_6']                  ='LEAF[9F,E6,00',
  ['DEBUG_7']                  ='LEAF[9F,E7,00',
  ['DEBUG_8']                  ='LEAF[9F,E8,00',
  ['GET_POWER_STATUS']         ='LEAF[2C,00,00',
  ['GET_IR_STATUS']            ='LEAF[2C,02,'  , -- up to calling method to put the rest of the args in there
  ['GET_FW_MAJOR']             ='LEAF[2C,10,10', -- ...
  ['GET_FW_MINOR']             ='LEAF[2C,11,11', -- ...
  ['GET_SRV_FW_MAJOR']         ='LEAF[2C,14,14', -- ...
  ['GET_SRV_FW_MINOR']         ='LEAF[2C,15,15', -- ...
  ['UPDATE_IS_AVAILABLE']      ='LEAF[2C,B9,B9', -- ...
  ['LAST_UPDATE_STATUS']       ='LEAF[2C,BA,BA', -- ...
  ['GET_CALIBRATION_STATE']    ='LEAF[2C,62,62', -- ...
  ['GET_CALIBRATION_ACTIVITY'] ='LEAF[2C,63,63', -- ...
  ['SET_AUDIO_DELAY']          ='LEAF[63,'     , -- ...
  ['SET_IR_DIRECTION']         ='LEAF[FE,'     , -- ...
  ['SET_AUTO_UPDATE']          ='LEAF[FE,B6,00', -- ... ALWAYS off.  The autoness of the update is on the driver side
  ['UPDATE_NOW']               ='LEAF[FE,B7,'  , -- ... 
  ['MAP_ANALOG_AUDIO']         ='LEAF[B0,'     , -- ...
  ['ANALOG_AUDIO_OFF']         ='LEAF[B1,'     , -- ...
  ['SET_AUDIO_VOLUME']         ='LEAF[59,'     , -- ...
  ['AV_ZONE_ON']               ='LEAF[48,'     , -- ...
  ['AV_ZONE_OFF']              ='LEAF[47,'     , -- ...
  ['AV_ZONE_LOCK']             ='LEAF[5D,'     , -- ...
  ['QUERY_AV_ZONE']            ='LEAF[34,00,'  , -- ...
  ['QUERY_AUDIO_ZONE']         ='LEAF[30,00,'  , -- ...
  ['QUERY_AV_LOCK']            ='LEAF[32,00,'  , -- ...
}

-- Table to be filled with functions (below) which will be our actions handler
ACTIONS = {}

-- Table to be filled with functions (below) which will be our proxy command handlers
PROXY_CMDS = {}

-- Table to be filled with functions (below) which will be handlers for the responses from the device
DEVICE_RESPONSE_HANDLERS = {}

--------------------------------------------------------------------------------------------------------
-- Variables
--------------------------------------------------------------------------------------------------------

-- A flag to show how many outputs we have.
gNumberOutputs = 8

-- A flag to keep track of initialization state so we do smart things at the right time(s)
gInitialized = false

-- Network port number to connect to
gPort = 8105

-- A flag to keep track of the status if we're connected or not
gNetConnected = false

-- Flag to know if we are printing debug messages in the console window
gDebugprint = false

-- Flag to know if we are logging debug message to the log
gDebuglog = false

-- Flag to know if we should not disable the debugging.  Only for development.
gPermaDebug = false

-- Flag to know if we should be verbose logging
gLogVerbose = false

-- Don't queue more than this many messages.  
gSendQueuesMaxSizes = 100

-- This is a queue to put everything outgoing into then we send it
gSendQueue = {}

-- This queue will always get serviced first as its the priority
gPrioritySendQueue = {}

-- Receive buffer, so we can handle partial messages / partial reads
gReceiveBuf = ''

-- Desire a flag to never turn off
gNeverPowerDown = false

-- This flag keeps track of the power status of the unit.  On means on, off means standby (we can still talk to it) but can not send switching commands
gPowerOn = nil

-- When we turn the power on, wait for it to be on before sending it stuff (presumably switching commands)
gWaitingForPowerOn = false

-- To acommodate delay's in the device communicating after it comes online, but before it is able to talk, and to not have some arbitrary super delay in here, 
--  this flag will let us know when we start receiving something from the device and we can send it more stuff.  This works because some commands, like get power status
--  happen no matter what when we first connect.  So once we receive a response we can set this flag to true and send more meaningful stuff.
gWaitingForFirstSuccessfulReceiveFromNetwork = true

-- Timer - Debug
gDebugTimer = 0

-- Timer - Calibration Check Timer.  When we start a calibration this timer will go get the status.
gCalibrationCheckTimer = 0
gCalibrationCheckTimerValueInMilliseconds = 1000

-- Timer - After Power On Power Status Detection
gPowerOnStatusDetectionTimer = 0
gPowerOnStatusDetectionValueInMilliseconds = 1000

-- Timer - Inter command delay.  If we get a resposne we will
--  automatically move on to the next message.  This is like a timeout for when we
--  get no response
gInterCommandDelayTimer = 0
gInterCommandDelayValueInMilliseconds = 250

-- Timer - After setting the URL wait a bit before asking for the version so the firmware can go out and figure it out
gAfterURLSetGetFWVersionTimer = 0
gAfterURLSetGetFWVersionTimerValueInSeconds = 60

-- Timer - After starting the upgrade, wait a bit before asking for the status so the firmware can internally update its
--  status from the last upgrade to the current one
gAfterUpgradeBeginsGetUpgradeStatusTimer = 0
gAfterUpgradeBeginsGetUpgradeStatusTimerValueInSeconds = 60

-- Timer - Upgrade Status Timer
gUpgradeStatusTimer = 0
gUpgradeStatusTimerValueInSeconds = 15

-- Timer for polling.  Default to 30 seconds
gPollingTimer = 0
gPollingTimerValueInSeconds = 60

-- Timers for "debouncing" the number of error events for failed to aquire source (due to lock).
--  Currently we get 4+ error events per attempt and we're really only looking for one.  So I'm using 
--  timers which can be reset on each event and eventually only fire one event
gDebounceFailedSourceMappingInZone1Timer = 0
gDebounceFailedSourceMappingInZone2Timer = 0
gDebounceFailedSourceMappingInZone3Timer = 0
gDebounceFailedSourceMappingInZone4Timer = 0
gDebounceFailedSourceMappingInZone5Timer = 0
gDebounceFailedSourceMappingInZone6Timer = 0
gDebounceFailedSourceMappingInZone7Timer = 0
gDebounceFailedSourceMappingInZone8Timer = 0
gDebounceFailedSourceMappingInZoneTimerValueInMilliseconds = 150

-- Map to keep track of inputs and outputs.  Primarily for progmatic zone locking
gOutputToInputMap={
  ["00"]="00",
  ["01"]="00",
  ["02"]="00",
  ["03"]="00",
  ["04"]="00",
  ["05"]="00",
  ["06"]="00",
  ["07"]="00",
}

-- Map to keep track of locks on sources.
gOutputToInputZoneLockMap={
  ["00"]="00",
  ["01"]="00",
  ["02"]="00",
  ["03"]="00",
  ["04"]="00",
  ["05"]="00",
  ["06"]="00",
  ["07"]="00",
}

gOutputToInputAudioMap={
  ["00"]="00",
  ["01"]="00",
  ["02"]="00",
  ["03"]="00",
  ["04"]="00",
  ["05"]="00",
  ["06"]="00",
  ["07"]="00", 
}

-- IR direction properties
--  Default to true but will be set via properties
gIR1DirectionFromSwitchToBalun = true
gIR2DirectionFromSwitchToBalun = true
gIR3DirectionFromSwitchToBalun = true
gIR4DirectionFromSwitchToBalun = true
gIR5DirectionFromSwitchToBalun = true
gIR6DirectionFromSwitchToBalun = true
gIR7DirectionFromSwitchToBalun = true
gIR8DirectionFromSwitchToBalun = true

-- Analog audio output delays
--  Default to 0 but will be set via properties
gAnalogAudio1Delay = 0
gAnalogAudio2Delay = 0
gAnalogAudio3Delay = 0
gAnalogAudio4Delay = 0
gAnalogAudio5Delay = 0
gAnalogAudio6Delay = 0
gAnalogAudio7Delay = 0
gAnalogAudio8Delay = 0

-- Analog audio output volumes
--  Default to 0 but will be set via properties, if the properties are uncommented.  For now this property has been removed.
gAnalogAudio1Volume = 100
gAnalogAudio2Volume = 100
gAnalogAudio3Volume = 100
gAnalogAudio4Volume = 100
gAnalogAudio5Volume = 100
gAnalogAudio6Volume = 100
gAnalogAudio7Volume = 100
gAnalogAudio8Volume = 100

-- Auto locking 
--  Default to false but will be set via properties
gAutoLockOnOutputZone1Selection = false
gAutoLockOnOutputZone2Selection = false
gAutoLockOnOutputZone3Selection = false
gAutoLockOnOutputZone4Selection = false
gAutoLockOnOutputZone5Selection = false
gAutoLockOnOutputZone6Selection = false
gAutoLockOnOutputZone7Selection = false
gAutoLockOnOutputZone8Selection = false

-- Firmware Upgrade
gTicketIdForFirmwareFileGet=0
gLastUpdateProperty="Last Upgrade Status"
gAutoUpdateProperty="Firmware Upgrade Mode"
gUpdateURLProperty="Update URL"
gServerFWVersionProperty="Firmware Version (Server)"
gUpgradingString="Upgrading"
gLeaveSourcesConnectedPropertyString="Leave Sources Connected"
gAudioDelay1PropertyString="Source 1 Audio Delay"
gAudioDelay2PropertyString="Source 2 Audio Delay"
gAudioDelay3PropertyString="Source 3 Audio Delay"
gAudioDelay4PropertyString="Source 4 Audio Delay"
gAudioDelay5PropertyString="Source 5 Audio Delay"
gAudioDelay6PropertyString="Source 6 Audio Delay"
gAudioDelay7PropertyString="Source 7 Audio Delay"
gAudioDelay8PropertyString="Source 8 Audio Delay"
gAudioDelay1VariableString="SOURCE_1_AUDIO_DELAY"
gAudioDelay2VariableString="SOURCE_2_AUDIO_DELAY"
gAudioDelay3VariableString="SOURCE_3_AUDIO_DELAY"
gAudioDelay4VariableString="SOURCE_4_AUDIO_DELAY"
gAudioDelay5VariableString="SOURCE_5_AUDIO_DELAY"
gAudioDelay6VariableString="SOURCE_6_AUDIO_DELAY"
gAudioDelay7VariableString="SOURCE_7_AUDIO_DELAY"
gAudioDelay8VariableString="SOURCE_8_AUDIO_DELAY"
gAutoUpdate = false
gForceUpdate = false

-- Firmware Version
gFWMajor="-1"
gFWMinor="-1"

-- Firmware on the server version
gFWServerMajor="-1"
gFWServerMinor="-1"

-- Currently Calibrating Flag
gCurrentlyCalibrating = false

-- We need to tell the proxy that we want to know about the validity of the av path
--  binding before it happens.  But if we do this before the proxy is "bound" to the 
--  protocol, the command seems to get lost.  So I need to do this once I know the 
--  proxy is available to communicate to, but don't want to send the message all the
--  time so I will use this flag to only send it once.
gHaveToldProxyWeWillHandleAvPathValid = false

-- System Version Variables
gSystemVersionMajor = 0
gSystemVersionMinor = 0
gSystemVersionPatch = 0
gSystemVersionBuild = 0

-- This is a global flag, when set to true, will prevent any zone from locking a source
--  if multiple zones are viewing the same source
gPreventSourceStealing = true

-- The following flags are to indicate that a particular source is not lockable
gPreventLockOnSource1 = false
gPreventLockOnSource2 = false
gPreventLockOnSource3 = false
gPreventLockOnSource4 = false
gPreventLockOnSource5 = false
gPreventLockOnSource6 = false
gPreventLockOnSource7 = false
gPreventLockOnSource8 = false

-- To prevent the audio delay variable setting the property, setting the variable, setting the property...
--  This flag will be set to prevent the infinite loop and ensure we only set the variable and
--  the property once each.
gSettingPropertyFromVariableContext = false

-- we could put all the global code in here I think - this is called after all the drivers are up 
function OnDriverLateInit()
  -- now that we know we can talk to the proxy, tell it we will handle the AV Valid
  if(gHaveToldProxyWeWillHandleAvPathValid == false) then
    TellProxyThisProtocolWillHandleAvValid()
  end
end


--------------------------------------------------------------------------------------------------------
-- debugging helpers
--------------------------------------------------------------------------------------------------------
function dbg(strDebugText)
  if (gDebugprint) then 
    local newDebugText = "DBG: [" .. os.date("%x %X") .. "] :: " .. strDebugText
    print(newDebugText) 
  end
  if (gDebuglog) then C4:DebugLog(strDebugText) end
end
    
function err(strErrText)
  local newErrorText = "ERR: [" .. os.date("%x %X") .. "] :: " .. strErrText
  print(newErrorText) 
  C4:ErrorLog(strErrText)
end

function printSystemVersion()
  print("System Version :: " .. gSystemVersionMajor .. "." .. gSystemVersionMinor .. "." .. gSystemVersionPatch .. "." .. gSystemVersionPatch)
end

function printSendQueue()
  for i=1,#gPrioritySendQueue do
    print("Priority Message: " .. i .. ":: \"" .. gPrioritySendQueue[i] .. "\"")
  end
  for i=1,#gSendQueue do
    print("         Message: " .. i .. ":: \"" .. gSendQueue[i] .. "\"")
  end
end

function printOutputToInputMapping()
  local numOuts = (gNumberOutputs-1)
  for i=0,numOuts do
     print("Output Zone(" .. makeZoneLoggable(i) .. ") <--> Input(" .. gOutputToInputMap[convertFromNumberToHexString(i)] .. ")" )
  end
end

function printZoneLockMapping()
  local numOuts = (gNumberOutputs-1)
  for i=0,numOuts do
     print("Output Zone(" .. makeZoneLoggable(i) .. ") <--> Locked Input(" .. gOutputToInputZoneLockMap[convertFromNumberToHexString(i)] .. ")" )
  end
end

function printAudioMapping()
  local numOuts = (gNumberOutputs-1)
  for i=0,numOuts do
    print("Output Audio(" .. makeZoneLoggable(i) .. ") <--> Input(" .. gOutputToInputAudioMap[convertFromNumberToHexString(i)] .. ")" )
  end
end

function makeZoneLoggable(zone)
  local zone_number = 0
  local zone_string = ""
  zone_number = tonumber(zone) + 1
  
  zone_string = convertFromNumberToHexString(zone_number)
  
  return zone_string
end

function fullDebugDump()
  print("Get Ascii Info")
  SendMessageToSwitch(MESSAGES.GET_ASCII_INFO)
  print("egress status")
  SendMessageToSwitch(MESSAGES.DEBUG_0)
  print("ingress edid status::1")
  SendMessageToSwitch(MESSAGES.DEBUG_1)
  print("ingress edid status::2")
  SendMessageToSwitch(MESSAGES.DEBUG_2)
  print("ingress edid status::3")
  SendMessageToSwitch(MESSAGES.DEBUG_3)
  print("ingress edid status::4")
  SendMessageToSwitch(MESSAGES.DEBUG_4)
  print("ingress edid status::5")
  SendMessageToSwitch(MESSAGES.DEBUG_5)
  print("ingress edid status::6")
  SendMessageToSwitch(MESSAGES.DEBUG_6)
  print("ingress edid status::7")
  SendMessageToSwitch(MESSAGES.DEBUG_7)
  print("ingress edid status::8")
  SendMessageToSwitch(MESSAGES.DEBUG_8)
end

--------------------------------------------------------------------------------------------------------
-- utility helpers
--------------------------------------------------------------------------------------------------------

function canSendMessage()
  local cantSendLogMessage = "Cant Send Right Now Because: "
  if(gInterCommandDelayTimer == 0 and gWaitingForFirstSuccessfulReceiveFromNetwork == false and gNetConnected == true and gWaitingForPowerOn == false and gCurrentlyCalibrating == false) then
    return true
  else
    if(gLogVerbose) then
      if(gInterCommandDelayTimer ~= 0) then
	cantSendLogMessage = cantSendLogMessage .. " :: Inter Command Delay Timer Is Active :: "
      end
      if(gNetConnected ~= true) then
	cantSendLogMessage = cantSendLogMessage .. " :: Not Network Connected :: "
      end
      if(gWaitingForPowerOn ~= false) then
	cantSendLogMessage = cantSendLogMessage .. " :: Not Powered On :: "
      end
      if(gCurrentlyCalibrating == true) then
	cantSendLogMessage = cantSendLogMessage .. " :: Calibrating :: "
      end
      if(gWaitingForFirstSuccessfulReceiveFromNetwork == true) then
	cantSendLogMessage = cantSendLogMessage .. " :: Waiting for a first response to know the device is ready :: "
      end
      dbg(cantSendLogMessage)
    end
    return false
  end
end

function propertyIRDirectionToBoolean(prop)
  if(prop == "Switch To Balun") then
    return true
  else
    return false
  end
end

function propertyStringBoolToBoolean(prop)
  if(prop == "true") then
    return true
  else 
   return false
  end
end

function convertFromNumberToHexString(value)
  local valueNumber = tonumber(value)
  return string.format("%02x", valueNumber)
end

function convertDirectionFromPropertyToHexString(value)
  if(value) then
    return "03"
  else
    return "02"
  end
end

function getCommandParamsForAudioDelay(whichOutput)
  local returnString = ""
  local whichSource = tonumber(gOutputToInputAudioMap[convertFromNumberToHexString(whichOutput-1)])
  -- dont subtract one from the logging to make it human readible and consistent with the other logging stuff being one indexed
  dbg("Output: " .. convertFromNumberToHexString(whichOutput) .. " is mapped to source: " .. tostring(whichSource))

  if(whichSource == 1) then
    returnString = convertFromNumberToHexString(gAnalogAudio1Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 2) then
    returnString = convertFromNumberToHexString(gAnalogAudio2Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 3) then
    returnString = convertFromNumberToHexString(gAnalogAudio3Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 4) then
    returnString = convertFromNumberToHexString(gAnalogAudio4Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 5) then
    returnString = convertFromNumberToHexString(gAnalogAudio5Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 6) then
    returnString = convertFromNumberToHexString(gAnalogAudio6Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 7) then
    returnString = convertFromNumberToHexString(gAnalogAudio7Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  elseif(whichSource == 8) then
    returnString = convertFromNumberToHexString(gAnalogAudio8Delay) .. "," .. convertFromNumberToHexString(whichOutput-1)
  else
    err("getCommandParamsForAudioDelay: Got bogus source (".. tostring(whichSource) ..")")
  end
  
  return returnString
end

function getCommandParamsForIRDirection(whichOutput)
  local returnString = ""
  if(whichOutput == 1) then
    returnString = convertDirectionFromPropertyToHexString(gIR1DirectionFromSwitchToBalun) .. ",00" 
  elseif(whichOutput == 2) then
    returnString = convertDirectionFromPropertyToHexString(gIR2DirectionFromSwitchToBalun) .. ",01" 
  elseif(whichOutput == 3) then
    returnString = convertDirectionFromPropertyToHexString(gIR3DirectionFromSwitchToBalun) .. ",02" 
  elseif(whichOutput == 4) then
    returnString = convertDirectionFromPropertyToHexString(gIR4DirectionFromSwitchToBalun) .. ",03" 
  elseif(whichOutput == 5) then
    returnString = convertDirectionFromPropertyToHexString(gIR5DirectionFromSwitchToBalun) .. ",04" 
  elseif(whichOutput == 6) then
    returnString = convertDirectionFromPropertyToHexString(gIR6DirectionFromSwitchToBalun) .. ",05" 
  elseif(whichOutput == 7) then
    returnString = convertDirectionFromPropertyToHexString(gIR7DirectionFromSwitchToBalun) .. ",06" 
  elseif(whichOutput == 8) then
    returnString = convertDirectionFromPropertyToHexString(gIR8DirectionFromSwitchToBalun) .. ",07" 
  else
    err("getCommandParamsForIRDirection: Got bogus output (".. whichOutput ..")")
  end
  
  return returnString
end

function getCommandParamsForAnalogAudioVolume(whichOutput)
  local returnString = ""
  if(whichOutput == 1) then
    returnString = convertFromNumberToHexString(gAnalogAudio1Volume) .. ",00" 
  elseif(whichOutput == 2) then
    returnString = convertFromNumberToHexString(gAnalogAudio2Volume) .. ",01" 
  elseif(whichOutput == 3) then
    returnString = convertFromNumberToHexString(gAnalogAudio3Volume) .. ",02" 
  elseif(whichOutput == 4) then
    returnString = convertFromNumberToHexString(gAnalogAudio4Volume) .. ",03" 
  elseif(whichOutput == 5) then
    returnString = convertFromNumberToHexString(gAnalogAudio5Volume) .. ",04" 
  elseif(whichOutput == 6) then
    returnString = convertFromNumberToHexString(gAnalogAudio6Volume) .. ",05" 
  elseif(whichOutput == 7) then
    returnString = convertFromNumberToHexString(gAnalogAudio7Volume) .. ",06" 
  elseif(whichOutput == 8) then
    returnString = convertFromNumberToHexString(gAnalogAudio8Volume) .. ",07" 
  else
    err("getCommandParamsForAudioVolume: Got bogus output (".. whichOutput ..")")
  end
  
  return returnString
end

function getCommandParamsForSourceToOutput(source, output)
  -- minus one on the output since their outputs are 0 indexed, but not on the source since those are 1 indexed.
  local returnString = convertFromNumberToHexString(source) .. "," .. convertFromNumberToHexString(output-1)
  return returnString
end

function getCommandParamsForOutputDisconnect(output)
  -- minus one on the output since their outputs are 0 indexed
  return "00," .. convertFromNumberToHexString(output-1)
end

function sanitizeInputValueFromProxy(source)
  -- first determine range
  --  1000-1999 - Video Input
  --  3000-3999 - Audio Input
  local offset = 0
  local input = 0
  if ( source >= 1000 and source <= 1999) then
    offset = 1000
  elseif(source >= 3000 and source <= 3999) then
    offset = 3000
  else
    err("Received invalid source binding (" .. source .. ")")
  end
  
  --remove offset to get the local output value, then add one since we're one indexed in here
  input = source-offset+1
  
  return input
end

function sanitzeOutputValueFromProxy(zone)
  -- first determine range
  --  2000-2999 - Video Output
  --  4000-4999 - Audio Output
  
  local offset = 0
  local output = 0
  if ( zone >= 2000 and zone <= 2999) then
    offset = 2000
  elseif(zone >= 4000 and zone <= 4999) then
    offset = 4000
  else
    err("Received invalid zone(output) binding (" .. zone .. ")")
  end
  
  --remove offset to get the local output value, then add one since we're one indexed in here
  output = zone-offset+1
  
  return output
end

--------------------------------------------------------------------------------------------------------
-- All timer related stuff
--------------------------------------------------------------------------------------------------------
function OnTimerExpired(idTimer)
  if(gPermaDebug == true) then
    if(idTimer == gDebugTimer) then
      return
    end
  end
  
  if (idTimer == gDebugTimer) then
    dbg('Turning Debug Mode back to Off [default] (timer expired)')
    C4:UpdateProperty('Debug Mode', 'Off')
    gDebugprint = false
    gDebuglog = false
    cancelDebugTimer()
  elseif (idTimer == gPollingTimer) then
    -- This is a repeating timer so don't cancel here
    processPoll()
  elseif (idTimer == gInterCommandDelayTimer) then
    cancelInterCommandDelayTimer()
    processSendQueue()
  elseif (idTimer == gPowerOnStatusDetectionTimer) then
    getPowerStatus()
  elseif (idTimer == gCalibrationCheckTimer) then
    getCalibratingStatus()
  elseif (idTimer == gUpgradeStatusTimer) then
    getUpgradeStatus()
  elseif (idTimer == gDebounceFailedSourceMappingInZone1Timer) then
    dbg("EVENT: Source Selection Failed In Zone 1")
    C4:FireEvent("Zone 1 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone2Timer) then
    dbg("EVENT: Source Selection Failed In Zone 2")
    C4:FireEvent("Zone 2 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone3Timer) then
    dbg("EVENT: Source Selection Failed In Zone 3")
    C4:FireEvent("Zone 3 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone4Timer) then
    dbg("EVENT: Source Selection Failed In Zone 4")
    C4:FireEvent("Zone 4 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone5Timer) then
    dbg("EVENT: Source Selection Failed In Zone 5")
    C4:FireEvent("Zone 5 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone6Timer) then
    dbg("EVENT: Source Selection Failed In Zone 6")
    C4:FireEvent("Zone 6 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone7Timer) then
    dbg("EVENT: Source Selection Failed In Zone 7")
    C4:FireEvent("Zone 7 Select Source Fail")
  elseif (idTimer == gDebounceFailedSourceMappingInZone8Timer) then
    dbg("EVENT: Source Selection Failed In Zone 8")
    C4:FireEvent("Zone 8 Select Source Fail")
  elseif (idTimer == gAfterUpgradeBeginsGetUpgradeStatusTimer) then
    dbg("Timer expired after kicking off the upgrade.  Start asking the device for the upgrade status.")
    startUpgradeStatusTimer()
  elseif (idTimer == gAfterURLSetGetFWVersionTimer) then
    dbg("Timer expired after setting the Uprade URL.  Ask the firmware about the version on the server")
    getFWVersionOnServerFromDevice()
  else
    err('DESTROYING STRAY TIMER: ' .. idTimer)
    C4:KillTimer(idTimer)
  end
end

