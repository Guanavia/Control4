		<script>
			<![CDATA[
lightProxyBinding = 5001
lutronHWBinding = 1

topButtonBinding = 300
bottomButtonBinding = 301
tapButtonBinding = 302
singleTapButtonBinding = 303
doubleTapButtonBinding = 304

function OnPropertyChanged(strProperty)
	dbg("strProperty = "  .. strProperty .. " changed to: " .. Properties[strProperty])

	if (strProperty == "Device Address") then
		g_deviceAddress = Properties[strProperty]
		local tParams = {DEVICE_ID = C4:GetDeviceID(), ADDRESS = g_deviceAddress}
		C4:SendToProxy(lutronHWBinding, "ADD_DRIVER", tParams)
	elseif (strProperty == "Click Ramp Rate Up") then
		gClickRampRateUp = Properties[strProperty] * 1000		-- convert to miliseconds
		dbg ("gClickRampRateUp = " .. gClickRampRateUp)
	elseif (strProperty == "Click Ramp Rate Down") then
		gClickRampRateDown = Properties[strProperty] * 1000		-- convert to miliseconds
	elseif (strProperty == "Debug Mode") then
		if (Properties[strProperty] == "Off") then
			g_debugprint = false
			g_debugunittest = false
			g_debuglog = false
			g_DebugTimer = 0
		elseif (Properties[strProperty] == "Print") then
			g_debugprint = true
			g_debugunittest = false
			g_debuglog = false
			startDebugTimer()
		elseif (Properties[strProperty] == "Log") then
			g_debugprint = false
			g_debugunittest = true
			g_debuglog = true
			startDebugTimer()
		elseif (Properties[strProperty] == "Print and Log") then
			g_debugprint = true
			g_debugunittest = true
			g_debuglog = true
			startDebugTimer()
		end
	else
		dbg("No action performed for " .. strProperty .. " which has been set to: " .. Properties[strProperty])
	end
end

function startDebugTimer()
	if (g_DebugTimer) then
		g_DebugTimer = C4:KillTimer(g_DebugTimer)
	end
	g_DebugTimer = C4:AddTimer(45, "MINUTES")
end

function dbg(strDebugText)
	if (g_debugprint) then print (strDebugText) end
	if (g_debuglog) then C4:ErrorLog("lutron_hw_dimmer: " .. strDebugText) end
end

function dbgUnitTest(strDebugText)
	if (g_debugunittest) then print (strDebugText) end
	if (g_debuglog) then C4:ErrorLog("lutron_hw_dimmer: " .. strDebugText) end
end

function dbgFunction(strFunction)
	local debugFunction = true
	if (g_debugprint and debugFunction) then print ("Function:\t" .. strFunction .. ":") end
	if (g_debuglog  and debugFunction) then C4:ErrorLog("lutron_hw_dimmer: " .. strFunction) end
end

function OnTimerExpired(idTimer)
	if (idTimer == g_DebugTimer) then
		dbg("Turning Debug Mode Off (timer expired)")
		C4:UpdateProperty("Debug Mode", "Off")
	end
	C4:KillTimer(idTimer)
end

-- Release things this driver had allocated...
function OnDriverDestroyed()
	-- Kill open timers
	if (g_DebugTimer ~= nil) then g_DebugTimer = C4:KillTimer(g_DebugTimer) end
end

function SendToProxy(idBinding, strCommand, tParams, ...)
	dbgFunction("SendToProxy (" .. idBinding .. ", " .. strCommand .. ")")
	if (idBinding == lutronHWBinding) then
		tParams["ADDRESS"] = g_deviceAddress
	end
	if ... then
		local callType = ...
		C4:SendToProxy(idBinding, strCommand, tParams, callType)
	else
		C4:SendToProxy(idBinding, strCommand, tParams)
	end
end

function ExecuteCommand(strCommand, tParams)
	dbg("ExecuteCommand function called with : " .. strCommand)
	if (tParams == nil) then
		if (strCommand =="GET_PROPERTIES") then
			SendToProxy(lightProxyBinding, "CLICK_RAMP_RATE_UP", gClickRampRateUp)
			SendToProxy(lightProxyBinding, "CLICK_RAMP_RATE_DOWN", gClickRampRateDown)
		else
			print ("From ExecuteCommand Function - Unutilized command: " .. strCommand)
		end
	end

	-- Proxy Commands
	if (strCommand == "LIGHT_LEVEL_CHANGED") then
		local lightLevel = tParams["LEVEL"]
		gDimmerLevel = lightLevel
		SendToProxy(lightProxyBinding, strCommand, lightLevel)

		if (tonumber(gDimmerLevel) == 0) then gLightState = "False" else gLightState = "True" end
		SendToProxy(topButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
		SendToProxy(bottomButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
		SendToProxy(tapButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
	elseif (strCommand == "TOP_BUTTON_PUSH") then
		SendToProxy(lightProxyBinding, "TOP_BUTTON_PUSH", {})
	elseif (strCommand == "TOP_BUTTON_RELEASE") then
		SendToProxy(lightProxyBinding, "TOP_BUTTON_RELEASE", {})
	elseif (strCommand == "CLICK_COUNT") then
		if (tParams["NUMBER"] == "1") then
			SendToProxy(lightProxyBinding, "CLICK_COUNT", {BUTTON = 0, COUNT = 2})
		end

	-- Device Specific Commands
	elseif (strCommand == "Fade Dimmer") then
		SendToProxy(lutronHWBinding, "FADE_DIMMER", tParams)
	elseif (strCommand == "Raise Dimmer") then
		SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
	elseif (strCommand == "Lower Dimmer") then
		SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
	elseif (strCommand == "Stop Dimmer") then
		SendToProxy(lutronHWBinding, "STOP_DIMMER", {})
	elseif (strCommand == "Flash Dimmer") then
		SendToProxy(lutronHWBinding, "FLASH_DIMMER", tParams)
	elseif (strCommand == "Stop Flashing Dimmer") then
		SendToProxy(lutronHWBinding, "STOP_FLASH_DIMMER", {})
	elseif (strCommand == "Dimmer Button Press") then
		SendToProxy(lutronHWBinding, "SINGLE_TAP", {})
	elseif (strCommand == "Dimmer Button Double Tap") then
		SendToProxy(lutronHWBinding, "DOUBLE_TAP", {})

	-- Events
	elseif (strCommand == "TOP_BUTTON_HOLD") then
		dbg ("Firing Event 1 (Button Hold)")
		C4:FireEvent("Button Hold")
	end
end

function ReceivedFromProxy(idBinding, strCommand, tParams)
	dbgFunction("ReceivedFromProxy (" .. idBinding .. ", " .. strCommand .. ")")
	CommandInterpreter(idBinding, strCommand, tParams)
end

function CommandInterpreter(idBinding, strCommand, tParams)
	if (strCommand ~= nill) then
		if(tParams == nill)    -- initial table variable if nill
			then tParams = {}
		end
		-- dbg("Received from Proxy: " .. strCommand .. " on binding " .. idBinding .. "; Call Function " .. strCommand .. "()")
		if (idBinding == lightProxyBinding) then

			-- notifies
			if (strCommand == "GET_LIGHT_LEVEL") then
				GET_LIGHT_LEVEL(idBinding, tParams)
			elseif (strCommand == "GET_CONNECTED_STATE") then
				SendToProxy(lightProxyBinding, "ONLINE_CHANGED", "True")

			-- commands
			elseif (strCommand == "TOGGLE") then
				TOGGLE(tParams)
			elseif (strCommand == "TOGGLE_PRESET") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "CLICK_TOGGLE_BUTTON") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "PUSH_TOGGLE_BUTTON") then
				if (tonumber(gDimmerLevel) == 0) then
					SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
					gRaiseDimmer = false
				elseif (tonumber(gDimmerLevel) == 100) then
					SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
					gRaiseDimmer = true
				else
					if (gRaiseDimmer) then
						SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
						gRaiseDimmer = false
					else
						SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
						gRaiseDimmer = true
					end
				end
			elseif (strCommand == "RELEASE_TOGGLE_BUTTON") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", tParams)
			elseif (strCommand == "PUSH_TOP_BUTTON") then
				SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", tParams)
			elseif (strCommand == "RELEASE_TOP_BUTTON") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", tParams)
			elseif (strCommand == "PUSH_BOTTOM_BUTTON") then
				SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", tParams)
			elseif (strCommand == "RELEASE_BOTTOM_BUTTON") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", tParams)
			elseif (strCommand == "AV_BINDINGS_CHANGED") then
				local tParams = {DEVICE_ID = C4:GetDeviceID()}
				SendToProxy(lutronHWBinding, "ADD_DRIVER", tParams)
			elseif (strCommand == "SET_CLICK_RAMP_RATE_DOWN") then
				gClickRampRateDown = tParams["RATE"]
				C4:UpdateProperty("Click Ramp Rate Down", gClickRampRateDown/1000)
				dbg ("gClickRampRateDown = " .. gClickRampRateDown)
			elseif (strCommand == "SET_CLICK_RAMP_RATE_UP") then
				gClickRampRateUp = tParams["RATE"]
				C4:UpdateProperty("Click Ramp Rate Up", gClickRampRateUp/1000)
				dbg ("gClickRampRateUp = " .. gClickRampRateUp)
			else
				SendToProxy(lutronHWBinding, strCommand, tParams)
			end
		elseif (idBinding == lutronHWBinding) then
			if (strCommand == "GET_PROPERTIES") then
				local tParams = {DEVICE_ID = C4:GetDeviceID()}
				SendToProxy(lutronHWBinding, "ADD_DRIVER", tParams)
			else
				SendToProxy(lightProxyBinding, strCommand, tParams)
			end
		elseif (idBinding == topButtonBinding) then
			if (strCommand == "DO_CLICK") then
				tParams["LEVEL"] = 100
				tParams["TIME"] = gClickRampRateUp
				SendToProxy(lutronHWBinding, "SET_LEVEL", tParams)
			elseif (strCommand == "DO_PUSH") then
				SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(topButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
			end
		elseif (idBinding == bottomButtonBinding) then
			if (strCommand == "DO_CLICK") then
				tParams["LEVEL"] = 0
				tParams["TIME"] = gClickRampRateDown
				SendToProxy(lutronHWBinding, "SET_LEVEL", tParams)
			elseif (strCommand == "DO_PUSH") then
				SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(bottomButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
			end
		elseif (idBinding == tapButtonBinding) then
			if (strCommand == "DO_CLICK") then
				TOGGLE_PRESET(tParams)
			elseif (strCommand == "DO_PUSH") then
				if (tonumber(gDimmerLevel) == 0) then
					SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
					gRaiseDimmer = false
				elseif (tonumber(gDimmerLevel) == 100) then
					SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
					gRaiseDimmer = true
				else
					if (gRaiseDimmer) then
						SendToProxy(lutronHWBinding, "START_RAISE_DIMMER", {})
						gRaiseDimmer = false
					else
						SendToProxy(lutronHWBinding, "START_LOWER_DIMMER", {})
						gRaiseDimmer = true
					end
				end
			elseif (strCommand == "DO_RELEASE") then
				SendToProxy(lutronHWBinding, "STOP_DIMMER", {})
--			Not currently supported, implement once SDK provides a color chooser
--			elseif (strCommand == "REQUEST_BUTTON_COLORS") then
--				SendToProxy(tapButtonBinding, "MATCH_LED_STATE", {STATE = gLightState})
			end
		elseif (idBinding == singleTapButtonBinding) then
			if (strCommand == "DO_CLICK") then
				SendToProxy(lutronHWBinding, "SINGLE_TAP", tParams)
			end
		elseif (idBinding == doubleTapButtonBinding) then
			if (strCommand == "DO_CLICK") then
				SendToProxy(lutronHWBinding, "DOUBLE_TAP", tParams)
			end
		end
	end
end

function GET_LIGHT_LEVEL(idBinding, tParams)
	cmd = "GET_LIGHT_LEVEL"
	lightLevel = gDimmerLevel
	C4:SendToProxy(idBinding, "LIGHT_LEVEL_CHANGED", lightLevel)
	SendToProxy(lutronHWBinding, "REQUEST_DIMMER_LEVEL", {})
end

function SET_LEVEL(tParams)
	SendToProxy(lutronHWBinding, "SET_LEVEL", tParams)
end

function TOGGLE_PRESET(tParams)
	if (gDimmerLevel == "0") then  -- this ignores presets and should be changed if presets are implemented
		tParams["LEVEL"] = 100
		tParams["TIME"] = gClickRampRateUp
	else
		tParams["LEVEL"] = 0
		tParams["TIME"] = gClickRampRateDown
	end
	SET_LEVEL(tParams)
end

function TOGGLE(tParams)
	if (gDimmerLevel == "0") then  -- this ignores presets and should be changed if presets are implemented
		tParams["LEVEL"] = 100
	else
		tParams["LEVEL"] = 0
	end
	SET_LEVEL(tParams)
end

function OnVariableChanged(strName)
	dbgFunction("OnVariableChanged(" .. strName .. ")")
end

-----------------------------  INIT   -----------------------------
--- global variables ---
g_deviceAddress = ""
gDimmerLevel = 0
gLightState = "False"
gRaiseDimmer = true
gClickRampRateDown = 2000
gClickRampRateUp = 1000

-- Fire On Property Changed to set the initial Headers and other Property global sets, they'll change if Property is changed.
for k,v in pairs(Properties) do
	OnPropertyChanged(k)
end

]]>
		</script>
	</config>
	<capabilities>
		<on_off>True</on_off>
		<set_level>True</set_level>
		<ramp_level>True</ramp_level>
		<can_detach_buttons>False</can_detach_buttons>
		<can_detach_led>False</can_detach_led>
		<has_press_events>True</has_press_events>
		<has_release_events>True</has_release_events>
		<single_button>True</single_button>
		<double_button>False</double_button>
		<do_push>False</do_push>
		<do_release>False</do_release>
		<double_tap_top>True</double_tap_top>
		<double_tap_bottom>False</double_tap_bottom>
		<triple_tap_top>False</triple_tap_top>
		<triple_tap_bottom>False</triple_tap_bottom>
		<button_events>False</button_events>
		<can_buttonpress_device>False</can_buttonpress_device>
		<hide_proxy_events>False</hide_proxy_events>
		<hide_proxy_properties>True</hide_proxy_properties>
	</capabilities>
	<connections>
		<connection>
			<id>1</id>
			<facing>6</facing>
			<connectionname>Lutron HomeWorks Control</connectionname>
			<type>1</type>
			<consumer>True</consumer>
			<audiosource>False</audiosource>
			<videosource>False</videosource>
			<linelevel>True</linelevel>
			<classes>
				<class>
					<classname>LUTRON_HW_DIMMER</classname>
					<autobind>True</autobind>
				</class>
			</classes>
		</connection>
		<connection>
			<id>5001</id>
			<facing>6</facing>
			<connectionname>Light</connectionname>
			<type>2</type>
			<consumer>False</consumer>
			<audiosource>False</audiosource>
			<videosource>False</videosource>
			<linelevel>False</linelevel>
			<classes>
				<class>
					<classname>LIGHT</classname>
				</class>
			</classes>
		</connection>
		<connection>
			<id>300</id>
			<facing>6</facing>
			<connectionname>Top (ON) Button Link</connectionname>
			<type>1</type>
			<consumer>False</consumer>
			<audiosource>False</audiosource>
			<videosource>False</videosource>
			<linelevel>True</linelevel>
			<classes>
				<class>
					<classname>BUTTON_LINK</classname>
				</class>
			</classes>
		</connection>
		<connection>
