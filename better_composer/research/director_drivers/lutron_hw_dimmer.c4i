				<description>Stop NAME</description>
			</command>
			<command>
				<name>Flash Dimmer</name>
				<description>Start flashing NAME at PARAM1 Intensity for PARAM2 : PARAM3 : PARAM4</description>
				<params>
					<param>
						<name>Intensity</name>
