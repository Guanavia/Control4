						<minimum>0</minimum>
						<maximum>100</maximum>
					</param>
					<param>
						<name>Fade Hours</name>
						<type>RANGED_INTEGER</type>
						<minimum>0</minimum>
						<maximum>99</maximum>
					</param>
					<param>
						<name>Fade Minutes</name>
						<type>RANGED_INTEGER</type>
						<minimum>0</minimum>
						<maximum>59</maximum>
					</param>
					<param>
						<name>Fade Seconds</name>
