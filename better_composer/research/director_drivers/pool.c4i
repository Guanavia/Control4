        </conditional>
        <conditional>
            <id>6</id>
            <name>IF_SPA_TEMPERATURE</name>
            <description>the NAME Spa Temperature is LOGIC INTEGER</description>
        </conditional>
        <conditional>
            <id>7</id>
            <name>IF_AIR_TEMPERATURE</name>
            <description>the NAME Air Temperature is LOGIC INTEGER</description>
        </conditional>
    </conditionals>
