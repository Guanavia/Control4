    <commands>
        <command>
            <name>SET_SPA_PUMPMODE</name>
            <description>Set the Spa Pump Mode of NAME to 'STRING'</description>
        </command>
        <command>
            <name>SET_POOL_PUMPMODE</name>
            <description>Set the Pump Mode of NAME to 'STRING'</description>
        </command>
        <command>
            <name>SET_POOL_SETPOINT</name>
            <description>Set the Pool Temperature of NAME to 'INTEGER'</description>
        </command>
        <command>
            <name>SET_SPA_SETPOINT</name>
            <description>Set the Spa Temperature of NAME to 'INTEGER'</description>
        </command>
        <command>
            <name>SET_POOL_HEATMODE</name>
            <description>Set the NAME Pool ANAME Mode to 'STRING'</description>
        </command>
        <command>
            <name>SET_SPA_HEATMODE</name>
            <description>Set the NAME Spa ANAME Mode to 'STRING'</description>
        </command>
        <command>
            <name>SET_AUX_MODE</name>
            <description>Set the NAME Auxiliary Mode [ANAME] to 'MODE'</description>
        </command>
    </commands>
    <conditionals>
        <conditional>
            <id>1</id>
            <name>IF_SPAMODE</name>
            <description>the NAME SPA Pump Mode is STRING</description>
        </conditional>
        <conditional>
            <id>2</id>
            <name>IF_PUMPMODE</name>
            <description>the NAME Pool Pump Mode is STRING</description>
        </conditional>
        <conditional>
            <id>3</id>
            <name>IF_POOL_SETPOINT</name>
            <description>the NAME Pool Set Point is LOGIC INTEGER</description>
        </conditional>
        <conditional>
            <id>4</id>
            <name>IF_SPA_SETPOINT</name>
            <description>the NAME Spa Set Point is LOGIC INTEGER</description>
        </conditional>
        <conditional>
            <id>5</id>
            <name>IF_POOL_TEMPERATURE</name>
