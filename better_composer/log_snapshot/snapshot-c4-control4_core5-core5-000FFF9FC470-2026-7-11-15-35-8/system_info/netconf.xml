<?xml version="1.0"?>
<netconf>
  <hostname>core5</hostname>
  <domain/>
  <nstype>dhcp</nstype>
  <nameserver1/>
  <nameserver2/>
  <nameserver3/>
  <interfaces>
    <interface name="eth0" type="dhcp" enabled="1">
      <address/>
      <bonding enabled="0">
      </bonding>
      <netmask/>
      <gateway/>
